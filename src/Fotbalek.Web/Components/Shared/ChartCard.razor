@* Card containing a Chart.js canvas with a header and a fallback when there's no
   data. Built on the shared Panel surface so it matches every other card in the app. *@

<Panel Class="h-100">
    <Header>
        @if (!string.IsNullOrEmpty(Icon))
        {
            <i class="@Icon"></i>
        }
        <div>
            <h2 class="panel__title">@Title</h2>
            @if (!string.IsNullOrEmpty(Subtitle))
            {
                <div class="text-muted small">@Subtitle</div>
            }
        </div>
    </Header>
    <ChildContent>
        @if (HasData)
        {
            <canvas id="@CanvasId" height="@Height"></canvas>
        }
        else
        {
            <p class="text-muted text-center mb-0">No data available</p>
        }
    </ChildContent>
</Panel>

@code {
    [Parameter, EditorRequired] public string CanvasId { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public int Height { get; set; } = 250;
    [Parameter] public bool HasData { get; set; }
}
