@* Shared site footer — single line, used on every page. *@

<footer class="border-top bg-body py-2 mt-auto">
    <div class="container d-flex flex-wrap justify-content-between align-items-center small text-muted">
        <span>&copy; @Year Fotbalek &middot; @Version</span>
        <span class="d-flex gap-3">
            <a href="@RepoUrl" target="_blank" rel="noopener" class="text-muted text-decoration-none">
                <i class="bi bi-github me-1"></i>GitHub
            </a>
            <a href="@IssuesUrl" target="_blank" rel="noopener" class="text-muted text-decoration-none">
                <i class="bi bi-bug me-1"></i>Report issue
            </a>
        </span>
    </div>
</footer>

@code {
    private const string Version = "v6.7";
    private const string RepoUrl = "https://github.com/DavidS-Kentico/fotbalek";
    private const string IssuesUrl = "https://github.com/DavidS-Kentico/fotbalek/issues";
    private static int Year => DateTime.UtcNow.Year;
}
