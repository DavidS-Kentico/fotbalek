@{
    var team1Players = Match.MatchPlayers.Where(mp => mp.TeamNumber == 1).ToList();
    var team2Players = Match.MatchPlayers.Where(mp => mp.TeamNumber == 2).ToList();
    var team1Won = Match.Team1Score > Match.Team2Score;
    var meInTeam1 = MyPlayerId.HasValue && team1Players.Any(mp => mp.PlayerId == MyPlayerId);
    var meInTeam2 = MyPlayerId.HasValue && team2Players.Any(mp => mp.PlayerId == MyPlayerId);
    var meWon = (team1Won && meInTeam1) || (!team1Won && meInTeam2);
    var meLost = (meInTeam1 || meInTeam2) && !meWon;

    // Both teammates always receive the same ELO change (zero-sum), so show one chip per team.
    // The chip shows the match's own ladder: seasonal ELO change for seasonal matches,
    // all-time change for off-season ones (contextual display rule).
    var isSeasonal = Match.SeasonId != null;
    var team1Change = isSeasonal
        ? team1Players.FirstOrDefault()?.SeasonEloChange ?? 0
        : team1Players.FirstOrDefault()?.EloChange ?? 0;
    var team2Change = isSeasonal
        ? team2Players.FirstOrDefault()?.SeasonEloChange ?? 0
        : team2Players.FirstOrDefault()?.EloChange ?? 0;

    var margin = Math.Abs(Match.Team1Score - Match.Team2Score);
    string? marginLabel = null;
    string? marginCss = null;
    string? marginIcon = null;
    if (margin >= 8) { marginLabel = "Blowout"; marginCss = "bg-warning-subtle text-warning-emphasis"; marginIcon = "bi-fire"; }
    else if (margin == 1) { marginLabel = "Nail-biter"; marginCss = "bg-info-subtle text-info-emphasis"; marginIcon = "bi-lightning-charge"; }

    string DeltaClass(int delta) => delta > 0 ? "bg-success-subtle text-success"
        : delta < 0 ? "bg-danger-subtle text-danger"
        : "bg-secondary-subtle text-secondary";
    string DeltaText(int delta) => (delta > 0 ? "+" : "") + delta.ToString();
}

<div class="card match-card mb-3 position-relative @(Compact ? "" : "shadow-sm") @(meWon ? "border-success" : meLost ? "border-danger" : "")">
    @if (Actions != null)
    {
        <div class="position-absolute top-0 end-0 mt-1 me-1" style="z-index: 2;">
            @Actions
        </div>
    }
    <div class="card-body @(Compact ? "p-2" : "")">
        <div class="d-flex align-items-center match-card-grid">
            <div class="flex-fill match-team match-team-1">
                <div class="d-flex align-items-center justify-content-end gap-2 flex-wrap @(team1Won ? "fw-bold text-success" : "text-muted")">
                    @foreach (var mp in team1Players.OrderBy(p => p.Position))
                    {
                        var isMe = mp.PlayerId == MyPlayerId;
                        <a href="/@TeamCode/players/@mp.PlayerId" class="text-decoration-none text-end @(team1Won ? "text-success" : "text-muted") @(isMe ? "fw-bold" : "")">
                            <Avatar AvatarId="@mp.Player.AvatarId" Size="sm" />
                            <span class="ms-1 @(Compact ? "small" : "")">@mp.Player.Name</span>
                        </a>
                    }
                </div>
            </div>

            <div class="text-center px-3 match-card-score">
                <a href="/@TeamCode/matches/@Match.Id" class="text-decoration-none d-block">
                    <div class="d-flex align-items-center justify-content-center gap-2">
                        <span class="badge @DeltaClass(team1Change) @(Compact ? "small" : "")" title="Team 1 ELO change">
                            @DeltaText(team1Change)
                        </span>
                        @if (team1Won)
                        {
                            <i class="bi bi-trophy-fill text-warning" title="Team 1 won"></i>
                        }
                        <span class="fs-4 fw-bold @(team1Won ? "text-success" : "text-muted")">@Match.Team1Score</span>
                        <span class="fs-4 text-muted">:</span>
                        <span class="fs-4 fw-bold @(!team1Won ? "text-success" : "text-muted")">@Match.Team2Score</span>
                        @if (!team1Won)
                        {
                            <i class="bi bi-trophy-fill text-warning" title="Team 2 won"></i>
                        }
                        <span class="badge @DeltaClass(team2Change) @(Compact ? "small" : "")" title="Team 2 ELO change">
                            @DeltaText(team2Change)
                        </span>
                    </div>
                </a>
            </div>

            <div class="flex-fill match-team match-team-2">
                <div class="d-flex align-items-center gap-2 flex-wrap @(!team1Won ? "fw-bold text-success" : "text-muted")">
                    @foreach (var mp in team2Players.OrderBy(p => p.Position))
                    {
                        var isMe = mp.PlayerId == MyPlayerId;
                        <a href="/@TeamCode/players/@mp.PlayerId" class="text-decoration-none @(!team1Won ? "text-success" : "text-muted") @(isMe ? "fw-bold" : "")">
                            <Avatar AvatarId="@mp.Player.AvatarId" Size="sm" />
                            <span class="ms-1 @(Compact ? "small" : "")">@mp.Player.Name</span>
                        </a>
                    }
                </div>
            </div>
        </div>

        @if (!Compact)
        {
            <div class="row mt-2">
                <div class="col text-center d-flex align-items-center justify-content-center gap-2 flex-wrap">
                    <small class="text-muted">
                        <i class="bi bi-calendar3 me-1"></i>
                        <span class="match-date" data-utc="@Match.PlayedAt.ToString("o")">@Match.PlayedAt.ToString("g")</span>
                    </small>
                    @if (marginLabel != null)
                    {
                        <span class="badge @marginCss" title="@($"Score margin: {margin}")">
                            <i class="bi @marginIcon me-1"></i>@marginLabel
                        </span>
                    }
                    @if (ShowSeasonChip)
                    {
                        @if (SeasonName != null)
                        {
                            <span class="badge bg-success-subtle text-success-emphasis" title="Seasonal match">
                                <i class="bi bi-award me-1"></i>@SeasonName
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary" title="Not part of any season">off-season</span>
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Match Match { get; set; } = null!;
    [Parameter] public string? TeamCode { get; set; }
    [Parameter] public bool Compact { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }

    /// <summary>Show the season / off-season chip (pages enable this once the team has seasons).</summary>
    [Parameter] public bool ShowSeasonChip { get; set; }
    /// <summary>Season name for the chip; null renders a muted "off-season" chip.</summary>
    [Parameter] public string? SeasonName { get; set; }

    [CascadingParameter(Name = "MyPlayerId")] public int? MyPlayerId { get; set; }
}
