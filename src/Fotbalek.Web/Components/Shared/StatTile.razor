@* Summary stat tile — accent stripe, tinted icon chip, big number. Shared across
   the overview, dashboard and stats pages so every summary stat looks the same.
   Style lives in app.css (.stat-card); Variant maps to the accent colour. *@

<div class="stat-card stat-card--@Variant h-100">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <span class="stat-card__icon"><i class="@Icon"></i></span>
    }
    <span class="stat-card__value">@Value</span>
    <span class="stat-card__label">@Label</span>
</div>

@code {
    [Parameter, EditorRequired] public string Variant { get; set; } = "success";
    [Parameter] public string? Icon { get; set; }
    [Parameter, EditorRequired] public string Value { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
}
