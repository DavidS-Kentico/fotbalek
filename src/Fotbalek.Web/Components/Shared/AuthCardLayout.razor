@* Branded, centered onboarding shell shared by Login, Register, Join, Create and
   AdminLogin. Echoes the overview hero: green wordmark + soft green glow, with a
   modern .panel supplied as ChildContent. *@

<div class="auth-shell">
    <div class="auth-shell__inner">
        <a href="/" class="auth-brand">
            <span class="auth-brand__mark">
                <i class="bi bi-trophy-fill"></i>Fotbalek
            </span>
            @if (!string.IsNullOrEmpty(Subtitle))
            {
                <span class="auth-brand__sub">@Subtitle</span>
            }
        </a>

        @ChildContent
    </div>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Subtitle { get; set; }
}
