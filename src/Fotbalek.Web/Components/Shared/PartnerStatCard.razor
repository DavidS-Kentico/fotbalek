@* Compact card highlighting a notable partner or opponent for a player. *@

<div class="panel panel--accent panel--@Variant panel--compact h-100 @(string.IsNullOrEmpty(PlayerName) ? "opacity-50" : "")">
    <div class="panel__head">
        @if (!string.IsNullOrEmpty(Icon))
        {
            <i class="@Icon"></i>
        }
        <h3 class="panel__title">@Title</h3>
    </div>
    <div class="panel__body text-center">
        @if (!string.IsNullOrEmpty(PlayerName))
        {
            <div class="fw-semibold mb-1">@PlayerName</div>
            <div class="fs-5 fw-bold @WinRateClass">@WinRate.ToString("F1")%</div>
            <div class="text-muted small">@Games games</div>
        }
        else
        {
            <div class="fw-semibold text-muted mb-1">—</div>
            <div class="text-muted small fst-italic">Not enough data</div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Icon { get; set; }
    [Parameter, EditorRequired] public string Variant { get; set; } = "success";
    [Parameter] public string? PlayerName { get; set; }
    [Parameter] public double WinRate { get; set; }
    [Parameter] public int Games { get; set; }
    [Parameter] public bool HighlightWin { get; set; } = true;

    private string WinRateClass => HighlightWin ? "text-success" : "text-danger";
}
