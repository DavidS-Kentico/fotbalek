@* Responsive grid of player cards with live name search. Used by the player &
   balance pickers on the New Match page. *@

<div class="player-picker">
    @if (ShowSearchBox)
    {
        <div class="picker-search">
            <i class="bi bi-search picker-search-icon"></i>
            <input type="text" class="form-control" placeholder="Search players…"
                   aria-label="Search players" autocomplete="off" @bind="_search" @bind:event="oninput" />
            @if (!string.IsNullOrWhiteSpace(_search))
            {
                <button type="button" class="picker-search-clear" aria-label="Clear search"
                        @onclick="ClearSearch">
                    <i class="bi bi-x-lg"></i>
                </button>
            }
        </div>
    }

    @{
        var filtered = Filtered.ToList();
    }
    @if (filtered.Count == 0)
    {
        <div class="picker-empty">
            <i class="bi bi-search"></i>
            <span>No players match “@_search”.</span>
        </div>
    }
    else
    {
        <div class="picker-grid">
            @foreach (var player in filtered)
            {
                var isSelected = SelectedIds?.Contains(player.Id) == true;
                var isMe = player.Id == MyPlayerId;
                <button type="button"
                        class="player-pick @(isSelected ? "selected" : "") @(isMe ? "is-me" : "")"
                        disabled="@(DisablePlayer?.Invoke(player) ?? false)"
                        @onclick="() => OnSelect.InvokeAsync(player.Id)">
                    @if (isSelected)
                    {
                        <span class="pick-check"><i class="bi bi-check-lg"></i></span>
                    }
                    <Avatar AvatarId="@player.AvatarId" Size="md" />
                    <span class="pick-name">
                        @player.Name
                        @if (isMe)
                        {
                            <span class="badge badge-you ms-1">you</span>
                        }
                    </span>
                    @if (ShowElo)
                    {
                        <span class="pick-elo">@player.Elo</span>
                    }
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public IEnumerable<Player> Players { get; set; } = [];
    [Parameter] public IReadOnlyCollection<int>? SelectedIds { get; set; }
    [Parameter] public int? MyPlayerId { get; set; }
    [Parameter] public bool ShowElo { get; set; } = true;
    [Parameter] public Func<Player, bool>? DisablePlayer { get; set; }
    [Parameter] public EventCallback<int> OnSelect { get; set; }

    private string _search = string.Empty;

    // Only surface search once the roster is big enough that scanning is a chore.
    private bool ShowSearchBox => Players.Count() > 6;

    private IEnumerable<Player> Filtered =>
        string.IsNullOrWhiteSpace(_search)
            ? Players
            : Players.Where(p => p.Name.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase));

    private void ClearSearch() => _search = string.Empty;
}
