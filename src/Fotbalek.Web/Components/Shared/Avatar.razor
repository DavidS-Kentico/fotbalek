@{
    var (emoji, name) = Avatars.GetValueOrDefault(AvatarId, Avatars[1]);
    var sizeClass = Size switch
    {
        "sm" => "avatar-sm",
        "lg" => "avatar-lg",
        "xl" => "avatar-xl",
        _ => "avatar-md"
    };
}

<span class="avatar @sizeClass @CssClass" title="@(Title ?? name)">@emoji</span>

@code {
    [Parameter] public int AvatarId { get; set; } = 1;
    [Parameter] public string Size { get; set; } = "md";
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public string? Title { get; set; }

    private static readonly IReadOnlyDictionary<int, (string Emoji, string Name)> Avatars = new Dictionary<int, (string, string)>
    {
        { 1,  ("⚽",       "Soccer Ball") },
        { 2,  ("\U0001F981",   "Lion") },
        { 3,  ("\U0001F43A",   "Wolf") },
        { 4,  ("\U0001F985",   "Eagle") },
        { 5,  ("\U0001F409",   "Dragon") },
        { 6,  ("\U0001F525",   "Fire") },
        { 7,  ("⚡",       "Lightning") },
        { 8,  ("\U0001F31F",   "Star") },
        { 9,  ("\U0001F3AF",   "Target") },
        { 10, ("\U0001F451",   "Crown") },
        { 11, ("\U0001F988",   "Shark") },
        { 12, ("\U0001F43B",   "Bear") },
        { 13, ("\U0001F98A",   "Fox") },
        { 14, ("\U0001F427",   "Penguin") },
        { 15, ("\U0001F984",   "Unicorn") },
        { 16, ("\U0001F680",   "Rocket") },
        { 17, ("\U0001F48E",   "Diamond") },
        { 18, ("\U0001F3B8",   "Guitar") },
        { 19, ("\U0001F30A",   "Wave") },
        { 20, ("\U0001F3C6",   "Trophy") },
    };
}
