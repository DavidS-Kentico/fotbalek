@* Standard interior page header: a title (with an optional accented icon) and an
   optional right-aligned Actions area. Keeps page titles consistent across the
   app so their size/spacing can be tuned in one place.

   Usage:
     <PageHeader Title="My account" Icon="bi bi-person-circle">
         <Actions><a href="/" class="btn btn-sm btn-outline-secondary">Overview</a></Actions>
     </PageHeader> *@

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 @Class">
    <div>
        <h1 class="@SizeClass mb-0 d-flex align-items-center gap-2">
            @if (!string.IsNullOrEmpty(Icon))
            {
                <i class="@Icon @IconClass"></i>
            }
            @Title
        </h1>
        @if (!string.IsNullOrEmpty(Subtitle))
        {
            <div class="text-muted small mt-1">@Subtitle</div>
        }
    </div>
    @if (Actions != null)
    {
        <div class="d-flex align-items-center gap-2">@Actions</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;

    /// <summary>Bootstrap-icon class for the leading icon, e.g. "bi bi-people".</summary>
    [Parameter] public string? Icon { get; set; }

    /// <summary>Optional muted sub-line rendered under the title (e.g. counts / context).</summary>
    [Parameter] public string? Subtitle { get; set; }

    /// <summary>Colour class for the leading icon; brand green by default.</summary>
    [Parameter] public string IconClass { get; set; } = "text-success";

    /// <summary>Heading size class. Kept uniform (h4) across pages by default.</summary>
    [Parameter] public string SizeClass { get; set; } = "h4";

    /// <summary>Wrapper classes; controls spacing below the header.</summary>
    [Parameter] public string Class { get; set; } = "mb-4";

    /// <summary>Right-aligned action content (buttons, links).</summary>
    [Parameter] public RenderFragment? Actions { get; set; }
}
