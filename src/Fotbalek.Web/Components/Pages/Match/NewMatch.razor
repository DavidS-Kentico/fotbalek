@page "/team/{TeamCode}/match/new"
@layout TeamLayout
@rendermode InteractiveServer
@attribute [Authorize]
@inject CurrentTeamProvider TeamAccess
@inject IScopedSender Sender

<PageTitle>New Match - Foosball Manager</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_players.Count < 4)
{
    <PageContainer Focused>
        <AlertMessage Variant="warning" Icon="bi bi-exclamation-triangle">
            You need at least 4 active players to record a match.
            <a href="/team/@TeamCode/players" class="alert-link">Add more players</a>
        </AlertMessage>
    </PageContainer>
}
else
{
    <PageContainer Focused>
        <PageHeader Title="New Match" Icon="bi bi-plus-circle" />

        <AlertMessage Message="@_error" Variant="danger" Dismissible="true" OnDismiss="() => _error = null" />

        @if (_activeSeason != null)
        {
            <div class="newmatch-season @(_seasonalToggle ? "is-seasonal" : "")">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" id="seasonalToggle"
                           checked="@_seasonalToggle" @onchange="OnSeasonalToggleChanged" />
                    <label class="form-check-label" for="seasonalToggle">
                        <i class="bi bi-trophy me-1 text-success"></i>Seasonal match
                        <span class="fw-semibold">(@_activeSeason.Name)</span>
                    </label>
                </div>
                <small class="text-muted ms-auto">
                    @(_seasonalToggle
                        ? "Counts toward the season ladder — ELO shown is seasonal."
                        : "Will be recorded off-season — only all-time ELO is affected.")
                </small>
            </div>
        }
        else if (_hasAnySeason)
        {
            <div class="newmatch-season">
                <small class="text-muted">
                    <i class="bi bi-info-circle me-1"></i>No season is currently active — this match will be recorded <strong>off-season</strong>.
                </small>
            </div>
        }

        <div class="newmatch-grid">
            @* ── Left: who plays ── *@
            <Panel Title="Lineup" Icon="bi bi-people-fill">
                <Actions>
                    <button class="btn btn-outline-success btn-sm" @onclick="OpenBalancePicker"
                            title="Pick 4 players and split them into balanced teams">
                        <i class="bi bi-shuffle me-1"></i> Pick &amp; balance
                    </button>
                </Actions>
                <ChildContent>
                    <div class="lineup-status @(AllPlayersSelected ? "ready" : "")">
                        <span class="status-icon">
                            <i class="bi @(AllPlayersSelected ? "bi-check-lg" : "bi-people-fill")"></i>
                        </span>
                        <span>
                            @if (AllPlayersSelected)
                            {
                                <text>Lineup ready</text>
                            }
                            else
                            {
                                <text>@(4 - PlayersSelectedCount) more @(PlayersSelectedCount == 3 ? "player" : "players") to pick</text>
                            }
                        </span>
                        @if (PlayersSelectedCount > 0)
                        {
                            <button class="btn btn-link btn-sm text-muted text-decoration-none ms-auto p-0" @onclick="ResetMatch">
                                <i class="bi bi-arrow-counterclockwise me-1"></i> Clear
                            </button>
                        }
                    </div>

                    <div class="foosball-table-container">
                        <div class="foosball-table">
                            <div class="team-side team-1-side">
                                <div class="team-label">
                                    <div class="team-label-row">
                                        <span>Team 1</span>
                                        @if (Team1AvgIfReady is int t1Avg)
                                        {
                                            <span class="team-avg-elo">ELO @t1Avg</span>
                                        }
                                    </div>
                                </div>
                                <div class="player-positions">
                                    <PlayerSlot Team="1" IsGoalkeeper="false" Player="GetPlayer(Team1AtkId)" MyPlayerId="MyPlayerId"
                                                OnSelect="() => OpenPlayerPicker(1, false)" OnRemove="() => RemovePlayer(1, false)" />
                                    <button class="swap-btn" @onclick="() => SwapPositions(1)" title="Swap positions">
                                        <i class="bi bi-arrow-left-right"></i>
                                    </button>
                                    <PlayerSlot Team="1" IsGoalkeeper="true" Player="GetPlayer(Team1GkId)" MyPlayerId="MyPlayerId"
                                                OnSelect="() => OpenPlayerPicker(1, true)" OnRemove="() => RemovePlayer(1, true)" />
                                </div>
                            </div>

                            <div class="midfield-line"></div>

                            <div class="team-side team-2-side">
                                <div class="player-positions">
                                    <PlayerSlot Team="2" IsGoalkeeper="true" Player="GetPlayer(Team2GkId)" MyPlayerId="MyPlayerId"
                                                OnSelect="() => OpenPlayerPicker(2, true)" OnRemove="() => RemovePlayer(2, true)" />
                                    <button class="swap-btn" @onclick="() => SwapPositions(2)" title="Swap positions">
                                        <i class="bi bi-arrow-left-right"></i>
                                    </button>
                                    <PlayerSlot Team="2" IsGoalkeeper="false" Player="GetPlayer(Team2AtkId)" MyPlayerId="MyPlayerId"
                                                OnSelect="() => OpenPlayerPicker(2, false)" OnRemove="() => RemovePlayer(2, false)" />
                                </div>
                                <div class="team-label">
                                    <div class="team-label-row">
                                        <span>Team 2</span>
                                        @if (Team2AvgIfReady is int t2Avg)
                                        {
                                            <span class="team-avg-elo">ELO @t2Avg</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </ChildContent>
            </Panel>

            @* ── Right: the result ── *@
            <Panel Title="Match result" Icon="bi bi-flag-fill">
                <ChildContent>
                    @if (_showSuccess)
                    {
                        <div class="match-recorded">
                            <div class="match-recorded__icon"><i class="bi bi-check-circle-fill"></i></div>
                            <div class="match-recorded__title">Match recorded!</div>
                            <div class="match-recorded__msg">@_successMessage</div>
                            <div class="match-recorded__actions">
                                <button class="btn btn-success" @onclick="PlayAgain">
                                    <i class="bi bi-arrow-repeat me-1"></i> Play again
                                </button>
                                <button class="btn btn-outline-secondary" @onclick="ResetMatch">
                                    <i class="bi bi-plus-lg me-1"></i> New match
                                </button>
                            </div>
                            @if (_recordedMatchId is int mid)
                            {
                                <a href="/team/@TeamCode/matches/@mid" class="match-recorded__link">
                                    View match details <i class="bi bi-arrow-right"></i>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        @if (AllPlayersSelected)
                        {
                            <div class="result-section match-preview">
                                <span class="section-label">Prediction</span>
                                <div class="elo-comparison">
                                    <div class="elo-side team-1">
                                        <span class="label">Team 1</span>
                                        <span class="value">@Team1AvgElo</span>
                                    </div>
                                    <div class="elo-vs">vs</div>
                                    <div class="elo-side team-2">
                                        <span class="label">Team 2</span>
                                        <span class="value">@Team2AvgElo</span>
                                    </div>
                                </div>
                                <div class="win-probability-bar">
                                    <div class="prob-fill team-1" style="width: @Team1WinProb%">
                                        @if (Team1WinProb >= 12)
                                        {
                                            <span>@Team1WinProb%</span>
                                        }
                                    </div>
                                    <div class="prob-fill team-2" style="width: @Team2WinProb%">
                                        @if (Team2WinProb >= 12)
                                        {
                                            <span>@Team2WinProb%</span>
                                        }
                                    </div>
                                </div>
                                <div class="match-preview-footer">
                                    <i class="bi bi-bar-chart-fill me-1"></i> Based on @(UseSeasonalLadder ? "seasonal" : "all-time") team ELO
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="result-hint text-muted small">
                                <i class="bi bi-arrow-up d-lg-none me-1"></i><i class="bi bi-arrow-left d-none d-lg-inline me-1"></i>Pick all four players to see the win probability.
                            </p>
                        }

                        <div class="result-section">
                            <span class="section-label">Who won?</span>
                            <div class="outcome-cards">
                                @OutcomeCard(1)
                                @OutcomeCard(2)
                            </div>
                        </div>

                        <div class="result-section">
                            <span class="section-label">Final score</span>
                            <div class="score-card-inputs">
                                <input type="number" class="form-control form-control-lg text-center score-input"
                                       min="0" max="10" @bind="Team1Score" />
                                <span class="fs-3 text-muted">:</span>
                                <input type="number" class="form-control form-control-lg text-center score-input"
                                       min="0" max="10" @bind="Team2Score" />
                            </div>
                        </div>

                        <SpinnerButton CssClass="btn-lg w-100 record-match-btn" Busy="_saving" Disabled="!IsValid()"
                                       Icon="bi bi-check-lg" OnClick="SubmitMatch">
                            Record Match
                        </SpinnerButton>
                        @if (!IsValid())
                        {
                            <div class="text-center mt-2">
                                <small class="text-muted">@GetValidationMessage()</small>
                            </div>
                        }
                    }
                </ChildContent>
            </Panel>
        </div>
    </PageContainer>

    <Modal Show="_showBalancePicker" Title="Balance Teams" Icon="bi bi-shuffle" Size="lg" OnClose="CloseBalancePicker">
        <Body>
            <p class="text-muted small mb-3">Pick exactly 4 players. We'll split them into the most balanced 2v2 and assign positions.</p>
            <PlayerPickerGrid Players="@_players.OrderByDescending(p => p.Id == MyPlayerId).ThenBy(p => p.Name)"
                              SelectedIds="_balanceSelectedIds"
                              MyPlayerId="MyPlayerId"
                              OnSelect="ToggleBalanceSelection" />
        </Body>
        <Footer>
            <span class="me-auto text-muted small">@_balanceSelectedIds.Count / 4 selected</span>
            <button class="btn btn-secondary" @onclick="CloseBalancePicker">Cancel</button>
            <SpinnerButton Icon="bi bi-shuffle" Disabled="_balanceSelectedIds.Count != 4" OnClick="ApplyBalance">
                Balance
            </SpinnerButton>
        </Footer>
    </Modal>

    <Modal Show="_showPlayerPicker" Title="Select Player" OnClose="ClosePlayerPicker">
        <Body>
            <PlayerPickerGrid Players="GetAvailablePlayers()" MyPlayerId="MyPlayerId" OnSelect="SelectPlayer" />
        </Body>
    </Modal>
}

@code {
    [Parameter] public string TeamCode { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "rematch")]
    public int? RematchId { get; set; }

    private TeamDto? _team;
    private bool _loading = true;
    private List<PlayerDto> _players = [];
    [CascadingParameter(Name = "MyPlayerId")] public int? MyPlayerId { get; set; }

    private int Team1GkId { get; set; }
    private int Team1AtkId { get; set; }
    private int Team2GkId { get; set; }
    private int Team2AtkId { get; set; }
    private int Team1Score { get; set; }
    private int Team2Score { get; set; }

    private bool _showPlayerPicker;
    private int _pickerTeam;
    private bool _pickerIsGk;

    private bool _showBalancePicker;
    private readonly HashSet<int> _balanceSelectedIds = new();

    private bool _saving;
    private string? _error;
    private bool _showSuccess;
    private string? _successMessage;
    private int? _recordedMatchId;

    private SeasonDto? _activeSeason;
    private bool _hasAnySeason;
    private bool _seasonalToggle;
    private Dictionary<int, int> _seasonEloByPlayer = new();

    // Matchmaking uses the match's ladder: seasonal ELO when the match will be seasonal
    // (toggle on, the default), all-time ELO for off-season matches.
    private bool UseSeasonalLadder => _seasonalToggle && _activeSeason != null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _team = await TeamAccess.GetCurrentTeamAsync();
        if (_team != null)
        {
            _players = (await Sender.Send(new GetTeamPlayersQuery(_team.Id))).Value;
            await LoadSeasonContextAsync();
            _seasonalToggle = _activeSeason != null; // checked by default when a season is active
            await TryPrefillFromRematchAsync();
        }
        _loading = false;
        StateHasChanged();
    }

    private async Task LoadSeasonContextAsync()
    {
        if (_team == null) return;
        _hasAnySeason = (await Sender.Send(new HasAnySeasonQuery(_team.Id))).Value;
        _activeSeason = _hasAnySeason ? (await Sender.Send(new GetActiveSeasonQuery(_team.Id))).Value : null;
        _seasonEloByPlayer = _activeSeason != null
            ? (await Sender.Send(new GetSeasonEloMapQuery(_activeSeason.Id))).Value
            : new Dictionary<int, int>();
    }

    private void OnSeasonalToggleChanged(ChangeEventArgs e)
    {
        // Toggling re-evaluates matchmaking numbers — they all read EloOf, which follows the ladder.
        _seasonalToggle = e.Value is bool b && b;
    }

    private async Task TryPrefillFromRematchAsync()
    {
        if (RematchId is not int id || _team == null) return;

        var source = (await Sender.Send(new GetMatchQuery(_team.Id, id))).Value;
        if (source == null) return;

        int Pick(int team, string position)
        {
            var mp = source.MatchPlayers.FirstOrDefault(p => p.TeamNumber == team && p.Position == position);
            if (mp == null) return 0;
            // Only prefill players who still exist on the roster and are active.
            return _players.Any(p => p.Id == mp.PlayerId && p.IsActive) ? mp.PlayerId : 0;
        }

        Team1GkId  = Pick(1, Constants.Positions.Goalkeeper);
        Team1AtkId = Pick(1, Constants.Positions.Attacker);
        Team2GkId  = Pick(2, Constants.Positions.Goalkeeper);
        Team2AtkId = Pick(2, Constants.Positions.Attacker);
    }

    private PlayerDto? GetPlayer(int id) => id > 0 ? _players.FirstOrDefault(p => p.Id == id) : null;

    private void OpenPlayerPicker(int team, bool isGk)
    {
        _pickerTeam = team;
        _pickerIsGk = isGk;
        _showPlayerPicker = true;
    }

    private void ClosePlayerPicker() => _showPlayerPicker = false;

    private IEnumerable<PlayerDto> GetAvailablePlayers()
    {
        var selectedIds = new HashSet<int> { Team1GkId, Team1AtkId, Team2GkId, Team2AtkId };

        var currentId = (_pickerTeam, _pickerIsGk) switch
        {
            (1, true) => Team1GkId,
            (1, false) => Team1AtkId,
            (2, true) => Team2GkId,
            (2, false) => Team2AtkId,
            _ => 0
        };

        return _players
            .Where(p => !selectedIds.Contains(p.Id) || p.Id == currentId)
            .OrderByDescending(p => p.Id == MyPlayerId)
            .ThenBy(p => p.Name);
    }

    private void SelectPlayer(int playerId)
    {
        switch ((_pickerTeam, _pickerIsGk))
        {
            case (1, true):  Team1GkId  = playerId; break;
            case (1, false): Team1AtkId = playerId; break;
            case (2, true):  Team2GkId  = playerId; break;
            case (2, false): Team2AtkId = playerId; break;
        }
        ClosePlayerPicker();
    }

    private int PlayersSelectedCount =>
        new[] { Team1AtkId, Team1GkId, Team2AtkId, Team2GkId }.Count(id => id > 0);

    private bool AllPlayersSelected
    {
        get
        {
            if (Team1AtkId == 0 || Team1GkId == 0 || Team2AtkId == 0 || Team2GkId == 0) return false;
            return new[] { Team1AtkId, Team1GkId, Team2AtkId, Team2GkId }.Distinct().Count() == 4;
        }
    }

    // UI-only preview math, formula-identical to Domain's EloCalculator (Web references Domain
    // only for Identity plumbing per §2; the authoritative values come from CreateMatchCommand).
    private static int PreviewTeamElo(int player1Elo, int player2Elo) => (player1Elo + player2Elo) / 2;

    private static int PreviewEloChange(int team1Elo, int team2Elo, bool team1Won)
    {
        var expected1 = 1.0 / (1.0 + Math.Pow(10, (team2Elo - team1Elo) / 400.0));
        var actual1 = team1Won ? 1.0 : 0.0;
        return (int)Math.Round(Constants.Elo.KFactor * (actual1 - expected1));
    }

    private int? Team1AvgIfReady => (Team1AtkId > 0 && Team1GkId > 0)
        ? PreviewTeamElo(EloOf(Team1AtkId), EloOf(Team1GkId))
        : null;

    private int? Team2AvgIfReady => (Team2AtkId > 0 && Team2GkId > 0)
        ? PreviewTeamElo(EloOf(Team2AtkId), EloOf(Team2GkId))
        : null;

    private int Team1AvgElo => Team1AvgIfReady ?? 0;
    private int Team2AvgElo => Team2AvgIfReady ?? 0;

    private int Team1WinProb
    {
        get
        {
            if (!AllPlayersSelected) return 50;
            var expected = 1.0 / (1.0 + Math.Pow(10, (Team2AvgElo - Team1AvgElo) / 400.0));
            return (int)Math.Round(expected * 100);
        }
    }

    private int Team2WinProb => 100 - Team1WinProb;

    private int GetWinDelta(int winningTeam)
    {
        if (!AllPlayersSelected) return 0;
        var change1 = PreviewEloChange(Team1AvgElo, Team2AvgElo, winningTeam == 1);
        return winningTeam == 1 ? change1 : -change1;
    }

    // The match's own ladder: seasonal ELO (players without a ladder row count as 1000)
    // when the match will be seasonal, all-time ELO otherwise.
    private int EloOf(int playerId) => UseSeasonalLadder
        ? _seasonEloByPlayer.GetValueOrDefault(playerId, Constants.Elo.DefaultRating)
        : _players.First(p => p.Id == playerId).Elo;

    private void OpenBalancePicker()
    {
        _balanceSelectedIds.Clear();
        foreach (var id in new[] { Team1AtkId, Team1GkId, Team2AtkId, Team2GkId })
        {
            if (id > 0) _balanceSelectedIds.Add(id);
        }
        _showBalancePicker = true;
    }

    private void CloseBalancePicker() => _showBalancePicker = false;

    private void ToggleBalanceSelection(int playerId)
    {
        if (!_balanceSelectedIds.Remove(playerId) && _balanceSelectedIds.Count < 4)
        {
            _balanceSelectedIds.Add(playerId);
        }
    }

    private void ApplyBalance()
    {
        if (_balanceSelectedIds.Count != 4) return;

        var picked = _balanceSelectedIds.Select(id => _players.First(p => p.Id == id)).ToList();

        // Three possible 2v2 splits — pick the one minimizing team ELO gap (on the match's ladder).
        var splits = new (PlayerDto a1, PlayerDto a2, PlayerDto b1, PlayerDto b2)[]
        {
            (picked[0], picked[1], picked[2], picked[3]),
            (picked[0], picked[2], picked[1], picked[3]),
            (picked[0], picked[3], picked[1], picked[2]),
        };

        var best = splits.OrderBy(s => Math.Abs((EloOf(s.a1.Id) + EloOf(s.a2.Id)) - (EloOf(s.b1.Id) + EloOf(s.b2.Id)))).First();

        // Assign positions to minimize per-position imbalance across teams.
        PlayerDto bestAtk1 = best.a1, bestGk1 = best.a2, bestAtk2 = best.b1, bestGk2 = best.b2;
        var bestScore = int.MaxValue;
        foreach (var swap1 in new[] { false, true })
        foreach (var swap2 in new[] { false, true })
        {
            var atk1 = swap1 ? best.a2 : best.a1;
            var gk1  = swap1 ? best.a1 : best.a2;
            var atk2 = swap2 ? best.b2 : best.b1;
            var gk2  = swap2 ? best.b1 : best.b2;
            var score = Math.Abs(EloOf(atk1.Id) - EloOf(atk2.Id)) + Math.Abs(EloOf(gk1.Id) - EloOf(gk2.Id));
            if (score < bestScore)
            {
                bestScore = score;
                bestAtk1 = atk1; bestGk1 = gk1; bestAtk2 = atk2; bestGk2 = gk2;
            }
        }

        Team1AtkId = bestAtk1.Id;
        Team1GkId = bestGk1.Id;
        Team2AtkId = bestAtk2.Id;
        Team2GkId = bestGk2.Id;

        _showBalancePicker = false;
    }

    private void SwapPositions(int team)
    {
        if (team == 1) (Team1GkId, Team1AtkId) = (Team1AtkId, Team1GkId);
        else (Team2GkId, Team2AtkId) = (Team2AtkId, Team2GkId);
    }

    private void RemovePlayer(int team, bool isGk)
    {
        switch ((team, isGk))
        {
            case (1, true):  Team1GkId  = 0; break;
            case (1, false): Team1AtkId = 0; break;
            case (2, true):  Team2GkId  = 0; break;
            case (2, false): Team2AtkId = 0; break;
        }
    }

    private void SetWinner(int team)
    {
        if (!AllPlayersSelected) return;

        if (team == 1)
        {
            Team1Score = 10;
            if (Team2Score >= 10) Team2Score = 9;
        }
        else
        {
            Team2Score = 10;
            if (Team1Score >= 10) Team1Score = 9;
        }
    }

    private bool IsValid()
    {
        if (Team1GkId == 0 || Team1AtkId == 0 || Team2GkId == 0 || Team2AtkId == 0) return false;
        if (new[] { Team1GkId, Team1AtkId, Team2GkId, Team2AtkId }.Distinct().Count() != 4) return false;
        if (Team1Score < 0 || Team1Score > 10 || Team2Score < 0 || Team2Score > 10) return false;
        if (Team1Score == Team2Score) return false;
        if (Team1Score != 10 && Team2Score != 10) return false;
        return true;
    }

    private string GetValidationMessage()
    {
        if (Team1GkId == 0 || Team1AtkId == 0 || Team2GkId == 0 || Team2AtkId == 0) return "Select all 4 players";
        if (Team1Score == Team2Score) return "Scores cannot be equal (no ties)";
        if (Team1Score != 10 && Team2Score != 10) return "At least one team must score 10";
        return "";
    }

    private async Task SubmitMatch()
    {
        if (_team == null || !IsValid()) return;

        _error = null;
        _saving = true;
        _showSuccess = false;

        try
        {
            var creation = await Sender.Send(new CreateMatchCommand(
                _team.Id,
                Team1GkId, Team1AtkId,
                Team2GkId, Team2AtkId,
                Team1Score, Team2Score,
                Seasonal: UseSeasonalLadder));
            if (creation.IsFailure)
            {
                _error = creation.Error.Message;
                return;
            }
            var result = creation.Value;

            _players = (await Sender.Send(new GetTeamPlayersQuery(_team.Id))).Value;
            await LoadSeasonContextAsync();
            if (_activeSeason == null) _seasonalToggle = false;

            // Winner determined by score; the ELO change shown comes from the match's own ladder
            // (seasonal by default, per the contextual display rule).
            var match = result.Match;
            _recordedMatchId = match.Id;
            var winningTeamNumber = match.Team1Score > match.Team2Score ? 1 : 2;
            var winningPlayer = match.MatchPlayers.First(mp => mp.TeamNumber == winningTeamNumber);
            var winner = winningTeamNumber == 1 ? "Team 1" : "Team 2";
            var eloDelta = result.Season != null
                ? winningPlayer.SeasonEloChange ?? 0
                : winningPlayer.EloChange;
            var ladderLabel = result.Season != null ? $"seasonal ELO ({result.Season.Name})" : "ELO";
            _successMessage = $"{winner} wins! {ladderLabel} change: {(eloDelta >= 0 ? "+" : "")}{eloDelta}";
            if (result.SeasonalFallback)
            {
                _successMessage += " — the season ended in the meantime, so the match was recorded off-season.";
            }
            _showSuccess = true;
        }
        catch (Exception)
        {
            _error = "Something went wrong. Please try again.";
        }
        finally
        {
            _saving = false;
        }
    }

    private void PlayAgain()
    {
        Team1Score = 0;
        Team2Score = 0;
        _showSuccess = false;
        _recordedMatchId = null;
    }

    private void ResetMatch()
    {
        Team1GkId = 0;
        Team1AtkId = 0;
        Team2GkId = 0;
        Team2AtkId = 0;
        Team1Score = 0;
        Team2Score = 0;
        _showSuccess = false;
        _recordedMatchId = null;
    }

    private RenderFragment OutcomeCard(int team) => __builder =>
    {
        var teamWon = team == 1 ? Team1Score > Team2Score : Team2Score > Team1Score;
        var activeClass = IsValid() && teamWon ? "active" : "";

        <button type="button" class="outcome-card team-@team @activeClass"
                @onclick="() => SetWinner(team)" disabled="@(!AllPlayersSelected)">
            <i class="bi bi-trophy-fill trophy-icon"></i>
            <span class="outcome-label">Team @team Wins</span>
            @if (AllPlayersSelected)
            {
                <span class="elo-delta">
                    <span class="gain">+@GetWinDelta(team)</span>
                    <span class="text-muted">/</span>
                    <span class="loss">-@GetWinDelta(team)</span>
                </span>
            }
            else
            {
                <span class="elo-delta text-muted">pick lineup</span>
            }
        </button>;
    };
}
