@page "/{TeamCode}/matches/{MatchId:int}"
@layout TeamLayout
@rendermode InteractiveServer
@attribute [Authorize]
@inject TeamAccessService TeamAccess
@inject MatchService MatchService
@inject SeasonService SeasonService
@inject CurrentUserService CurrentUser
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Match Detail - Foosball Manager</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_match != null)
{
    var team1Players = _match.MatchPlayers.Where(mp => mp.TeamNumber == 1).OrderBy(mp => mp.Position).ToList();
    var team2Players = _match.MatchPlayers.Where(mp => mp.TeamNumber == 2).OrderBy(mp => mp.Position).ToList();
    var team1Won = _match.Team1Score > _match.Team2Score;

    var margin = Math.Abs(_match.Team1Score - _match.Team2Score);
    string? marginLabel = margin >= 8 ? "Blowout" : margin == 1 ? "Nail-biter" : null;
    string? marginCss = margin >= 8 ? "bg-warning-subtle text-warning-emphasis"
                       : margin == 1 ? "bg-info-subtle text-info-emphasis"
                       : null;
    string? marginIcon = margin >= 8 ? "bi-fire" : margin == 1 ? "bi-lightning-charge" : null;

    var winners = (team1Won ? team1Players : team2Players);
    var losers  = (team1Won ? team2Players : team1Players);

    // Pre-match prediction based on the match's own ladder (team ELO = avg of the two players):
    // seasonal EloBefore for seasonal matches, all-time otherwise.
    var isSeasonal = _match.SeasonId != null;
    var team1AvgBefore = (int)Math.Round(team1Players.Average(p => (double)(isSeasonal ? p.SeasonEloBefore ?? 0 : p.EloBefore)));
    var team2AvgBefore = (int)Math.Round(team2Players.Average(p => (double)(isSeasonal ? p.SeasonEloBefore ?? 0 : p.EloBefore)));
    var team1WinProb = 1.0 / (1.0 + Math.Pow(10, (team2AvgBefore - team1AvgBefore) / 400.0));
    var team2WinProb = 1.0 - team1WinProb;
    var team1Pct = (int)Math.Round(team1WinProb * 100);
    var team2Pct = 100 - team1Pct;
    var winnerProb = team1Won ? team1WinProb : team2WinProb;
    var isUpset = winnerProb < 0.5;
    // Eloquent gap label
    var eloGap = Math.Abs(team1AvgBefore - team2AvgBefore);
    string gapLabel = eloGap < 25 ? "Evenly matched"
        : eloGap < 75 ? "Slight favorite"
        : eloGap < 150 ? "Clear favorite"
        : "Heavy favorite";

    <div class="container py-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/@TeamCode">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/@TeamCode/matches">Matches</a></li>
                <li class="breadcrumb-item active">Match #@MatchId</li>
            </ol>
        </nav>

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div class="btn-group">
                <a class="btn btn-outline-secondary btn-sm @(_olderId == null ? "disabled" : "")"
                   href="@(_olderId != null ? $"/{TeamCode}/matches/{_olderId}" : "#")"
                   aria-disabled="@(_olderId == null)" title="Older match">
                    <i class="bi bi-chevron-left"></i> Older
                </a>
                <a class="btn btn-outline-secondary btn-sm @(_newerId == null ? "disabled" : "")"
                   href="@(_newerId != null ? $"/{TeamCode}/matches/{_newerId}" : "#")"
                   aria-disabled="@(_newerId == null)" title="Newer match">
                    Newer <i class="bi bi-chevron-right"></i>
                </a>
            </div>

            <div class="d-flex gap-2">
                <a href="/@TeamCode/match/new?rematch=@MatchId" class="btn btn-success btn-sm">
                    <i class="bi bi-arrow-repeat me-1"></i> Rematch
                </a>
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CopyLink" title="Copy link">
                    <i class="bi @(_copied ? "bi-check2" : "bi-link-45deg") me-1"></i>@(_copied ? "Copied" : "Copy link")
                </button>
                @if (_isAdmin && _canDelete)
                {
                    <button class="btn btn-outline-danger btn-sm" @onclick="() => _showDeleteConfirm = true">
                        <i class="bi bi-trash me-1"></i> Delete
                    </button>
                }
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="mb-0">
                    <i class="bi bi-calendar3 me-2"></i>
                    <span class="match-date" data-utc="@_match.PlayedAt.ToString("o")">@_match.PlayedAt.ToString("f")</span>
                </h5>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    @if (isSeasonal)
                    {
                        <span class="badge bg-success-subtle text-success-emphasis" title="Seasonal match — numbers below show the seasonal ladder">
                            <i class="bi bi-award me-1"></i>@(_match.Season?.Name ?? "Season")
                        </span>
                    }
                    else if (_hasAnySeason)
                    {
                        <span class="badge bg-secondary-subtle text-secondary" title="Not part of any season">off-season</span>
                    }
                    <span class="badge bg-secondary">Margin @margin</span>
                    @if (marginLabel != null)
                    {
                        <span class="badge @marginCss"><i class="bi @marginIcon me-1"></i>@marginLabel</span>
                    }
                </div>
            </div>
            <div class="card-body">
                <div class="row align-items-center text-center mb-4">
                    <div class="col-5">
                        <h6 class="text-warning fw-bold">Team 1 @(team1Won ? "(Winner)" : "")</h6>
                    </div>
                    <div class="col-2">
                        <div class="d-flex align-items-center justify-content-center gap-2">
                            <span class="display-4 fw-bold @(team1Won ? "text-success" : "text-muted")">@_match.Team1Score</span>
                            <span class="display-5 text-muted">:</span>
                            <span class="display-4 fw-bold @(!team1Won ? "text-success" : "text-muted")">@_match.Team2Score</span>
                        </div>
                    </div>
                    <div class="col-5">
                        <h6 class="text-primary fw-bold">Team 2 @(!team1Won ? "(Winner)" : "")</h6>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <MatchTeamPanel Title="Team 1" Players="team1Players" TeamCode="@TeamCode" IsWinner="team1Won" HeaderVariant="warning" IsSeasonal="isSeasonal" />
                    </div>
                    <div class="col-md-6">
                        <MatchTeamPanel Title="Team 2" Players="team2Players" TeamCode="@TeamCode" IsWinner="!team1Won" HeaderVariant="primary" IsSeasonal="isSeasonal" />
                    </div>
                </div>

                <div class="row mt-4 g-3">
                    <div class="col-12">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                                <div class="text-muted small">
                                    <i class="bi bi-bullseye me-1"></i>Pre-match prediction
                                    <span class="ms-2 badge bg-light text-muted">@gapLabel</span>
                                </div>
                                @if (isUpset)
                                {
                                    <span class="badge bg-warning-subtle text-warning-emphasis" title="@($"Winner had only {(int)Math.Round(winnerProb * 100)}% predicted win chance")">
                                        <i class="bi bi-stars me-1"></i>Upset!
                                    </span>
                                }
                            </div>
                            <div class="row align-items-center g-2">
                                <div class="col-md-3 text-md-end">
                                    <div class="fw-semibold @(team1Won ? "text-success" : "text-muted")">
                                        Team 1
                                        @if (team1Won) { <i class="bi bi-trophy-fill ms-1"></i> }
                                    </div>
                                    <small class="text-muted">avg ELO @team1AvgBefore</small>
                                </div>
                                <div class="col-md-6">
                                    <div class="progress" style="height: 18px;" role="progressbar"
                                         aria-label="Win probability" aria-valuenow="@team1Pct" aria-valuemin="0" aria-valuemax="100">
                                        <div class="progress-bar @(team1Won ? "bg-success" : "bg-secondary")" style="width: @(team1Pct)%">@team1Pct%</div>
                                        <div class="progress-bar @(!team1Won ? "bg-success" : "bg-secondary") opacity-75" style="width: @(team2Pct)%">@team2Pct%</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="fw-semibold @(!team1Won ? "text-success" : "text-muted")">
                                        Team 2
                                        @if (!team1Won) { <i class="bi bi-trophy-fill ms-1"></i> }
                                    </div>
                                    <small class="text-muted">avg ELO @team2AvgBefore</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer text-muted small d-flex justify-content-between flex-wrap gap-2">
                <span>Recorded: <span class="match-date" data-utc="@_match.CreatedAt.ToString("o")">@_match.CreatedAt.ToString("f")</span></span>
                @if (!_canDelete && _isAdmin)
                {
                    <span title="@_deleteBlockedReason">
                        <i class="bi bi-lock me-1"></i>Cannot be deleted (@(_deleteBlockedReason ?? "locked"))
                    </span>
                }
            </div>
        </div>

        <AlertMessage Message="@_deleteError" Variant="danger" Icon="bi bi-exclamation-triangle"
                      Dismissible="true" OnDismiss="() => _deleteError = null" />

        <a href="/@TeamCode/matches" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to History
        </a>
    </div>

    <Modal Show="_showDeleteConfirm" Title="Delete Match" OnClose="() => _showDeleteConfirm = false">
        <Body>
            <p>Are you sure you want to delete this match? ELO changes will be reversed.</p>
            <div class="alert alert-secondary">
                <strong>Match Summary:</strong><br />
                Team 1 (@string.Join(", ", team1Players.Select(p => p.Player.Name))) vs
                Team 2 (@string.Join(", ", team2Players.Select(p => p.Player.Name)))<br />
                Score: @_match.Team1Score : @_match.Team2Score<br />
                Date: @_match.PlayedAt.ToString("f")
            </div>
        </Body>
        <Footer>
            <button type="button" class="btn btn-secondary" @onclick="() => _showDeleteConfirm = false">Cancel</button>
            <SpinnerButton Variant="danger" Busy="_deleting" OnClick="DeleteMatch">Delete Match</SpinnerButton>
        </Footer>
    </Modal>
}
else
{
    <div class="container py-4">
        <AlertMessage Message="Match not found." Variant="warning" Icon="bi bi-exclamation-triangle" />
        <a href="/@TeamCode/matches" class="btn btn-primary">Back to History</a>
    </div>
}

@code {
    [Parameter] public string TeamCode { get; set; } = string.Empty;
    [Parameter] public int MatchId { get; set; }

    private Team? _team;
    private Match? _match;
    private bool _loading = true;
    private bool _isAdmin;
    private bool _canDelete;
    private string? _deleteBlockedReason;
    private bool _showDeleteConfirm;
    private bool _deleting;
    private string? _deleteError;
    private bool _copied;

    private int? _newerId;
    private int? _olderId;
    private int _loadedMatchId = -1;
    private bool _firstRenderDone;
    private bool _hasAnySeason;

    protected override async Task OnParametersSetAsync()
    {
        // Reload whenever we navigate to a different match (component instance is reused).
        if (_firstRenderDone && _loadedMatchId != MatchId)
        {
            await LoadAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _firstRenderDone = true;
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _match = null;
        _showDeleteConfirm = false;
        _deleteError = null;
        StateHasChanged();

        _team ??= await TeamAccess.GetCurrentTeamAsync();
        _isAdmin = await TeamAccess.IsAdminAsync();

        if (_team != null)
        {
            _hasAnySeason = await SeasonService.HasAnySeasonAsync(_team.Id);
            var match = await MatchService.GetByIdAsync(MatchId);
            if (match != null && match.TeamId == _team.Id)
            {
                _match = match;
                var (canDelete, reason) = await MatchService.CanDeleteWithReasonAsync(MatchId);
                _canDelete = canDelete;
                _deleteBlockedReason = reason;

                (_newerId, _olderId) = await MatchService.GetAdjacentMatchIdsAsync(MatchId, _team.Id);
            }
        }

        _loadedMatchId = MatchId;
        _loading = false;
        StateHasChanged();
    }

    private async Task CopyLink()
    {
        try
        {
            var url = Navigation.Uri;
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);
            _copied = true;
            StateHasChanged();
            await Task.Delay(1500);
            _copied = false;
            StateHasChanged();
        }
        catch
        {
            // Ignore clipboard failures (older browsers / insecure contexts).
        }
    }

    private async Task DeleteMatch()
    {
        if (_match == null || _team == null) return;

        _deleting = true;
        try
        {
            var userId = await CurrentUser.GetUserIdAsync();
            if (userId == null) return;
            var deleted = await MatchService.DeleteAsync(MatchId, _team.Id, userId.Value);
            if (deleted)
            {
                Navigation.NavigateTo($"/{TeamCode}/matches?message=Match deleted successfully", forceLoad: true);
            }
            else
            {
                _deleteError = "Cannot delete this match. It may have been modified or the deletion window has passed.";
                _showDeleteConfirm = false;
            }
        }
        catch
        {
            _deleteError = "An error occurred while deleting the match.";
            _showDeleteConfirm = false;
        }
        finally
        {
            _deleting = false;
        }
    }
}
