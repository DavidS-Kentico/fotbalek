@page "/team/{TeamCode}/matches"
@layout TeamLayout
@rendermode InteractiveServer
@attribute [Authorize]
@inject TeamAccessService TeamAccess
@inject MatchService MatchService
@inject SeasonService SeasonService
@inject PlayerService PlayerService
@inject CurrentUserService CurrentUser
@inject NavigationManager Navigation
@inject TimeZoneService Tz
@using Fotbalek.Web.Helpers
@using System.Globalization

<PageTitle>Match History - Foosball Manager</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else
{
    <PageContainer Focused>
        <PageHeader Title="Match History" Icon="bi bi-clock-history">
            <Actions>
                <a href="/team/@TeamCode/match/new" class="btn btn-success">
                    <i class="bi bi-plus-lg me-1"></i> New Match
                </a>
            </Actions>
        </PageHeader>

        <AlertMessage Message="@_message" Variant="success" Dismissible="true" OnDismiss="() => _message = null" />

        <Panel Class="mb-4 match-history-filters" BodyClass="py-2">
                <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
                    <TimePeriodFilter @bind-SelectedPeriod="_selectedPeriod"
                                      @bind-CustomStartDate="_customStartDate"
                                      @bind-CustomEndDate="_customEndDate"
                                      Today="Tz.Today"
                                      OnFilterChanged="OnFilterChanged" />
                </div>

                @if (_seasons.Count > 0)
                {
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                        <span class="text-muted small"><i class="bi bi-award me-1"></i>Season:</span>
                        <select class="form-select form-select-sm w-auto" value="@(_selectedSeasonId?.ToString() ?? "all")" @onchange="OnSeasonFilterChanged">
                            <option value="all">All matches</option>
                            @if (_activeSeason != null)
                            {
                                <option value="@_activeSeason.Id">This season (@_activeSeason.Name)</option>
                            }
                            @foreach (var season in _seasons.Where(s => s.IsClosed))
                            {
                                <option value="@season.Id">@season.Name</option>
                            }
                        </select>
                    </div>
                }

                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    @if (MyPlayerId.HasValue)
                    {
                        <button type="button"
                                class="btn btn-sm @(_myMatchesOnly ? "btn-success" : "btn-outline-success")"
                                @onclick="ToggleMyMatches">
                            <i class="bi bi-person-check me-1"></i> My matches
                            @if (_myMatchesOnly)
                            {
                                <span class="badge bg-light text-success ms-1">@_filteredMatches.Count</span>
                            }
                        </button>
                    }

                    @if (_canFilterByOutcome)
                    {
                        <div class="btn-group btn-group-sm" role="group" aria-label="Outcome filter">
                            <button type="button"
                                    class="btn @(_outcome == null ? "btn-secondary" : "btn-outline-secondary")"
                                    @onclick='() => SetOutcome(null)'>All</button>
                            <button type="button"
                                    class="btn @(_outcome == "wins" ? "btn-success" : "btn-outline-success")"
                                    @onclick='() => SetOutcome("wins")'>
                                <i class="bi bi-trophy me-1"></i>Wins
                            </button>
                            <button type="button"
                                    class="btn @(_outcome == "losses" ? "btn-danger" : "btn-outline-danger")"
                                    @onclick='() => SetOutcome("losses")'>
                                <i class="bi bi-x-circle me-1"></i>Losses
                            </button>
                        </div>
                    }
                </div>

                @if (_players.Count > 0)
                {
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="text-muted small"><i class="bi bi-people me-1"></i>Players:</span>
                        @foreach (var player in _players)
                        {
                            var isSelected = _selectedPlayerIds.Contains(player.Id);
                            <button type="button"
                                    class="btn btn-sm @(isSelected ? "btn-success" : "btn-outline-secondary")"
                                    @onclick="() => TogglePlayer(player.Id)"
                                    disabled="@(!isSelected && _selectedPlayerIds.Count >= 4)">
                                @player.Name
                            </button>
                        }
                        @if (_selectedPlayerIds.Count > 0)
                        {
                            <button type="button" class="btn btn-sm btn-link text-muted" @onclick="ClearPlayerFilter">
                                <i class="bi bi-x-circle"></i> Clear players
                            </button>
                        }
                    </div>
                }

                @if (HasActiveFilters)
                {
                    <div class="mt-2 d-flex flex-wrap align-items-center gap-2">
                        <span class="badge bg-secondary">@GetFilterDescription()</span>
                        <button type="button" class="btn btn-sm btn-link text-decoration-none p-0" @onclick="ClearAllFilters">
                            <i class="bi bi-x-circle me-1"></i>Clear all
                        </button>
                    </div>
                }
        </Panel>

        @if (_filteredMatches.Count > 0)
        {
            @if (_focusPlayerId.HasValue)
            {
                var focus = _focusPlayerId.Value;
                var rows = _filteredMatches
                    .Select(m => m.MatchPlayers.FirstOrDefault(mp => mp.PlayerId == focus))
                    .Where(mp => mp != null)
                    .ToList();
                // Wins judged by score; the net-ELO chip sums the seasonal change when a season
                // filter is active, the all-time change otherwise (mixed views: every match has an
                // all-time change, only seasonal ones have a seasonal one).
                var wins = rows.Count(mp => IsWinByScore(mp!));
                var losses = rows.Count - wins;
                var netElo = _selectedSeasonId != null
                    ? rows.Sum(mp => mp!.SeasonEloChange ?? 0)
                    : rows.Sum(mp => mp!.EloChange);
                var winRate = rows.Count > 0 ? (int)Math.Round(wins * 100.0 / rows.Count) : 0;
                var focusName = _players.FirstOrDefault(p => p.Id == focus)?.Name ?? "player";
                <Panel Class="border-success mb-3" BodyClass="py-2 d-flex flex-wrap align-items-center gap-3">
                    <span class="fw-semibold text-success">
                        <i class="bi bi-person-badge me-1"></i>@focusName
                    </span>
                    <span class="text-muted">|</span>
                    <span><i class="bi bi-trophy-fill text-success me-1"></i><strong>@wins</strong> wins</span>
                    <span><i class="bi bi-x-circle text-danger me-1"></i><strong>@losses</strong> losses</span>
                    <span><i class="bi bi-percent me-1"></i><strong>@winRate%</strong> win rate</span>
                    <span class="@(netElo >= 0 ? "text-success" : "text-danger")">
                        <i class="bi @(netElo >= 0 ? "bi-graph-up-arrow" : "bi-graph-down-arrow") me-1"></i>
                        <strong>@(netElo > 0 ? "+" : "")@netElo</strong> ELO
                    </span>
                </Panel>
            }

            <div class="text-muted small mb-3">
                Showing @Math.Min(_visibleCount, _filteredMatches.Count) of @_filteredMatches.Count matches
            </div>

            <MatchDayList Matches="GetVisibleMatches()" TeamCode="@TeamCode" ShowSeasonChip="@(_seasons.Count > 0)">
                <Actions Context="match">
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary border-0" type="button"
                                data-bs-toggle="dropdown" aria-label="Match actions">
                            <i class="bi bi-three-dots-vertical"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="/team/@TeamCode/matches/@match.Id">
                                    <i class="bi bi-eye me-2"></i>View details
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/team/@TeamCode/match/new?rematch=@match.Id">
                                    <i class="bi bi-arrow-repeat me-2"></i>Rematch
                                </a>
                            </li>
                            @if (_isCaptain)
                            {
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <button type="button" class="dropdown-item text-danger"
                                            @onclick="() => RequestDelete(match)">
                                        <i class="bi bi-trash me-2"></i>Delete
                                    </button>
                                </li>
                            }
                        </ul>
                    </div>
                </Actions>
            </MatchDayList>

            @if (_filteredMatches.Count > _visibleCount)
            {
                <LoadMoreButton Remaining="@(_filteredMatches.Count - _visibleCount)" OnClick="LoadMore" />
            }
        }
        else
        {
            <EmptyState Icon="bi bi-calendar-x" IconSize="xl" Padding="py-5"
                        Title="@(HasActiveFilters ? "No matches found for the selected filters" : "No matches recorded yet")"
                        Message="@(HasActiveFilters ? "Try adjusting your filters or selecting a different time period." : "Start playing and record your first match!")">
                @if (HasActiveFilters)
                {
                    <button class="btn btn-outline-success" @onclick="ClearAllFilters">Clear Filters</button>
                }
                else
                {
                    <a href="/team/@TeamCode/match/new" class="btn btn-success">Record First Match</a>
                }
            </EmptyState>
        }
    </PageContainer>

    <Modal Show="_pendingDelete != null" Title="Delete Match" OnClose="() => _pendingDelete = null">
        <Body>
            @if (_pendingDelete != null)
            {
                <p>Are you sure you want to delete this match? ELO changes will be reversed.</p>
                <div class="alert alert-secondary mb-0">
                    <strong>Score:</strong> @_pendingDelete.Team1Score : @_pendingDelete.Team2Score<br />
                    <strong>Date:</strong>
                    <span class="match-date" data-utc="@_pendingDelete.PlayedAt.ToString("o")">
                        @_pendingDelete.PlayedAt.ToString("g")
                    </span>
                </div>
            }
            <AlertMessage Message="@_deleteError" Variant="danger" Icon="bi bi-exclamation-triangle"
                          Dismissible="true" OnDismiss="() => _deleteError = null" />
        </Body>
        <Footer>
            <button type="button" class="btn btn-secondary" @onclick="() => _pendingDelete = null">Cancel</button>
            <SpinnerButton Variant="danger" Busy="_deleting" OnClick="ConfirmDelete">Delete Match</SpinnerButton>
        </Footer>
    </Modal>
}

@code {
    [Parameter] public string TeamCode { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "message")] public string? MessageParam { get; set; }
    [SupplyParameterFromQuery(Name = "player")]  public int? PlayerParam { get; set; }
    [SupplyParameterFromQuery(Name = "period")]  public string? PeriodParam { get; set; }
    [SupplyParameterFromQuery(Name = "players")] public string? PlayersParam { get; set; }
    [SupplyParameterFromQuery(Name = "outcome")] public string? OutcomeParam { get; set; }
    [SupplyParameterFromQuery(Name = "mine")]    public bool? MineParam { get; set; }
    [SupplyParameterFromQuery(Name = "start")]   public string? StartParam { get; set; }
    [SupplyParameterFromQuery(Name = "end")]     public string? EndParam { get; set; }
    [SupplyParameterFromQuery(Name = "season")]  public string? SeasonParam { get; set; }

    [CascadingParameter(Name = "MyPlayerId")] public int? MyPlayerId { get; set; }

    private Team? _team;
    private bool _loading = true;
    private bool _isCaptain;
    private List<Match> _allMatches = [];
    private List<Match> _filteredMatches = [];
    private List<Player> _players = [];
    // Load-more window: how many of _filteredMatches are rendered; grows by DefaultPageSize
    // per "Load more" click and resets to one page whenever the filters change.
    private int _visibleCount = Constants.Pagination.DefaultPageSize;
    private string? _message;

    private string _selectedPeriod = "all";
    private HashSet<int> _selectedPlayerIds = [];
    private DateOnly? _customStartDate;
    private DateOnly? _customEndDate;
    private bool _myMatchesOnly;
    private string? _outcome;

    private List<Season> _seasons = [];
    private Season? _activeSeason;
    private int? _selectedSeasonId;
    private int? _defaultSeasonId;

    private Match? _pendingDelete;
    private bool _deleting;
    private string? _deleteError;

    private bool HasActiveFilters =>
        _selectedPeriod != "all"
        || _selectedPlayerIds.Count > 0
        || _myMatchesOnly
        || _outcome != null
        || _selectedSeasonId != _defaultSeasonId;

    private bool _canFilterByOutcome =>
        (_myMatchesOnly && MyPlayerId.HasValue) || _selectedPlayerIds.Count == 1;

    // The player whose perspective we display in the summary bar:
    //  - "My matches" mode -> the logged-in user's player
    //  - single player selected -> that player
    private int? _focusPlayerId =>
        _myMatchesOnly && MyPlayerId.HasValue ? MyPlayerId :
        _selectedPlayerIds.Count == 1 ? _selectedPlayerIds.First() :
        (int?)null;

    private int? _lastMyPlayerId;
    private bool _dataLoaded;

    protected override void OnParametersSet()
    {
        // When the cascading MyPlayerId arrives (or changes) after the initial render,
        // re-apply the filter so "My matches" reflects the current player.
        if (_dataLoaded && _lastMyPlayerId != MyPlayerId)
        {
            _lastMyPlayerId = MyPlayerId;
            ApplyFilter();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Tz.EnsureResolvedAsync();
            _team = await TeamAccess.GetCurrentTeamAsync();
            _isCaptain = await TeamAccess.IsCaptainAsync();
            if (_team != null)
            {
                _allMatches = await MatchService.GetByTeamAsync(_team.Id, 1, 10000);
                _players = await PlayerService.GetByTeamAsync(_team.Id);

                _seasons = await SeasonService.GetByTeamAsync(_team.Id);
                _activeSeason = _seasons.FirstOrDefault(s => s.IsActiveAt(DateTimeOffset.UtcNow));
                // "This season" is the default preset when an active season exists.
                _defaultSeasonId = _activeSeason?.Id;
                _selectedSeasonId = _defaultSeasonId;

                _customEndDate = Tz.Today;
                _customStartDate = _customEndDate.Value.AddMonths(-1);

                ApplyFiltersFromUrl();

                _message = MessageParam;

                _dataLoaded = true;
                _lastMyPlayerId = MyPlayerId;
                ApplyFilter();
            }
            _loading = false;
            StateHasChanged();
        }
    }

    private void ApplyFiltersFromUrl()
    {
        if (!string.IsNullOrWhiteSpace(PeriodParam))
        {
            _selectedPeriod = PeriodParam;
        }

        if (!string.IsNullOrWhiteSpace(StartParam) && DateOnly.TryParse(StartParam, CultureInfo.InvariantCulture, out var s))
            _customStartDate = s;
        if (!string.IsNullOrWhiteSpace(EndParam) && DateOnly.TryParse(EndParam, CultureInfo.InvariantCulture, out var e))
            _customEndDate = e;

        // Player IDs: support legacy ?player=X and new ?players=1,2,3
        if (PlayerParam.HasValue && _players.Any(p => p.Id == PlayerParam.Value))
        {
            _selectedPlayerIds.Add(PlayerParam.Value);
        }
        if (!string.IsNullOrWhiteSpace(PlayersParam))
        {
            foreach (var part in PlayersParam.Split(',', StringSplitOptions.RemoveEmptyEntries))
            {
                if (int.TryParse(part, out var id) && _players.Any(p => p.Id == id))
                    _selectedPlayerIds.Add(id);
                if (_selectedPlayerIds.Count >= 4) break;
            }
        }

        if (MineParam == true && MyPlayerId.HasValue) _myMatchesOnly = true;

        if (OutcomeParam is "wins" or "losses") _outcome = OutcomeParam;

        if (!string.IsNullOrWhiteSpace(SeasonParam))
        {
            if (SeasonParam == "all") _selectedSeasonId = null;
            else if (int.TryParse(SeasonParam, out var seasonId) && _seasons.Any(s => s.Id == seasonId))
                _selectedSeasonId = seasonId;
        }
    }

    private void OnFilterChanged()
    {
        ApplyFilter();
        SyncUrl();
    }

    private void OnSeasonFilterChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        _selectedSeasonId = int.TryParse(raw, out var id) ? id : null;
        ApplyFilter();
        SyncUrl();
    }

    private void TogglePlayer(int playerId)
    {
        if (_selectedPlayerIds.Contains(playerId)) _selectedPlayerIds.Remove(playerId);
        else if (_selectedPlayerIds.Count < 4) _selectedPlayerIds.Add(playerId);
        if (!_canFilterByOutcome) _outcome = null;
        ApplyFilter();
        SyncUrl();
    }

    private void ClearPlayerFilter()
    {
        _selectedPlayerIds.Clear();
        if (!_canFilterByOutcome) _outcome = null;
        ApplyFilter();
        SyncUrl();
    }

    private void ToggleMyMatches()
    {
        _myMatchesOnly = !_myMatchesOnly;
        if (!_canFilterByOutcome) _outcome = null;
        ApplyFilter();
        SyncUrl();
    }

    private void SetOutcome(string? outcome)
    {
        _outcome = outcome;
        ApplyFilter();
        SyncUrl();
    }

    private void ClearAllFilters()
    {
        _selectedPeriod = "all";
        _selectedPlayerIds.Clear();
        _myMatchesOnly = false;
        _outcome = null;
        _selectedSeasonId = _defaultSeasonId;
        ApplyFilter();
        SyncUrl();
    }

    private void ApplyFilter()
    {
        var query = _allMatches.AsEnumerable();

        if (_selectedSeasonId is int seasonId)
        {
            query = query.Where(m => m.SeasonId == seasonId);
        }

        query = query.Where(m => DateFilterHelper.IsDateInPeriod(
            Tz.ToLocalDate(m.PlayedAt),
            _selectedPeriod,
            Tz.Today,
            _customStartDate,
            _customEndDate));

        if (_selectedPlayerIds.Count > 0)
        {
            query = query.Where(m =>
                _selectedPlayerIds.All(pid => m.MatchPlayers.Any(mp => mp.PlayerId == pid)));
        }

        if (_myMatchesOnly && MyPlayerId.HasValue)
        {
            var mine = MyPlayerId.Value;
            query = query.Where(m => m.MatchPlayers.Any(mp => mp.PlayerId == mine));
        }

        if (_canFilterByOutcome && _outcome != null)
        {
            // Outcome is judged from the perspective of the focused player:
            // - "my matches" mode  -> MyPlayerId
            // - one player selected -> that player
            var focus = _myMatchesOnly ? MyPlayerId :
                        _selectedPlayerIds.Count == 1 ? _selectedPlayerIds.First() :
                        (int?)null;

            if (focus.HasValue)
            {
                var want = _outcome == "wins";
                query = query.Where(m =>
                {
                    var mp = m.MatchPlayers.FirstOrDefault(p => p.PlayerId == focus.Value);
                    return mp != null && IsWinByScore(mp) == want;
                });
            }
        }

        _filteredMatches = query.ToList();

        // Any filter change collapses the list back to a single page.
        _visibleCount = Constants.Pagination.DefaultPageSize;

        StateHasChanged();
    }

    private List<Match> GetVisibleMatches() => _filteredMatches.Take(_visibleCount).ToList();

    private void LoadMore()
    {
        _visibleCount += Constants.Pagination.DefaultPageSize;
        StateHasChanged();
    }

    private static bool IsWinByScore(MatchPlayer mp)
    {
        var teamScore = mp.TeamNumber == 1 ? mp.Match.Team1Score : mp.Match.Team2Score;
        var opponentScore = mp.TeamNumber == 1 ? mp.Match.Team2Score : mp.Match.Team1Score;
        return teamScore > opponentScore;
    }

    private string GetFilterDescription()
    {
        var parts = new List<string>();

        if (_selectedSeasonId is int seasonId)
        {
            var name = _seasons.FirstOrDefault(s => s.Id == seasonId)?.Name;
            if (name != null) parts.Add(name);
        }
        else if (_defaultSeasonId != null)
        {
            parts.Add("All seasons");
        }

        var periodDesc = DateFilterHelper.GetPeriodDescription(_selectedPeriod, Tz.Today, _customStartDate, _customEndDate);
        if (periodDesc != null) parts.Add(periodDesc);

        if (_myMatchesOnly) parts.Add("My matches");

        if (_selectedPlayerIds.Count > 0)
        {
            var playerNames = _players
                .Where(p => _selectedPlayerIds.Contains(p.Id))
                .Select(p => p.Name);
            parts.Add(string.Join(" + ", playerNames));
        }

        if (_outcome != null) parts.Add(_outcome == "wins" ? "Wins only" : "Losses only");

        var desc = string.Join(" | ", parts);
        return $"{_filteredMatches.Count} matches" + (parts.Count > 0 ? $" ({desc})" : "");
    }

    private void SyncUrl()
    {
        var qs = new Dictionary<string, object?>
        {
            ["season"]  = _selectedSeasonId == _defaultSeasonId
                            ? null
                            : _selectedSeasonId?.ToString() ?? "all",
            ["period"]  = _selectedPeriod == "all" ? null : _selectedPeriod,
            ["start"]   = _selectedPeriod == "custom" ? _customStartDate?.ToString("yyyy-MM-dd") : null,
            ["end"]     = _selectedPeriod == "custom" ? _customEndDate?.ToString("yyyy-MM-dd") : null,
            ["players"] = _selectedPlayerIds.Count > 0 ? string.Join(",", _selectedPlayerIds) : null,
            ["mine"]    = _myMatchesOnly ? "true" : null,
            ["outcome"] = _outcome,
            ["player"]  = null,   // clear legacy param
            ["page"]    = null,   // clear legacy param (pagination replaced by load-more)
            ["size"]    = null,   // clear legacy param
            ["message"] = null,   // one-shot
        };

        var newUri = Navigation.GetUriWithQueryParameters(qs);
        Navigation.NavigateTo(newUri, forceLoad: false, replace: true);
    }

    private void RequestDelete(Match match)
    {
        _deleteError = null;
        _pendingDelete = match;
    }

    private async Task ConfirmDelete()
    {
        if (_pendingDelete == null || _team == null) return;

        _deleting = true;
        try
        {
            var userId = await CurrentUser.GetUserIdAsync();
            if (userId == null) { _deleteError = "Not signed in."; return; }

            var deleted = await MatchService.DeleteAsync(_pendingDelete.Id, _team.Id, userId.Value);
            if (deleted)
            {
                _allMatches.Remove(_pendingDelete);
                _message = "Match deleted successfully.";
                _pendingDelete = null;
                ApplyFilter();
            }
            else
            {
                _deleteError = "Cannot delete this match. The deletion window may have passed or a later match exists.";
            }
        }
        catch
        {
            _deleteError = "An error occurred while deleting the match.";
        }
        finally
        {
            _deleting = false;
        }
    }
}
