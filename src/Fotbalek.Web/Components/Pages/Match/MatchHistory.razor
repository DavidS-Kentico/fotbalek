@page "/{TeamCode}/matches"
@layout TeamLayout
@rendermode InteractiveServer
@attribute [Authorize]
@inject TeamAccessService TeamAccess
@inject MatchService MatchService
@inject PlayerService PlayerService
@using Fotbalek.Web.Helpers

<PageTitle>Match History - Foosball Manager</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else
{
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="bi bi-clock-history me-2"></i>Match History</h2>
            <a href="/@TeamCode/match/new" class="btn btn-success">
                <i class="bi bi-plus-lg me-1"></i> New Match
            </a>
        </div>

        <AlertMessage Message="@_message" Variant="success" Dismissible="true" OnDismiss="() => _message = null" />

        <div class="card mb-4">
            <div class="card-body py-2">
                <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
                    <TimePeriodFilter @bind-SelectedPeriod="_selectedPeriod"
                                      @bind-CustomStartDate="_customStartDate"
                                      @bind-CustomEndDate="_customEndDate"
                                      OnFilterChanged="OnFilterChanged" />
                </div>

                @if (_players.Count > 0)
                {
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="text-muted small"><i class="bi bi-people me-1"></i>Players:</span>
                        @foreach (var player in _players)
                        {
                            var isSelected = _selectedPlayerIds.Contains(player.Id);
                            <button type="button"
                                    class="btn btn-sm @(isSelected ? "btn-success" : "btn-outline-secondary")"
                                    @onclick="() => TogglePlayer(player.Id)"
                                    disabled="@(!isSelected && _selectedPlayerIds.Count >= 4)">
                                @player.Name
                            </button>
                        }
                        @if (_selectedPlayerIds.Count > 0)
                        {
                            <button type="button" class="btn btn-sm btn-link text-muted" @onclick="ClearPlayerFilter">
                                <i class="bi bi-x-circle"></i> Clear
                            </button>
                        }
                    </div>
                }

                @if (HasActiveFilters)
                {
                    <div class="mt-2">
                        <span class="badge bg-secondary">@GetFilterDescription()</span>
                    </div>
                }
            </div>
        </div>

        @if (_filteredMatches.Count > 0)
        {
            <div class="text-muted small mb-3">
                Showing @((_currentPage - 1) * PageSize + 1)-@Math.Min(_currentPage * PageSize, _filteredMatches.Count) of @_filteredMatches.Count matches
            </div>

            @foreach (var match in GetCurrentPageMatches())
            {
                <MatchCard Match="@match" TeamCode="@TeamCode" />
            }

            @if (_totalPages > 1)
            {
                <nav aria-label="Match history pagination">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(_currentPage - 1)" disabled="@(_currentPage == 1)">Previous</button>
                        </li>
                        @foreach (var pageNum in GetPageNumbers())
                        {
                            if (pageNum == -1)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                            else
                            {
                                <li class="page-item @(_currentPage == pageNum ? "active" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                                </li>
                            }
                        }
                        <li class="page-item @(_currentPage == _totalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(_currentPage + 1)" disabled="@(_currentPage == _totalPages)">Next</button>
                        </li>
                    </ul>
                </nav>
            }
        }
        else
        {
            <EmptyState Icon="bi bi-calendar-x" IconSize="xl" Padding="py-5"
                        Title="@(HasActiveFilters ? "No matches found for the selected filters" : "No matches recorded yet")"
                        Message="@(HasActiveFilters ? "Try adjusting your filters or selecting a different time period." : "Start playing and record your first match!")">
                @if (HasActiveFilters)
                {
                    <button class="btn btn-outline-success" @onclick="ClearAllFilters">Clear Filters</button>
                }
                else
                {
                    <a href="/@TeamCode/match/new" class="btn btn-success">Record First Match</a>
                }
            </EmptyState>
        }
    </div>
}

@code {
    [Parameter] public string TeamCode { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "message")]
    public string? MessageParam { get; set; }

    [SupplyParameterFromQuery(Name = "player")]
    public int? PlayerParam { get; set; }

    private Team? _team;
    private bool _loading = true;
    private List<Match> _allMatches = [];
    private List<Match> _filteredMatches = [];
    private List<Player> _players = [];
    private int _currentPage = 1;
    private int _totalPages = 1;
    private const int PageSize = 10;
    private string? _message;

    private string _selectedPeriod = "all";
    private HashSet<int> _selectedPlayerIds = [];
    private DateOnly? _customStartDate;
    private DateOnly? _customEndDate;

    private bool HasActiveFilters => _selectedPeriod != "all" || _selectedPlayerIds.Count > 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _team = await TeamAccess.GetCurrentTeamAsync();
            if (_team != null)
            {
                _allMatches = await MatchService.GetByTeamAsync(_team.Id, 1, 10000);
                _players = await PlayerService.GetByTeamAsync(_team.Id);

                _customEndDate = DateOnly.FromDateTime(DateTime.Today);
                _customStartDate = _customEndDate.Value.AddMonths(-1);

                if (PlayerParam.HasValue && _players.Any(p => p.Id == PlayerParam.Value))
                {
                    _selectedPlayerIds.Add(PlayerParam.Value);
                }

                _message = MessageParam;

                ApplyFilter();
            }
            _loading = false;
            StateHasChanged();
        }
    }

    private void OnFilterChanged()
    {
        _currentPage = 1;
        ApplyFilter();
    }

    private void TogglePlayer(int playerId)
    {
        if (_selectedPlayerIds.Contains(playerId))
        {
            _selectedPlayerIds.Remove(playerId);
        }
        else if (_selectedPlayerIds.Count < 4)
        {
            _selectedPlayerIds.Add(playerId);
        }
        _currentPage = 1;
        ApplyFilter();
    }

    private void ClearPlayerFilter()
    {
        _selectedPlayerIds.Clear();
        _currentPage = 1;
        ApplyFilter();
    }

    private void ClearAllFilters()
    {
        _selectedPeriod = "all";
        _selectedPlayerIds.Clear();
        _currentPage = 1;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        _filteredMatches = _allMatches
            .Where(m => DateFilterHelper.IsDateInPeriod(
                DateOnly.FromDateTime(m.PlayedAt.Date),
                _selectedPeriod,
                _customStartDate,
                _customEndDate))
            .ToList();

        if (_selectedPlayerIds.Count > 0)
        {
            _filteredMatches = _filteredMatches
                .Where(m => _selectedPlayerIds.All(pid => m.MatchPlayers.Any(mp => mp.PlayerId == pid)))
                .ToList();
        }

        _totalPages = Math.Max(1, (int)Math.Ceiling((double)_filteredMatches.Count / PageSize));
        if (_currentPage > _totalPages) _currentPage = _totalPages;

        StateHasChanged();
    }

    private List<Match> GetCurrentPageMatches() =>
        _filteredMatches.Skip((_currentPage - 1) * PageSize).Take(PageSize).ToList();

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= _totalPages)
        {
            _currentPage = page;
            StateHasChanged();
        }
    }

    private IEnumerable<int> GetPageNumbers()
    {
        const int maxVisible = 7;
        if (_totalPages <= maxVisible) return Enumerable.Range(1, _totalPages);

        var pages = new List<int> { 1 };
        var start = Math.Max(2, _currentPage - 2);
        var end = Math.Min(_totalPages - 1, _currentPage + 2);

        if (_currentPage <= 3) end = Math.Min(_totalPages - 1, 5);
        else if (_currentPage >= _totalPages - 2) start = Math.Max(2, _totalPages - 4);

        if (start > 2) pages.Add(-1);
        for (var i = start; i <= end; i++) pages.Add(i);
        if (end < _totalPages - 1) pages.Add(-1);
        pages.Add(_totalPages);

        return pages;
    }

    private string GetFilterDescription()
    {
        var parts = new List<string>();

        var periodDesc = DateFilterHelper.GetPeriodDescription(_selectedPeriod, _customStartDate, _customEndDate);
        if (periodDesc != null) parts.Add(periodDesc);

        if (_selectedPlayerIds.Count > 0)
        {
            var playerNames = _players
                .Where(p => _selectedPlayerIds.Contains(p.Id))
                .Select(p => p.Name);
            parts.Add(string.Join(" + ", playerNames));
        }

        var desc = string.Join(" | ", parts);
        return $"{_filteredMatches.Count} matches" + (parts.Count > 0 ? $" ({desc})" : "");
    }
}
