@page "/join"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IScopedSender Sender
@inject NavigationManager Navigation

<PageTitle>Join Team - Foosball Manager</PageTitle>

<AuthCardLayout>
    @if (_validatingToken)
    {
        <div class="panel">
            <div class="panel__body text-center py-5">
                <div class="spinner-border text-success mb-3" role="status">
                    <span class="visually-hidden">Validating share link...</span>
                </div>
                <p class="text-muted mb-0">Validating share link...</p>
            </div>
        </div>
    }
    else
    {
        <div class="panel auth-panel">
            <div class="auth-panel__head">
                <span class="auth-panel__icon"><i class="bi bi-box-arrow-in-right"></i></span>
                <h1 class="auth-panel__title">Join a team</h1>
                <p class="auth-panel__sub">Enter your team's code and password.</p>
            </div>
            <div class="panel__body">
                <EditForm Model="@_model" OnValidSubmit="HandleSubmit" FormName="join-team">
                    <DataAnnotationsValidator />

                    <AlertMessage Message="@_error" Variant="danger" />

                    <div class="mb-3">
                        <label for="codeName" class="form-label">Team code</label>
                        <InputText id="codeName" @bind-Value="_model.CodeName" class="form-control" placeholder="e.g., office-league" />
                        <ValidationMessage For="@(() => _model.CodeName)" class="text-danger" />
                        <small class="text-muted">The URL-friendly name of your team.</small>
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">Password</label>
                        <InputText id="password" @bind-Value="_model.Password" type="password" class="form-control" />
                        <ValidationMessage For="@(() => _model.Password)" class="text-danger" />
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <SpinnerButton Type="submit" Busy="_loading" CssClass="btn-lg">Join team</SpinnerButton>
                        <a href="/" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </EditForm>
            </div>
        </div>
    }
</AuthCardLayout>

@code {
    [SupplyParameterFromQuery(Name = "team")]
    public string? TeamCode { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private JoinTeamModel _model = new();
    private string? _error;
    private bool _loading;
    private bool _validatingToken;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(TeamCode))
        {
            _model.CodeName = TeamCode;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(Token) && !string.IsNullOrEmpty(TeamCode))
        {
            _validatingToken = true;
            StateHasChanged();

            try
            {
                var result = await Sender.Send(new JoinTeamByShareTokenCommand(Token, TeamCode));
                if (result.IsSuccess)
                {
                    Navigation.NavigateTo($"/team/{result.Value.CodeName}/claim", forceLoad: true);
                    return;
                }
                if (result.Error.Type == ErrorType.Unauthorized && result.Error.Code == "Auth.NotAuthenticated")
                {
                    Navigation.NavigateTo("/login", forceLoad: true);
                    return;
                }

                _error = "The share link has expired or is invalid. Please enter the password to join.";
            }
            catch
            {
                _error = "Something went wrong validating the share link. Please enter the password to join.";
            }
            finally
            {
                _validatingToken = false;
                StateHasChanged();
            }
        }
    }

    private async Task HandleSubmit()
    {
        _error = null;
        _loading = true;

        try
        {
            var result = await Sender.Send(new JoinTeamCommand(_model.CodeName, _model.Password));
            if (result.IsFailure)
            {
                if (result.Error.Code == "Auth.NotAuthenticated")
                {
                    Navigation.NavigateTo("/login", forceLoad: true);
                    return;
                }
                _error = result.Error.Message;
                return;
            }

            Navigation.NavigateTo($"/team/{result.Value.CodeName}/claim", forceLoad: true);
        }
        catch (Exception)
        {
            _error = "Something went wrong. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private class JoinTeamModel
    {
        public string CodeName { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
