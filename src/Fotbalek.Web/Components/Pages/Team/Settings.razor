@page "/team/{TeamCode}/settings"
@layout TeamLayout
@rendermode InteractiveServer
@attribute [Authorize]
@inject CurrentTeamProvider TeamAccess
@inject IScopedSender Sender

<PageTitle>Team settings - Foosball Manager</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_team == null)
{
    <PageContainer>
        <AlertMessage Message="Team not found." Variant="warning" />
    </PageContainer>
}
else if (!_isCaptain)
{
    <PageContainer>
        <AlertMessage Message="Only the team captain can change settings." Variant="danger" Icon="bi bi-shield-lock" />
        <a href="/team/@TeamCode" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to team
        </a>
    </PageContainer>
}
else
{
    <PageContainer>
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <PageHeader Title="Team settings" Icon="bi bi-gear" />

                <Panel Title="Team name" Icon="bi bi-pencil">
                    <AlertMessage Message="@_nameSuccess" Variant="success" />
                    <AlertMessage Message="@_nameError" Variant="danger" />
                    <div class="mb-3">
                        <label for="teamName" class="form-label">Display name</label>
                        <input id="teamName" class="form-control" @bind="_name" maxlength="100" />
                        <small class="text-muted">The URL code <code>/team/@_team.CodeName</code> can't be changed.</small>
                    </div>
                    <SpinnerButton Busy="_savingName" OnClick="SaveName">Save name</SpinnerButton>
                </Panel>

                <Panel Title="Team password" Icon="bi bi-key">
                    <AlertMessage Message="@_pwdSuccess" Variant="success" />
                    <AlertMessage Message="@_pwdError" Variant="danger" />
                    <p class="text-muted small">Anyone who already joined the team stays a member. Future joiners (via the secondary link) will need the new password.</p>
                    <div class="mb-3">
                        <label for="newPassword" class="form-label">New password</label>
                        <input id="newPassword" type="password" class="form-control" @bind="_newPassword" />
                        <small class="text-muted">Min 4 characters.</small>
                    </div>
                    <div class="mb-3">
                        <label for="confirmPassword" class="form-label">Confirm new password</label>
                        <input id="confirmPassword" type="password" class="form-control" @bind="_confirmPassword" />
                    </div>
                    <SpinnerButton Busy="_savingPassword" OnClick="SavePassword">Change password</SpinnerButton>
                </Panel>
            </div>
        </div>
    </PageContainer>
}

@code {
    [Parameter] public string TeamCode { get; set; } = string.Empty;

    private TeamDto? _team;
    private bool _loading = true;
    private bool _isCaptain;

    private string _name = string.Empty;
    private string? _nameError;
    private string? _nameSuccess;
    private bool _savingName;

    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string? _pwdError;
    private string? _pwdSuccess;
    private bool _savingPassword;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _team = await TeamAccess.GetCurrentTeamAsync();
        if (_team != null)
        {
            _isCaptain = await TeamAccess.IsCaptainAsync(_team);
            _name = _team.Name;
        }
        _loading = false;
        StateHasChanged();
    }

    private async Task SaveName()
    {
        if (_team == null) return;
        _nameError = null;
        _nameSuccess = null;

        var trimmed = _name?.Trim() ?? string.Empty;
        if (trimmed.Length < 1 || trimmed.Length > 100)
        {
            _nameError = "Name must be 1-100 characters.";
            return;
        }

        _savingName = true;
        try
        {
            var result = await Sender.Send(new UpdateTeamNameCommand(_team.Id, trimmed));
            if (result.IsFailure)
            {
                _nameError = result.Error.Type == ErrorType.Forbidden
                    ? "Could not update — you may not have permission."
                    : result.Error.Message;
                return;
            }
            _team = _team with { Name = trimmed };
            _nameSuccess = "Team name updated.";
        }
        finally
        {
            _savingName = false;
            StateHasChanged();
        }
    }

    private async Task SavePassword()
    {
        if (_team == null) return;
        _pwdError = null;
        _pwdSuccess = null;

        if (string.IsNullOrEmpty(_newPassword) || _newPassword.Length < 4)
        {
            _pwdError = "Password must be at least 4 characters.";
            return;
        }
        if (_newPassword != _confirmPassword)
        {
            _pwdError = "Passwords do not match.";
            return;
        }

        _savingPassword = true;
        try
        {
            var result = await Sender.Send(new UpdateTeamPasswordCommand(_team.Id, _newPassword));
            if (result.IsFailure)
            {
                _pwdError = result.Error.Type == ErrorType.Forbidden
                    ? "Could not update — you may not have permission."
                    : result.Error.Message;
                return;
            }
            _newPassword = string.Empty;
            _confirmPassword = string.Empty;
            _pwdSuccess = "Team password updated.";
        }
        finally
        {
            _savingPassword = false;
            StateHasChanged();
        }
    }
}
