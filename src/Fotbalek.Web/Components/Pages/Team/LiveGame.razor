@page "/team/{TeamCode}/game"
@layout TeamLayout
@rendermode InteractiveServer
@attribute [Authorize]
@using Fotbalek.Web.Game
@using Fotbalek.Web.Game.Core
@implements IAsyncDisposable
@inject TeamAccessService TeamAccess
@inject CurrentUserService CurrentUser
@inject PlayerService PlayerService
@inject GameRoomManager Rooms
@inject IJSRuntime JS

<PageTitle>Live Game - Foosball Manager</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_team != null && _user != null)
{
    <div class="container py-4 live-game">
        @if (_state == null)
        {
            <div class="card">
                <div class="card-body lg-hero">
                    <div class="lg-hero__icon">🎮</div>
                    <h4>@(_roomEnded ? "The game has ended" : "No live game right now")</h4>
                    <p>Play foosball in the browser against your teammates — up to 4 players, everyone else can watch.</p>
                    <button class="btn btn-success btn-lg" @onclick="StartGame">
                        <i class="bi bi-play-fill me-1"></i> Start live game
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="card mb-3">
                <div class="card-body py-2 lg-scorebar">
                    <div class="lg-scorebar__left">
                        <span class="lg-chip lg-chip--live"><span class="live-dot"></span> LIVE</span>
                        <span class="lg-chip"><i class="bi bi-eye"></i> @_state.Viewers.Count</span>
                    </div>
                    <div class="lg-scorebar__center">
                        <div class="lg-score">
                            <span class="lg-score__team lg-score__team--a"><span class="lg-dot lg-dot--a"></span> Team A</span>
                            <span class="lg-score__value">@_state.ScoreA<span class="lg-score__sep">:</span>@_state.ScoreB</span>
                            <span class="lg-score__team lg-score__team--b">Team B <span class="lg-dot lg-dot--b"></span></span>
                        </div>
                    </div>
                    <div class="lg-scorebar__right">
                        @if (IsSeated)
                        {
                            <button class="lg-btn lg-btn--danger" @onclick="() => _showEndModal = true">
                                <i class="bi bi-power"></i> End game
                            </button>
                        }
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-lg-8">
                    <div class="game-canvas-wrap">
                        <canvas @ref="_canvas" data-room-id="@_room?.RoomId"></canvas>

                        @if (_state.State == (int)GamePhase.Waiting)
                        {
                            <div class="game-overlay">
                                <div class="game-overlay-box">
                                    @if (WaitingForReconnect is { Count: > 0 } names)
                                    {
                                        <div class="fs-5">⏸️ Waiting for @string.Join(" & ", names) to reconnect…</div>
                                    }
                                    else
                                    {
                                        <div class="fs-5">Waiting for opponents…</div>
                                        <div class="text-muted small mt-1">Ball rolls once each side has a player.</div>
                                    }
                                </div>
                            </div>
                        }
                        else if (_state.State == (int)GamePhase.GameOver)
                        {
                            <div class="game-overlay">
                                <div class="game-overlay-box text-center">
                                    <div class="fs-4">
                                        🏆
                                        @for (var i = 0; i < _state.Winners.Count; i++)
                                        {
                                            var w = _state.Winners[i];
                                            if (i > 0)
                                            {
                                                <span class="mx-1">&amp;</span>
                                            }
                                            <Avatar AvatarId="@w.AvatarId" Size="sm" CssClass="mx-1" />@w.Name
                                        }
                                        win @Math.Max(_state.ScoreA, _state.ScoreB) : @Math.Min(_state.ScoreA, _state.ScoreB)
                                    </div>
                                    @if (IsSeated)
                                    {
                                        <button class="btn btn-success mt-3" @onclick="Rematch">
                                            <i class="bi bi-arrow-repeat me-1"></i> Rematch
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    @if (IsSeated)
                    {
                        <div class="lg-controls">
                            <span><kbd class="lg-key">W</kbd><kbd class="lg-key">S</kbd> left rod</span>
                            <span class="lg-sep">·</span>
                            <span><kbd class="lg-key">↑</kbd><kbd class="lg-key">↓</kbd> right rod</span>
                            <span class="lg-sep">·</span>
                            <span>hold <kbd class="lg-key">Shift</kbd> to catch · release to shoot</span>
                            <span class="lg-sep">·</span>
                            <span><kbd class="lg-key">Space</kbd> pass: slide = along rod, else back a rod</span>
                            <span class="lg-sep">·</span>
                            <span>goalie: hold <kbd class="lg-key">Space</kbd> to charge, release to launch</span>
                        </div>
                    }
                </div>

                <div class="col-lg-4">
                    <div class="card mb-3">
                        <div class="card-header py-2 lg-card-head">
                            <i class="bi bi-people-fill"></i> Lineup
                        </div>
                        <div class="card-body lg-lineup">
                            @foreach (var (side, label, dot) in new[] { (0, "Team A", "lg-dot--a"), (1, "Team B", "lg-dot--b") })
                            {
                                <div class="lg-team-group @(side == 0 ? "lg-team-group--a" : "lg-team-group--b")">
                                    <div class="lg-team-group__head"><span class="lg-dot @dot"></span> @label</div>
                                    <div class="lg-seats">
                                        @foreach (var seat in _state.Seats.Where(s => side == 0 ? s.Seat <= 1 : s.Seat >= 2))
                                        {
                                            var isMine = seat.UserId == _user.Id;
                                            var isEmpty = seat.UserId == null && !seat.IsBot;
                                            var isOpen = isEmpty && _addBotSeat != seat.Seat;
                                            <div class="lg-seat @(isMine ? "is-mine" : "") @(isOpen ? "is-open" : "") @(seat.UserId != null && !seat.Connected ? "is-offline" : "")">
                                                @if (seat.UserId != null)
                                                {
                                                    <Avatar AvatarId="@(seat.AvatarId ?? 1)" Size="sm" />
                                                    <div class="lg-seat__main">
                                                        <div class="lg-seat__role">@SeatRole(seat.Seat)</div>
                                                        <div class="lg-seat__name">
                                                            <span class="text-truncate">@seat.Name</span>
                                                            @if (isMine)
                                                            {
                                                                <span class="badge-you">you</span>
                                                            }
                                                            @if (!seat.Connected)
                                                            {
                                                                <i class="bi bi-wifi-off" title="Reconnecting…"></i>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                                else if (seat.IsBot)
                                                {
                                                    <Avatar AvatarId="@(seat.AvatarId ?? BotAvatarId)" Size="sm" />
                                                    <div class="lg-seat__main">
                                                        <div class="lg-seat__role">@SeatRole(seat.Seat)</div>
                                                        <div class="lg-seat__name">
                                                            Computer <span class="lg-tag">@BotLevelName(seat.BotLevel)</span>
                                                        </div>
                                                    </div>
                                                    <div class="lg-seat__actions">
                                                        <button class="lg-btn lg-btn--primary" @onclick="() => TakeSeat(seat.Seat)" title="@(IsSeated ? "Move here" : "Sit here")">
                                                            <i class="bi bi-box-arrow-in-down"></i> @(IsSeated ? "Move" : "Sit")
                                                        </button>
                                                        <button class="lg-btn lg-btn--icon lg-btn--danger" @onclick="() => RemoveBot(seat.Seat)" title="Remove computer">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </div>
                                                }
                                                else if (_addBotSeat == seat.Seat)
                                                {
                                                    <span class="lg-seat__glyph"><i class="bi bi-robot"></i></span>
                                                    <div class="lg-seat__main">
                                                        <div class="lg-seat__role">@SeatRole(seat.Seat)</div>
                                                        <div class="lg-seat__name lg-seat__name--open">Add computer</div>
                                                    </div>
                                                    <div class="lg-seat__picker">
                                                        <span class="lg-seat__picker-label">Skill</span>
                                                        <div class="lg-seg">
                                                            @foreach (var level in new[] { BotDifficulty.Easy, BotDifficulty.Medium, BotDifficulty.Hard })
                                                            {
                                                                <button @onclick="() => AddBot(seat.Seat, level)">@BotLevelName((int)level)</button>
                                                            }
                                                        </div>
                                                        <button class="lg-btn lg-btn--icon" @onclick="() => _addBotSeat = null" title="Cancel">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="lg-seat__glyph"><i class="bi @SeatIcon(seat.Seat)"></i></span>
                                                    <div class="lg-seat__main">
                                                        <div class="lg-seat__role">@SeatRole(seat.Seat)</div>
                                                        <div class="lg-seat__name lg-seat__name--open">Open seat</div>
                                                    </div>
                                                    <div class="lg-seat__actions">
                                                        <button class="lg-btn lg-btn--primary" @onclick="() => TakeSeat(seat.Seat)">
                                                            <i class="bi bi-box-arrow-in-down"></i> @(IsSeated ? "Move" : "Sit")
                                                        </button>
                                                        <button class="lg-btn lg-btn--icon" @onclick="() => _addBotSeat = seat.Seat" title="Add a computer player">
                                                            <i class="bi bi-robot"></i>
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="card mb-3">
                        <div class="card-header py-2 lg-card-head">
                            <i class="bi bi-eye"></i> Viewers <span class="lg-count">@_state.Viewers.Count</span>
                        </div>
                        <div class="card-body">
                            @if (_state.Viewers.Count == 0)
                            {
                                <div class="lg-muted-note">Nobody is watching yet.</div>
                            }
                            else
                            {
                                <div class="lg-viewers">
                                    @foreach (var viewer in _state.Viewers)
                                    {
                                        <span class="lg-viewer">
                                            <Avatar AvatarId="@viewer.AvatarId" Size="sm" />
                                            <span>@viewer.Name</span>
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    @if (IsSeated)
                    {
                        <div class="card mb-3">
                            <div class="card-header py-2 lg-card-head">
                                <i class="bi bi-sliders"></i> Match settings
                            </div>
                            <div class="card-body">
                                <div class="lg-setting">
                                    <div class="lg-setting__text">
                                        <div class="lg-setting__label">No quick goals</div>
                                        <div class="lg-setting__desc">Ignore goals in the first 1.5&nbsp;s after kickoff</div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" id="opt-quick-goals"
                                               aria-label="No quick goals"
                                               checked="@_state.Options.DisallowQuickGoals" @onchange="OnToggleQuickGoals" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card mb-3">
                            <div class="card-body lg-actions">
                                <button class="lg-btn" @onclick="ResetBall">
                                    <i class="bi bi-record-circle"></i> Reset ball
                                </button>
                                <button class="lg-btn" @onclick="ResetScore">
                                    <i class="bi bi-0-circle"></i> Reset score
                                </button>
                                <button class="lg-btn lg-btn--danger" @onclick="LeaveSeat">
                                    <i class="bi bi-box-arrow-left"></i> Leave seat
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <Modal Show="_showEndModal" Title="End game" Icon="bi bi-x-circle" OnClose="() => _showEndModal = false">
        <Body>
            <p>End the live game for everyone? The score will be lost.</p>
        </Body>
        <Footer>
            <button type="button" class="btn btn-secondary" @onclick="() => _showEndModal = false">Cancel</button>
            <button type="button" class="btn btn-danger" @onclick="EndGame">End game</button>
        </Footer>
    </Modal>
}

@code {
    [Parameter] public string TeamCode { get; set; } = string.Empty;

    private Team? _team;
    private AppUser? _user;
    private Player? _myPlayer;
    private GameRoom? _room;
    private RoomStateDto? _state;
    private bool _loading = true;
    private bool _roomEnded;
    private bool _showEndModal;
    private bool _subscribed;

    /// <summary>Seat whose inline difficulty picker is open, or null. UI-only.</summary>
    private int? _addBotSeat;

    /// <summary>Robot avatar id (mirrors <c>GameRoom</c>); fallback when a bot seat's avatar is absent.</summary>
    private const int BotAvatarId = 21;

    private ElementReference _canvas;
    private IJSObjectReference? _jsModule;
    private bool _jsInitialized;
    private Guid? _jsRoomId;

    private bool IsSeated => _state != null && _user != null && _state.Seats.Any(s => s.UserId == _user.Id);

    private string MyDisplayName => _myPlayer?.Name ?? _user?.UserName ?? "Player";
    private int MyAvatarId => _myPlayer?.AvatarId ?? 1;

    /// <summary>Names of grace-held occupants, but only when the wait is a reconnect hold —
    /// i.e. both sides are seated and one has no connected player (§3.4).</summary>
    private List<string>? WaitingForReconnect
    {
        get
        {
            if (_state == null)
                return null;
            // Occupancy counts bots too, so a human-vs-bot pause still reads as a reconnect hold;
            // the disconnected filter below stays human-only (a bot is always Connected).
            var sideAOccupied = _state.Seats.Any(s => s.Seat <= 1 && s.Occupied);
            var sideBOccupied = _state.Seats.Any(s => s.Seat >= 2 && s.Occupied);
            if (!sideAOccupied || !sideBOccupied)
                return null;
            return _state.Seats
                .Where(s => s.UserId != null && !s.Connected)
                .Select(s => s.Name!)
                .ToList();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _team = await TeamAccess.GetCurrentTeamAsync();
            _user = await CurrentUser.GetUserAsync();
            if (_team == null || _user == null)
            {
                return; // TeamLayout handles the redirect
            }
            _myPlayer = await PlayerService.GetUserPlayerInTeamAsync(_team.Id, _user.Id);

            Rooms.Changed += OnRoomsChanged;
            _subscribed = true;
            RefreshRoom();
            _loading = false;
            StateHasChanged();
        }

        // The canvas exists only after the room renders; (re)initialize the JS client then.
        if (_room != null && _state != null && !_jsInitialized)
        {
            _jsInitialized = true;
            _jsRoomId = _room.RoomId;
            _jsModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "/js/game.js");
            await _jsModule.InvokeVoidAsync("init", _canvas, new
            {
                hubUrl = "/hubs/game",
                roomId = _room.RoomId.ToString(),
                userId = _user!.Id,
            });
        }
    }

    private void RefreshRoom()
    {
        var room = _team != null ? Rooms.GetForTeam(_team.Id) : null;
        if (_room != null && room == null)
        {
            _roomEnded = true;
        }
        _room = room;
        _state = room?.GetState();
    }

    private async void OnRoomsChanged()
    {
        try
        {
            await InvokeAsync(async () =>
            {
                RefreshRoom();
                if (_jsInitialized && _room?.RoomId != _jsRoomId)
                {
                    // Room gone (or replaced) — tear the JS client down; a new room re-inits
                    // on the next render.
                    _jsInitialized = false;
                    _jsRoomId = null;
                    await DisposeJsClientAsync();
                }
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException)
        {
            // Circuit torn down between event and dispatch.
        }
    }

    private void StartGame()
    {
        if (_team == null || _user == null)
        {
            return;
        }
        _roomEnded = false;
        var room = Rooms.GetOrCreateForTeam(_team.Id);
        room.TryTakeFirstFreeSeat(_user.Id, MyDisplayName, MyAvatarId);
        RefreshRoom();
    }

    private void TakeSeat(int seat)
    {
        _addBotSeat = null;
        _room?.TakeSeat(_user!.Id, seat, MyDisplayName, MyAvatarId);
    }

    private void AddBot(int seat, BotDifficulty difficulty)
    {
        _addBotSeat = null;
        _room?.AddBot(seat, difficulty);
    }

    private void RemoveBot(int seat) => _room?.RemoveBot(seat);

    /// <summary>Short role label for a seat — team is shown by the lineup group,
    /// so the tile only needs the position. Seats 0/2 defend, 1/3 attack (§2.2).</summary>
    private static string SeatRole(int seat) => seat % 2 == 0 ? "Defense" : "Attack";

    /// <summary>Bootstrap icon shown in an empty seat's placeholder circle.</summary>
    private static string SeatIcon(int seat) => seat % 2 == 0 ? "bi-shield-fill" : "bi-bullseye";

    private static string BotLevelName(int level) => (BotDifficulty)level switch
    {
        BotDifficulty.Easy => "Easy",
        BotDifficulty.Medium => "Medium",
        BotDifficulty.Hard => "Hard",
        _ => "",
    };

    private void LeaveSeat() => _room?.LeaveSeat(_user!.Id);
    private void ResetBall() => _room?.ResetBall(_user!.Id);
    private void ResetScore() => _room?.ResetScore(_user!.Id);
    private void Rematch() => _room?.Rematch(_user!.Id);
    private void OnToggleQuickGoals(ChangeEventArgs e) => _room?.SetGameOptions(_user!.Id, e.Value is true);

    private void EndGame()
    {
        _showEndModal = false;
        _room?.EndGame(_user!.Id);
    }

    private async Task DisposeJsClientAsync()
    {
        if (_jsModule == null)
        {
            return;
        }
        try
        {
            await _jsModule.InvokeVoidAsync("dispose");
        }
        catch (JSDisconnectedException)
        {
        }
        catch (JSException)
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_subscribed)
        {
            Rooms.Changed -= OnRoomsChanged;
            _subscribed = false;
        }
        await DisposeJsClientAsync();
        if (_jsModule != null)
        {
            try
            {
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
            _jsModule = null;
        }
    }
}
