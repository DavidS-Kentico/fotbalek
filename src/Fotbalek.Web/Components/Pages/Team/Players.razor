@page "/{TeamCode}/players"
@layout TeamLayout
@rendermode InteractiveServer
@attribute [Authorize]
@inject TeamAccessService TeamAccess
@inject PlayerService PlayerService
@inject StatsService StatsService
@inject StatsEngine StatsEngine
@inject CurrentUserService CurrentUser

<PageTitle>Players - Foosball Manager</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else
{
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="bi bi-people me-2"></i>Players</h2>
            @if (_isAdmin)
            {
                <button class="btn btn-success" @onclick="ShowAddModal">
                    <i class="bi bi-plus-lg me-1"></i> Add Player
                </button>
            }
        </div>

        <AlertMessage Message="@_message" Variant="@(_messageIsError ? "danger" : "success")"
                      Dismissible="true" OnDismiss="() => _message = null" />

        <h5 class="mb-3">Active Players (@_activePlayers.Count)</h5>
        @if (_activePlayers.Count > 0)
        {
            <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-3 mb-4">
                @foreach (var player in _activePlayers)
                {
                    var badges = StatRegistry.PlayerBadges(_stats, player.Id);
                    var isMine = player.Id == MyPlayerId;
                    <div class="col">
                        <div class="card h-100 @(isMine ? "border-success" : "")">
                            <div class="card-body text-center">
                                <Avatar AvatarId="@player.AvatarId" Size="lg" />
                                <h6 class="card-title mt-2 mb-1">
                                    @player.Name
                                    @if (isMine)
                                    {
                                        <span class="badge badge-you ms-1">you</span>
                                    }
                                </h6>
                                <p class="text-muted small mb-1">ELO: @player.Elo</p>
                                @if (badges.Count > 0)
                                {
                                    <div class="d-flex flex-wrap gap-1 justify-content-center">
                                        @foreach (var badge in badges)
                                        {
                                            <span class="badge @badge.CssClass px-1" title="@badge.Tooltip"><i class="@badge.IconClass"></i></span>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="card-footer bg-transparent border-top-0">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a href="/@TeamCode/players/@player.Id" class="btn btn-sm btn-outline-primary" title="View stats">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (_isAdmin && player.Id != MyPlayerId)
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ShowDeactivateConfirm(player)" title="Deactivate">
                                            <i class="bi bi-person-dash"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <AlertMessage Message="No active players. Add at least 4 players to start playing matches!"
                          Variant="info" Icon="bi bi-info-circle" />
        }

        @if (_inactivePlayers.Count > 0)
        {
            <h5 class="mb-3 text-muted">Inactive Players (@_inactivePlayers.Count)</h5>
            <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-3">
                @foreach (var player in _inactivePlayers)
                {
                    <div class="col">
                        <div class="card h-100 bg-light">
                            <div class="card-body text-center">
                                <Avatar AvatarId="@player.AvatarId" Size="lg" CssClass="opacity-50" />
                                <h6 class="card-title mt-2 mb-1 text-muted">@player.Name</h6>
                                <p class="text-muted small mb-2">ELO: @player.Elo</p>
                                <span class="badge bg-secondary">Inactive</span>
                            </div>
                            <div class="card-footer bg-transparent border-top-0">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a href="/@TeamCode/players/@player.Id" class="btn btn-sm btn-outline-primary" title="View stats">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (_isAdmin)
                                    {
                                        <button class="btn btn-sm btn-outline-success" @onclick="() => ReactivatePlayer(player)" title="Reactivate">
                                            <i class="bi bi-person-check"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <Modal Show="_showModal" Title="Add Player" OnClose="HideModal">
        <Body>
            <EditForm Model="@_formModel" OnValidSubmit="SavePlayer" id="addPlayerForm">
                <AlertMessage Message="@_modalError" Variant="danger" />
                <div class="mb-3">
                    <label for="playerName" class="form-label">Name</label>
                    <InputText id="playerName" @bind-Value="_formModel.Name" class="form-control" placeholder="Player name" maxlength="50" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Avatar</label>
                    <AvatarPicker @bind-Value="_formModel.AvatarId" />
                </div>
            </EditForm>
        </Body>
        <Footer>
            <button type="button" class="btn btn-secondary" @onclick="HideModal">Cancel</button>
            <SpinnerButton Type="submit" Form="addPlayerForm" Busy="_saving" Variant="success">Save</SpinnerButton>
        </Footer>
    </Modal>

    <Modal Show="@(_showDeactivateConfirm && _playerToDeactivate != null)"
           Title="Deactivate Player" OnClose="() => _showDeactivateConfirm = false">
        <Body>
            <AlertMessage Message="@_deactivateError" Variant="danger" />
            <p>Are you sure you want to deactivate <strong>@_playerToDeactivate?.Name</strong>?</p>
            <p class="text-muted small">Deactivated players won't appear in match dropdowns but their history will be preserved.</p>
        </Body>
        <Footer>
            <button type="button" class="btn btn-secondary" @onclick="() => _showDeactivateConfirm = false">Cancel</button>
            <SpinnerButton Variant="danger" Busy="_saving" OnClick="ConfirmDeactivate">Deactivate</SpinnerButton>
        </Footer>
    </Modal>
}

@code {
    [Parameter] public string TeamCode { get; set; } = string.Empty;

    private Team? _team;
    private bool _loading = true;
    private List<Player> _activePlayers = [];
    private List<Player> _inactivePlayers = [];
    private List<StatResult> _stats = [];

    private bool _showModal;
    private PlayerFormModel _formModel = new();
    private string? _modalError;
    private bool _saving;

    private bool _showDeactivateConfirm;
    private Player? _playerToDeactivate;
    private string? _deactivateError;

    private string? _message;
    private bool _messageIsError;
    private bool _isAdmin;
    [CascadingParameter(Name = "MyPlayerId")] public int? MyPlayerId { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _team = await TeamAccess.GetCurrentTeamAsync();
            if (_team != null)
            {
                _isAdmin = await TeamAccess.IsAdminAsync(_team);
                await LoadPlayers();
                _stats = await StatsEngine.GetAllTimeAsync(_team.Id);
            }
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadPlayers()
    {
        if (_team == null) return;
        var allPlayers = await PlayerService.GetByTeamAsync(_team.Id, includeInactive: true);
        _activePlayers = allPlayers.Where(p => p.IsActive).ToList();
        _inactivePlayers = allPlayers.Where(p => !p.IsActive).ToList();
    }

    private void ShowAddModal()
    {
        _formModel = new PlayerFormModel { AvatarId = 1 };
        _modalError = null;
        _showModal = true;
    }

    private void HideModal()
    {
        _showModal = false;
        _modalError = null;
    }

    private async Task SavePlayer()
    {
        if (_team == null) return;

        _modalError = null;
        _saving = true;

        try
        {
            var name = _formModel.Name?.Trim() ?? string.Empty;
            if (name.Length < 1 || name.Length > 50)
            {
                _modalError = "Name must be 1-50 characters.";
                return;
            }
            _formModel.Name = name;

            if (await PlayerService.IsNameTakenAsync(_team.Id, name))
            {
                _modalError = "A player with this name already exists.";
                return;
            }

            var userId = await CurrentUser.GetUserIdAsync();
            if (userId == null)
            {
                _modalError = "You must be logged in.";
                return;
            }
            var created = await PlayerService.CreatePlaceholderAsync(_team.Id, userId.Value, _formModel.Name, _formModel.AvatarId);
            if (created == null)
            {
                _modalError = "Only the team admin can add players.";
                return;
            }
            _message = $"Player '{_formModel.Name}' added successfully.";
            _messageIsError = false;
            await LoadPlayers();
            HideModal();
        }
        catch (Exception)
        {
            _modalError = "Something went wrong. Please try again.";
        }
        finally
        {
            _saving = false;
        }
    }

    private void ShowDeactivateConfirm(Player player)
    {
        _playerToDeactivate = player;
        _deactivateError = null;
        _showDeactivateConfirm = true;
    }

    private async Task ConfirmDeactivate()
    {
        if (_playerToDeactivate == null || _team == null) return;

        _deactivateError = null;
        _saving = true;

        try
        {
            if (!await PlayerService.CanDeactivateAsync(_playerToDeactivate.Id))
            {
                _deactivateError = $"Cannot deactivate player with matches in the last {Constants.TimeThresholds.RecentActivityDays} days.";
                return;
            }

            var userId = await CurrentUser.GetUserIdAsync();
            if (userId == null)
            {
                _deactivateError = "You must be logged in.";
                return;
            }
            var deactivated = await PlayerService.DeactivateAsync(_playerToDeactivate.Id, _team.Id, userId.Value);
            if (!deactivated)
            {
                _deactivateError = "Failed to deactivate player.";
                return;
            }
            _message = $"Player '{_playerToDeactivate.Name}' deactivated.";
            _messageIsError = false;
            await LoadPlayers();
            _showDeactivateConfirm = false;
            _playerToDeactivate = null;
        }
        catch (Exception)
        {
            _deactivateError = "Something went wrong. Please try again.";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ReactivatePlayer(Player player)
    {
        if (_team == null) return;

        try
        {
            var userId = await CurrentUser.GetUserIdAsync();
            if (userId == null)
            {
                _message = "You must be logged in.";
                _messageIsError = true;
                return;
            }
            var reactivated = await PlayerService.ReactivateAsync(player.Id, _team.Id, userId.Value);
            if (!reactivated)
            {
                _message = "Failed to reactivate player.";
                _messageIsError = true;
                return;
            }
            _message = $"Player '{player.Name}' reactivated.";
            _messageIsError = false;
            await LoadPlayers();
            StateHasChanged();
        }
        catch (Exception)
        {
            _message = "Something went wrong. Please try again.";
            _messageIsError = true;
        }
    }

    private class PlayerFormModel
    {
        public string Name { get; set; } = string.Empty;
        public int AvatarId { get; set; } = 1;
    }
}
