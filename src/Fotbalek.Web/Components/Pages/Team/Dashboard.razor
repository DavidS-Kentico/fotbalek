@page "/{TeamCode}"
@layout TeamLayout
@rendermode InteractiveServer
@attribute [Authorize]
@inject TeamAccessService TeamAccess
@inject StatsService StatsService
@inject StatsEngine StatsEngine
@inject MatchService MatchService
@inject PlayerService PlayerService

<PageTitle>@(_team?.Name ?? "Dashboard") - Foosball Manager</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_team != null)
{
    <div class="container py-4">
        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Rankings</h5>
                        <a href="/@TeamCode/rankings" class="btn btn-sm btn-outline-success">View All</a>
                    </div>
                    <div class="card-body p-0">
                        @if (_rankings.Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="text-center" style="width: 50px;">#</th>
                                            <th>Player</th>
                                            <th class="text-end">ELO</th>
                                            <th class="text-end">Win Rate</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var player in _rankings.Take(Constants.Pagination.DashboardTopPlayers))
                                        {
                                            var isMine = player.PlayerId == MyPlayerId;
                                            <tr class="@(isMine ? "table-success" : "")">
                                                <td class="text-center">
                                                    <RankBadge Rank="@player.Rank" />
                                                </td>
                                                <td>
                                                    <a href="/@TeamCode/players/@player.PlayerId" class="text-decoration-none">
                                                        <Avatar AvatarId="@player.AvatarId" Size="sm" />
                                                        <span class="ms-2">@player.PlayerName</span>
                                                    </a>
                                                    @if (isMine)
                                                    {
                                                        <span class="badge badge-you ms-1">you</span>
                                                    }
                                                    @foreach (var badge in StatRegistry.PlayerBadges(_stats, player.PlayerId))
                                                    {
                                                        <span class="badge @badge.CssClass ms-1 px-1" title="@badge.Tooltip"><i class="@badge.IconClass"></i></span>
                                                    }
                                                </td>
                                                <td class="text-end fw-bold">@player.Elo</td>
                                                <td class="text-end text-muted">@player.WinRate.ToString("F1")%</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <EmptyState Icon="bi bi-people" Message="No players yet. Add some players to get started!">
                                <a href="/@TeamCode/players" class="btn btn-success btn-sm">Add Players</a>
                            </EmptyState>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-6 mb-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Recent Matches</h5>
                        <a href="/@TeamCode/matches" class="btn btn-sm btn-outline-success">View All</a>
                    </div>
                    <div class="card-body">
                        @if (_recentMatches.Count > 0)
                        {
                            @foreach (var match in _recentMatches.Take(Constants.Pagination.DashboardRecentMatches))
                            {
                                <MatchCard Match="@match" TeamCode="@TeamCode" Compact="true" />
                            }
                        }
                        else
                        {
                            <EmptyState Icon="bi bi-calendar-x" Message="No matches played yet.">
                                @if (_playerCount >= 4)
                                {
                                    <a href="/@TeamCode/match/new" class="btn btn-success btn-sm">Record First Match</a>
                                }
                                else
                                {
                                    <p class="small">You need at least 4 players to play a match.</p>
                                }
                            </EmptyState>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-3 mb-3">
                <StatTile Variant="success" Value="@_playerCount.ToString()" Label="Active Players" />
            </div>
            <div class="col-md-3 mb-3">
                <StatTile Variant="primary" Value="@_matchCount.ToString()" Label="Total Matches" />
            </div>
            <div class="col-md-3 mb-3">
                <StatTile Variant="info" Value="@_matchesThisWeek.ToString()" Label="Matches This Week" />
            </div>
            <div class="col-md-3 mb-3">
                <StatTile Variant="warning" Value="@_avgMatchScore.ToString("F1")" Label="Avg Goals/Match" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TeamCode { get; set; } = string.Empty;

    private Team? _team;
    private bool _loading = true;
    private List<PlayerRanking> _rankings = [];
    private List<Match> _recentMatches = [];
    private List<StatResult> _stats = [];
    private int _playerCount;
    private int _matchCount;
    private int _matchesThisWeek;
    private double _avgMatchScore;
    [CascadingParameter(Name = "MyPlayerId")] public int? MyPlayerId { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _team = await TeamAccess.GetCurrentTeamAsync();
            if (_team != null)
            {
                _rankings = await StatsService.GetRankingsAsync(_team.Id);
                _recentMatches = await MatchService.GetRecentByTeamAsync(_team.Id, Constants.Pagination.DashboardRecentMatches);
                _stats = await StatsEngine.GetAllTimeAsync(_team.Id);
                _playerCount = await PlayerService.GetActiveCountAsync(_team.Id);
                _matchCount = await MatchService.GetCountByTeamAsync(_team.Id);
                _matchesThisWeek = await MatchService.GetMatchesThisWeekAsync(_team.Id);
                _avgMatchScore = await MatchService.GetAverageMatchScoreAsync(_team.Id);
            }
            _loading = false;
            StateHasChanged();
        }
    }
}
