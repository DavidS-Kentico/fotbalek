@page "/team/{TeamCode}"
@layout TeamLayout
@rendermode InteractiveServer
@attribute [Authorize]
@implements IDisposable
@inject GameRoomManager GameRooms
@inject TeamAccessService TeamAccess
@inject StatsService StatsService
@inject StatsEngine StatsEngine
@inject MatchService MatchService
@inject SeasonService SeasonService
@inject PlayerService PlayerService
@inject TimeZoneService Tz

<PageTitle>@(_team?.Name ?? "Dashboard") - Foosball Manager</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_team != null)
{
    <PageContainer>
        @if (_activeSeason != null)
        {
            <Panel Class="border-success mb-4" BodyClass="py-3">
                    <div class="d-flex flex-wrap align-items-center gap-3">
                        <div class="flex-grow-1 min-w-0">
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <h4 class="mb-0"><i class="bi bi-award me-2 text-success"></i>@_activeSeason.Name</h4>
                                <span class="badge bg-success">Live</span>
                            </div>
                            @if (!string.IsNullOrEmpty(_activeSeason.Description))
                            {
                                <div class="text-muted small mt-1">@_activeSeason.Description</div>
                            }
                            <div class="text-muted small mt-1">
                                <i class="bi bi-calendar-range me-1"></i>@FormatPeriod(_activeSeason)
                                <span class="mx-1">·</span>
                                Day @_seasonDay
                                <span class="mx-1">·</span>
                                @_seasonMatchCount match@(_seasonMatchCount == 1 ? "" : "es")
                            </div>
                        </div>
                        <a href="/team/@TeamCode/seasons/@_activeSeason.Id" class="btn btn-sm btn-outline-success">
                            Season detail
                        </a>
                    </div>
            </Panel>
        }
        else if (_latestClosedSeason != null && _nextScheduledSeason == null)
        {
            <div class="alert alert-success d-flex flex-wrap align-items-center gap-2 mb-4">
                <span><strong>@_latestClosedSeason.Name</strong> has ended 🏆</span>
                <a href="/team/@TeamCode/seasons/@_latestClosedSeason.Id" class="alert-link">View the final results and awards</a>
                <span class="text-muted small ms-auto">Content below shows all-time numbers.</span>
            </div>
        }
        else if (_nextScheduledSeason != null)
        {
            <div class="alert alert-info d-flex flex-wrap align-items-center gap-2 mb-4">
                <span>
                    <strong>@_nextScheduledSeason.Name</strong> starts in @_daysUntilNextSeason day@(_daysUntilNextSeason == 1 ? "" : "s")
                    (@Tz.FormatLocalDate(_nextScheduledSeason.StartsAt)).
                </span>
                @if (_latestClosedSeason != null)
                {
                    <a href="/team/@TeamCode/seasons/@_latestClosedSeason.Id" class="alert-link">Results of @_latestClosedSeason.Name</a>
                }
                <span class="text-muted small ms-auto">Until then, matches are off-season; content below shows all-time numbers.</span>
            </div>
        }
        else if (!_hasAnySeason && _isCaptain)
        {
            <div class="alert alert-light border d-flex flex-wrap align-items-center gap-2 mb-4">
                <span><i class="bi bi-award me-1"></i>Group your matches into seasons — fresh ELO ladder, champions and permanent awards.</span>
                <a href="/team/@TeamCode/seasons/new" class="btn btn-sm btn-success ms-auto">Start your first season</a>
            </div>
        }

        @if (GameRooms.GetForTeam(_team.Id) is { } liveRoom)
        {
            var liveState = liveRoom.GetState();
            var seatedPlayers = liveState.Seats.Where(s => s.Occupied).ToList();
            var freeSeats = 4 - seatedPlayers.Count;
            <Panel Class="border-danger mb-4" BodyClass="py-3 d-flex flex-wrap align-items-center gap-3">
                <span class="live-dot"></span>
                <strong>Live game in progress</strong>
                <span>
                    @foreach (var seat in seatedPlayers)
                    {
                        <Avatar AvatarId="@(seat.AvatarId ?? 1)" Size="sm" Title="@seat.Name" CssClass="me-1" />
                    }
                </span>
                <span class="text-muted small">
                    @(freeSeats > 0 ? $"{freeSeats} seat{(freeSeats == 1 ? "" : "s")} free" : "table full")
                    <span class="mx-1">·</span>
                    <i class="bi bi-eye me-1"></i>@liveState.Viewers.Count watching
                </span>
                <a href="/team/@TeamCode/game" class="btn btn-sm btn-danger ms-auto">
                    @(freeSeats > 0 ? "Join" : "Watch")
                </a>
            </Panel>
        }

        <div class="row">
            <div class="col-lg-6 mb-4">
                <Panel Class="h-100" Flush>
                    <Header>
                        <i class="bi bi-bar-chart"></i>
                        <h2 class="panel__title">
                            Rankings
                            @if (_activeSeason != null)
                            {
                                <small class="text-muted fw-normal">(@_activeSeason.Name)</small>
                            }
                        </h2>
                        <div class="panel__actions"><a href="/team/@TeamCode/rankings" class="btn btn-sm btn-outline-success">View All</a></div>
                    </Header>
                    <ChildContent>
                        @if (_rankingRows.Count > 0)
                        {
                            <div class="table-responsive panel-scroll">
                                <table class="table table-hover mb-0 rankings-table">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="text-center" style="width: 50px;">#</th>
                                            <th>Player</th>
                                            <th class="text-end">ELO</th>
                                            <th class="text-end">Win Rate</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var player in _rankingRows.Take(_rankingsVisible))
                                        {
                                            var isMine = player.PlayerId == MyPlayerId;
                                            <tr class="@(isMine ? "table-success" : "")">
                                                <td class="text-center">
                                                    <RankBadge Rank="@player.Rank" />
                                                </td>
                                                <td>
                                                    <a href="/team/@TeamCode/players/@player.PlayerId" class="text-decoration-none">
                                                        <Avatar AvatarId="@player.AvatarId" Size="sm" />
                                                        <span class="ms-2">@player.PlayerName</span>
                                                    </a>
                                                    @if (player.PlayerId == _captainPlayerId)
                                                    {
                                                        <CaptainMark Class="ms-1" />
                                                    }
                                                    @if (isMine)
                                                    {
                                                        <span class="badge badge-you ms-1">you</span>
                                                    }
                                                    @{
                                                        var rankBadges = StatRegistry.PlayerBadges(_stats, player.PlayerId);
                                                        const int maxRankBadges = 5;
                                                        // Cap to keep the Player column tidy: show all when they fit, otherwise
                                                        // 4 badges + a "+N" overflow pill for the rest.
                                                        var visRankBadges = rankBadges.Count <= maxRankBadges ? rankBadges.Count : maxRankBadges - 1;
                                                        var hiddenRankBadges = rankBadges.Count - visRankBadges;
                                                        var wrGood = player.WinRate >= 50;
                                                    }
                                                    @foreach (var badge in rankBadges.Take(visRankBadges))
                                                    {
                                                        <span class="badge @badge.CssClass ms-1 px-1" title="@badge.Tooltip"><i class="@badge.IconClass"></i></span>
                                                    }
                                                    @if (hiddenRankBadges > 0)
                                                    {
                                                        <span class="badge-more ms-1" title="@string.Join(" · ", rankBadges.Skip(visRankBadges).Select(b => b.Tooltip))">+@hiddenRankBadges</span>
                                                    }
                                                </td>
                                                <td class="text-end elo-cell">@player.Elo</td>
                                                <td class="text-end">
                                                    <div class="rank-wr">
                                                        <span class="rank-wr__pct @(wrGood ? "good" : "bad")">@player.WinRate.ToString("F1")%</span>
                                                        <span class="rank-wr__track"><span class="rank-wr__fill @(wrGood ? "" : "bad")" style="width:@player.WinRate.ToString("F0")%"></span></span>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            @if (_rankingRows.Count > _rankingsVisible)
                            {
                                <LoadMoreButton Compact Remaining="@(_rankingRows.Count - _rankingsVisible)" OnClick="LoadMoreRankings" />
                            }
                        }
                        else
                        {
                            <EmptyState Icon="bi bi-people" Message="@(_activeSeason != null ? "No seasonal matches yet — record the first one!" : "No players yet. Add some players to get started!")">
                                <a href="/team/@TeamCode/players" class="btn btn-success btn-sm">Add Players</a>
                            </EmptyState>
                        }
                    </ChildContent>
                </Panel>
            </div>

            <div class="col-lg-6 mb-4">
                <Panel Title="Recent Matches" Icon="bi bi-clock-history" Class="h-100">
                    <Actions><a href="/team/@TeamCode/matches" class="btn btn-sm btn-outline-success">View All</a></Actions>
                    <ChildContent>
                        @if (_recentMatches.Count > 0)
                        {
                            <div class="dashboard-recent panel-scroll">
                                <MatchDayList Matches="_recentMatches" TeamCode="@TeamCode" Compact="true" HeaderMarginClass="mt-3 mb-2" />
                            </div>
                            @if (_recentMatches.Count < _matchCount)
                            {
                                <LoadMoreButton Compact Busy="_loadingMore" Remaining="@(_matchCount - _recentMatches.Count)" OnClick="LoadMoreRecent" />
                            }
                        }
                        else
                        {
                            <EmptyState Icon="bi bi-calendar-x" Message="@(_activeSeason != null ? "No matches in this season yet." : "No matches played yet.")">
                                @if (_playerCount >= 4)
                                {
                                    <a href="/team/@TeamCode/match/new" class="btn btn-success btn-sm">Record First Match</a>
                                }
                                else
                                {
                                    <p class="small">You need at least 4 players to play a match.</p>
                                }
                            </EmptyState>
                        }
                    </ChildContent>
                </Panel>
            </div>
        </div>

        <div class="row">
            <div class="col-md-3 mb-3">
                <StatTile Variant="success" Icon="bi bi-people-fill" Value="@_playerCount.ToString()" Label="Active Players" />
            </div>
            <div class="col-md-3 mb-3">
                <StatTile Variant="primary" Icon="bi bi-controller" Value="@_matchCount.ToString()" Label="@(_activeSeason != null ? "Season Matches" : "Total Matches")" />
            </div>
            <div class="col-md-3 mb-3">
                <StatTile Variant="info" Icon="bi bi-calendar-week" Value="@_matchesThisWeek.ToString()" Label="Matches This Week" />
            </div>
            <div class="col-md-3 mb-3">
                <StatTile Variant="warning" Icon="bi bi-bullseye" Value="@_avgMatchScore.ToString("F1")" Label="Avg Goals/Match" />
            </div>
        </div>
    </PageContainer>
}

@code {
    [Parameter] public string TeamCode { get; set; } = string.Empty;

    private Team? _team;
    private bool _loading = true;
    private bool _isCaptain;
    private List<Match> _recentMatches = [];
    private List<StatResult> _stats = [];
    private int _playerCount;
    private int _matchCount;
    private int _matchesThisWeek;
    private double _avgMatchScore;
    [CascadingParameter(Name = "MyPlayerId")] public int? MyPlayerId { get; set; }

    // Player claimed by the team captain, if any — marked with the armband "C" in the rankings preview.
    private int? _captainPlayerId;

    private bool _hasAnySeason;
    private Season? _activeSeason;
    private Season? _latestClosedSeason;
    private Season? _nextScheduledSeason;
    private int _daysUntilNextSeason;
    private int _seasonDay;
    private int _seasonMatchCount;

    // Unified ranking rows: seasonal standings when a season is active, all-time otherwise.
    private List<(int Rank, int PlayerId, string PlayerName, int AvatarId, int Elo, double WinRate)> _rankingRows = [];

    // Fixed-height scroll panels: "Load more" reveals the next chunk within the capped scroll
    // area, so the panel height never grows. Rankings are held in memory (all rows loaded);
    // recent matches are fetched from the server a batch at a time until the lens is exhausted.
    private int _rankingsVisible = Constants.Pagination.DashboardTopPlayers;
    private int _recentTake = Constants.Pagination.DashboardRecentMatches;
    private bool _loadingMore;

    private void LoadMoreRankings() => _rankingsVisible += Constants.Pagination.DashboardTopPlayers;

    private async Task LoadMoreRecent()
    {
        if (_team == null || _loadingMore) return;
        _loadingMore = true;
        try
        {
            _recentTake += Constants.Pagination.DashboardRecentMatches;
            _recentMatches = await MatchService.GetRecentByTeamAsync(_team.Id, _recentTake, _activeSeason?.Id);
        }
        finally
        {
            _loadingMore = false;
        }
    }

    private bool _gameRoomsSubscribed;

    private async void OnGameRoomsChanged()
    {
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException)
        {
            // Circuit torn down between event and dispatch.
        }
    }

    public void Dispose()
    {
        if (_gameRoomsSubscribed)
        {
            GameRooms.Changed -= OnGameRoomsChanged;
            _gameRoomsSubscribed = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            GameRooms.Changed += OnGameRoomsChanged;
            _gameRoomsSubscribed = true;
            await Tz.EnsureResolvedAsync();
            _team = await TeamAccess.GetCurrentTeamAsync();
            if (_team != null)
            {
                _isCaptain = await TeamAccess.IsCaptainAsync(_team);

                if (_team.CaptainUserId is int captainUserId)
                {
                    _captainPlayerId = (await PlayerService.GetUserPlayerInTeamAsync(_team.Id, captainUserId))?.Id;
                }

                var seasons = await SeasonService.GetByTeamAsync(_team.Id);
                var now = DateTimeOffset.UtcNow;
                _hasAnySeason = seasons.Count > 0;
                _activeSeason = seasons.FirstOrDefault(s => s.IsActiveAt(now));
                _latestClosedSeason = seasons.Where(s => s.IsClosed).OrderByDescending(s => s.ClosedAt).FirstOrDefault();
                _nextScheduledSeason = seasons.Where(s => s.IsScheduledAt(now)).OrderBy(s => s.StartsAt).FirstOrDefault();
                if (_nextScheduledSeason != null)
                {
                    _daysUntilNextSeason = Math.Max(1, (int)Math.Ceiling((_nextScheduledSeason.StartsAt - now).TotalDays));
                }

                // "Current season" is the default lens; with no active season everything falls back to all-time.
                var seasonId = _activeSeason?.Id;

                if (_activeSeason != null)
                {
                    _seasonDay = Math.Max(1, (int)(now - _activeSeason.StartsAt).TotalDays + 1);
                    _seasonMatchCount = await SeasonService.GetMatchCountAsync(_activeSeason.Id);

                    var standings = await StatsService.GetSeasonStandingsAsync(_activeSeason);
                    _rankingRows = standings
                        .Select(r => (r.Rank, r.PlayerId, r.PlayerName, r.AvatarId, r.Elo, r.WinRate))
                        .ToList();

                    var (players, matches, seasonPlayers) = await StatsEngine.LoadSeasonAsync(_team.Id, _activeSeason.Id);
                    _stats = StatsEngine.ComputeSeason(players, seasonPlayers, matches, isFullScope: true);
                }
                else
                {
                    var rankings = await StatsService.GetRankingsAsync(_team.Id);
                    _rankingRows = rankings
                        .Select(r => (r.Rank, r.PlayerId, r.PlayerName, r.AvatarId, r.Elo, r.WinRate))
                        .ToList();
                    _stats = await StatsEngine.GetAllTimeAsync(_team.Id);
                }

                _recentMatches = await MatchService.GetRecentByTeamAsync(_team.Id, _recentTake, seasonId);
                _playerCount = await PlayerService.GetActiveCountAsync(_team.Id);
                _matchCount = await MatchService.GetCountByTeamAsync(_team.Id, seasonId);
                _matchesThisWeek = await MatchService.GetMatchesThisWeekAsync(_team.Id, seasonId);
                _avgMatchScore = await MatchService.GetAverageMatchScoreAsync(_team.Id, seasonId);
            }
            _loading = false;
            StateHasChanged();
        }
    }

    private string FormatPeriod(Season season)
    {
        var start = Tz.FormatLocalDate(season.StartsAt);
        var end = season.EndsAt is { } ends ? Tz.FormatLocalDate(ends) : "open-ended";
        return $"{start} – {end}";
    }
}
