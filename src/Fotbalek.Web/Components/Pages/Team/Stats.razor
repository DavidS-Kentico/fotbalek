@page "/team/{TeamCode}/stats"
@layout TeamLayout
@rendermode InteractiveServer
@attribute [Authorize]
@inject TeamAccessService TeamAccess
@inject StatsService StatsService
@inject StatsEngine StatsEngine
@inject SeasonService SeasonService
@inject PlayerService PlayerService
@inject MatchService MatchService
@inject TimeZoneService Tz
@inject IJSRuntime JS
@using Fotbalek.Web.Helpers

<PageTitle>Statistics - Foosball Manager</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else
{
    <PageContainer>
        <PageHeader Title="Statistics" Icon="bi bi-graph-up">
            <Actions>
                @if (_seasons.Count > 0)
                {
                    <SeasonSelector Seasons="_seasons" @bind-Value="_selectedSeasonId" OnChangedCallback="OnScopeChanged" />
                }
            </Actions>
        </PageHeader>

        <Panel BodyClass="py-2">
            <div class="d-flex flex-wrap align-items-center gap-3">
                <TimePeriodFilter @bind-SelectedPeriod="_selectedPeriod"
                                  @bind-CustomStartDate="_customStartDate"
                                  @bind-CustomEndDate="_customEndDate"
                                  LimitCustomRangeToThreeMonths="true"
                                  Today="Tz.Today"
                                  OnFilterChanged="OnFilterChanged" />

                @if (_selectedPeriod != "all")
                {
                    <span class="badge bg-secondary">@GetFilterDescription()</span>
                }
            </div>
        </Panel>

        <Panel Title="Stats" Icon="bi bi-trophy" Class="mb-4" BodyClass="py-2">
                @foreach (var themeGroup in _stats.GroupBy(s => s.Theme).OrderBy(g => (int)g.Key))
                {
                    <div class="stats-theme-row">
                        <small class="text-muted fw-semibold stats-theme-label">
                            <i class="@themeGroup.Key.Icon() me-1"></i>@themeGroup.Key.DisplayName()
                        </small>
                        <div class="stats-theme-pills">
                            @foreach (var stat in themeGroup)
                            {
                                var hasHolders = stat.Holders.Count > 0;
                                <div class="d-flex align-items-center gap-1 px-2 py-1 rounded small @(hasHolders ? StatPillCss(stat) : "bg-secondary bg-opacity-10 opacity-50")"
                                     title="@stat.Description">
                                    <span>@stat.Emoji</span>
                                    <span class="fw-semibold">@stat.Name:</span>
                                    @if (hasHolders)
                                    {
                                        <span>@string.Join(", ", stat.Holders.Select(h => h.PlayerName).Distinct())</span>
                                        <span class="text-muted">(@stat.Holders[0].DisplayValue)</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">—</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
        </Panel>

        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <StatTile Variant="success" Icon="bi bi-people"
                          Value="@_filteredPlayerCount.ToString()"
                          Label="@(_selectedPeriod == "all" ? "Active Players" : "Players in Period")" />
            </div>
            <div class="col-md-3 mb-3">
                <StatTile Variant="primary" Icon="bi bi-controller"
                          Value="@_filteredMatchCount.ToString()"
                          Label="@(_selectedPeriod == "all" ? "Total Matches" : "Matches in Period")" />
            </div>
            <div class="col-md-3 mb-3">
                <StatTile Variant="info" Icon="bi bi-bullseye"
                          Value="@_filteredTotalGoals.ToString()"
                          Label="@(_selectedPeriod == "all" ? "Total Goals" : "Goals in Period")" />
            </div>
            <div class="col-md-3 mb-3">
                <StatTile Variant="warning" Icon="bi bi-calculator"
                          Value="@_filteredAvgGoalsPerMatch.ToString("F1")"
                          Label="Avg Goals/Match" />
            </div>
        </div>

        <div class="row">
            <div class="col-12 mb-4">
                <ChartCard CanvasId="eloTrajectoryChart"
                           Title="ELO Trajectory" Icon="bi bi-activity"
                           Subtitle="Each player's ELO after every match. Click legend entries to toggle players."
                           Height="200"
                           HasData="_eloTrajectoryDatasets.Count > 0" />
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6 mb-4">
                <ChartCard CanvasId="eloDistributionChart" Title="@(IsSeasonScope ? "Seasonal ELO Distribution" : "ELO Distribution")" Icon="bi bi-graph-up-arrow"
                           HasData="@(IsSeasonScope ? _seasonPlayersById.Count > 0 : _rankings.Count > 0)" />
            </div>
            <div class="col-lg-6 mb-4">
                <ChartCard CanvasId="winRateChart" Title="Win Rate Distribution" Icon="bi bi-pie-chart"
                           HasData="_filteredRankings.Count > 0" />
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6 mb-4">
                <ChartCard CanvasId="gamesPerPlayerChart" Title="Games per Player" Icon="bi bi-person-lines-fill"
                           HasData="_filteredRankings.Count > 0" />
            </div>
            <div class="col-lg-6 mb-4">
                <ChartCard CanvasId="matchesOverTimeChart" Title="Matches Over Time" Icon="bi bi-calendar-week"
                           HasData="_matchesOverTime.Count > 0" />
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6 mb-4">
                <ChartCard CanvasId="dayOfWeekChart" Title="Activity by Day of Week" Icon="bi bi-calendar3"
                           HasData="_dayOfWeekStats.Any(d => d > 0)" />
            </div>
            <div class="col-lg-6 mb-4">
                <ChartCard CanvasId="commonPairsChart" Title="Most Common Pairs" Icon="bi bi-people-fill"
                           HasData="_filteredPairStats.Count > 0" />
            </div>
        </div>

        <div class="row">
            <div class="col-12 mb-4">
                <PlayerMatrix Rows="_h2hMatrix"
                              Title="Head-to-Head Matrix" Icon="bi bi-grid-3x3"
                              Subtitle="Row player's win rate when facing column player as an opponent. Cell brightness reflects sample size."
                              TooltipConnector="vs" />
            </div>
        </div>

        <div class="row">
            <div class="col-12 mb-4">
                <PlayerMatrix Rows="_teammateMatrix"
                              Title="Teammate Matrix" Icon="bi bi-people"
                              Subtitle="Win rate when row player teams up with column player. Cell brightness reflects sample size."
                              TooltipConnector="with" />
            </div>
        </div>
    </PageContainer>
}

@code {
    [Parameter] public string TeamCode { get; set; } = string.Empty;

    private Team? _team;
    private bool _loading = true;

    private List<PlayerRanking> _rankings = [];
    private IReadOnlyDictionary<int, Player> _playersById = new Dictionary<int, Player>();
    private List<Match> _allMatches = [];

    private List<Season> _seasons = [];
    private int? _selectedSeasonId;
    private Season? _selectedSeason;
    private IReadOnlyDictionary<int, SeasonPlayer> _seasonPlayersById = new Dictionary<int, SeasonPlayer>();

    private string _selectedPeriod = "all";
    private DateOnly? _customStartDate;
    private DateOnly? _customEndDate;

    private List<Match> _filteredMatches = [];
    private List<FilteredPlayerRanking> _filteredRankings = [];
    private List<FilteredPairStats> _filteredPairStats = [];
    private List<StatResult> _stats = [];
    private int _filteredPlayerCount;
    private int _filteredMatchCount;
    private int _filteredTotalGoals;
    private double _filteredAvgGoalsPerMatch;
    private Dictionary<string, int> _matchesOverTime = [];
    private int[] _dayOfWeekStats = new int[7];
    private List<PlayerMatrix.MatrixRow> _h2hMatrix = [];
    private List<PlayerMatrix.MatrixRow> _teammateMatrix = [];
    private List<string> _eloTrajectoryLabels = [];
    private List<EloTrajectoryDataset> _eloTrajectoryDatasets = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await Tz.EnsureResolvedAsync();
        _team = await TeamAccess.GetCurrentTeamAsync();
        if (_team != null)
        {
            _rankings = await StatsService.GetRankingsAsync(_team.Id);

            var (players, matches) = await StatsEngine.LoadAsync(_team.Id);
            _playersById = players;
            _allMatches = matches.ToList();

            _seasons = await SeasonService.GetByTeamAsync(_team.Id);
            // Default scope = the current season; all-time when none is active (idle default).
            _selectedSeasonId = _seasons.FirstOrDefault(s => s.IsActiveAt(DateTimeOffset.UtcNow))?.Id;
            await ResolveScopeAsync();

            _customEndDate = Tz.Today;
            _customStartDate = _customEndDate.Value.AddMonths(-1);

            ApplyFilter();
        }
        _loading = false;
        StateHasChanged();

        await RenderCharts();
    }

    private async Task ResolveScopeAsync()
    {
        _selectedSeason = _selectedSeasonId is int id ? _seasons.FirstOrDefault(s => s.Id == id) : null;
        if (_selectedSeason != null && _team != null)
        {
            var (_, _, seasonPlayers) = await StatsEngine.LoadSeasonAsync(_team.Id, _selectedSeason.Id);
            _seasonPlayersById = seasonPlayers;
        }
        else
        {
            _seasonPlayersById = new Dictionary<int, SeasonPlayer>();
        }
    }

    private async Task OnScopeChanged()
    {
        await ResolveScopeAsync();
        ApplyFilter();
        StateHasChanged();
        await RenderCharts();
    }

    /// <summary>The selected scope's matches — the season's subset, or every match for all-time.</summary>
    private IEnumerable<Match> ScopeMatches => _selectedSeason is { } season
        ? _allMatches.Where(m => m.SeasonId == season.Id)
        : _allMatches;

    private bool IsSeasonScope => _selectedSeason != null;

    private void ApplyFilter()
    {
        // The time period filter narrows the selected scope (season or all-time) further.
        _filteredMatches = ScopeMatches
            .Where(m => DateFilterHelper.IsDateInPeriod(
                Tz.ToLocalDate(m.PlayedAt),
                _selectedPeriod,
                Tz.Today,
                _customStartDate,
                _customEndDate))
            .ToList();

        RecalculateStats();
    }

    private void RecalculateStats()
    {
        _filteredMatchCount = _filteredMatches.Count;
        _filteredTotalGoals = _filteredMatches.Sum(m => m.Team1Score + m.Team2Score);
        _filteredAvgGoalsPerMatch = _filteredMatchCount > 0 ? (double)_filteredTotalGoals / _filteredMatchCount : 0;

        var playerStats = new Dictionary<int, (string Name, int AvatarId, int Games, int Wins)>();
        foreach (var match in _filteredMatches)
        {
            foreach (var mp in match.MatchPlayers)
            {
                if (!playerStats.ContainsKey(mp.PlayerId))
                    playerStats[mp.PlayerId] = (mp.Player.Name, mp.Player.AvatarId, 0, 0);

                var current = playerStats[mp.PlayerId];
                var won = IsWinByScore(match, mp.TeamNumber);
                playerStats[mp.PlayerId] = (current.Name, current.AvatarId, current.Games + 1, current.Wins + (won ? 1 : 0));
            }
        }

        _filteredPlayerCount = playerStats.Count;
        _filteredRankings = playerStats
            .Select(kvp => new FilteredPlayerRanking
            {
                PlayerId = kvp.Key,
                PlayerName = kvp.Value.Name,
                AvatarId = kvp.Value.AvatarId,
                Matches = kvp.Value.Games,
                Wins = kvp.Value.Wins,
                WinRate = kvp.Value.Games > 0 ? (double)kvp.Value.Wins / kvp.Value.Games * 100 : 0
            })
            .OrderByDescending(r => r.WinRate)
            .ThenByDescending(r => r.Matches)
            .ToList();

        var pairStats = new Dictionary<string, FilteredPairStats>();
        foreach (var match in _filteredMatches)
        {
            AccumulateTeamPair(match, 1, pairStats);
            AccumulateTeamPair(match, 2, pairStats);
        }
        _filteredPairStats = pairStats.Values
            .OrderByDescending(p => p.Matches)
            .Take(8)
            .ToList();

        CalculateMatchesOverTime();
        CalculateDayOfWeekStats();

        // All themed stats — single call into the registry replaces ~250 lines of inline calculations.
        // Season scope uses the ladder-aware context so ELO-based badges show seasonal numbers.
        _stats = IsSeasonScope
            ? StatsEngine.ComputeSeason(_playersById, _seasonPlayersById, _filteredMatches, isFullScope: _selectedPeriod == "all")
            : StatsEngine.Compute(_playersById, _filteredMatches, isAllTime: _selectedPeriod == "all");

        _h2hMatrix = BuildMatrix(includeAcrossTeams: true);
        _teammateMatrix = BuildMatrix(includeAcrossTeams: false);
        CalculateEloTrajectory();
    }

    private static bool IsWinByScore(Match match, int teamNumber) =>
        teamNumber == 1 ? match.Team1Score > match.Team2Score : match.Team2Score > match.Team1Score;

    /// <summary>Current ELO of the selected ladder — orders chart series and the distribution chart.</summary>
    private int CurrentEloOf(int playerId) => IsSeasonScope
        ? (_seasonPlayersById.TryGetValue(playerId, out var sp) ? sp.Elo : Constants.Elo.DefaultRating)
        : _rankings.FirstOrDefault(r => r.PlayerId == playerId)?.Elo ?? 0;

    private List<PlayerMatrix.MatrixRow> BuildMatrix(bool includeAcrossTeams)
    {
        if (_filteredMatches.Count == 0 || _filteredRankings.Count < 2) return [];

        var pairs = new Dictionary<(int Row, int Col), (int Wins, int Games)>();

        foreach (var match in _filteredMatches)
        {
            var team1 = match.MatchPlayers.Where(mp => mp.TeamNumber == 1).ToList();
            var team2 = match.MatchPlayers.Where(mp => mp.TeamNumber == 2).ToList();
            if (team1.Count == 0 || team2.Count == 0) continue;

            var team1Won = match.Team1Score > match.Team2Score;

            if (includeAcrossTeams)
            {
                foreach (var p1 in team1)
                foreach (var p2 in team2)
                {
                    AccumulatePair(pairs, p1.PlayerId, p2.PlayerId, team1Won);
                    AccumulatePair(pairs, p2.PlayerId, p1.PlayerId, !team1Won);
                }
            }
            else
            {
                foreach (var team in new[] { (Players: team1, Won: team1Won), (Players: team2, Won: !team1Won) })
                {
                    if (team.Players.Count != 2) continue;
                    AccumulatePair(pairs, team.Players[0].PlayerId, team.Players[1].PlayerId, team.Won);
                    AccumulatePair(pairs, team.Players[1].PlayerId, team.Players[0].PlayerId, team.Won);
                }
            }
        }

        var rankingByPlayerId = _filteredRankings.ToDictionary(r => r.PlayerId);

        var orderedIds = _filteredRankings
            .Select(r => r.PlayerId)
            .OrderByDescending(CurrentEloOf)
            .ToList();

        return orderedIds
            .Select(rowId =>
            {
                var ranking = rankingByPlayerId[rowId];
                var row = new PlayerMatrix.MatrixRow
                {
                    PlayerId = rowId,
                    PlayerName = ranking.PlayerName,
                    AvatarId = ranking.AvatarId
                };
                foreach (var colId in orderedIds)
                {
                    if (rowId == colId) continue;
                    pairs.TryGetValue((rowId, colId), out var p);
                    row.Cells[colId] = new PlayerMatrix.MatrixCell { Wins = p.Wins, Games = p.Games };
                }
                return row;
            })
            .ToList();
    }

    private void CalculateEloTrajectory()
    {
        _eloTrajectoryLabels = [];
        _eloTrajectoryDatasets = [];

        if (_filteredMatches.Count == 0) return;

        var ordered = _filteredMatches.OrderBy(m => m.PlayedAt).ThenBy(m => m.Id).ToList();
        _eloTrajectoryLabels = ordered.Select(m => m.PlayedAt.ToString("MMM dd")).ToList();

        var participantIds = ordered.SelectMany(m => m.MatchPlayers.Select(mp => mp.PlayerId)).Distinct().ToHashSet();
        var orderedPlayerIds = participantIds
            .OrderByDescending(CurrentEloOf)
            .ToList();

        var nameByPlayerId = ordered
            .SelectMany(m => m.MatchPlayers)
            .GroupBy(mp => mp.PlayerId)
            .ToDictionary(g => g.Key, g => g.First().Player.Name);

        for (var i = 0; i < orderedPlayerIds.Count; i++)
        {
            var pid = orderedPlayerIds[i];
            var data = new int?[ordered.Count];
            for (var j = 0; j < ordered.Count; j++)
            {
                var mp = ordered[j].MatchPlayers.FirstOrDefault(p => p.PlayerId == pid);
                // Season scope plots the seasonal ladder trajectory.
                data[j] = mp == null ? null : IsSeasonScope ? mp.SeasonEloAfter : mp.EloAfter;
            }
            _eloTrajectoryDatasets.Add(new EloTrajectoryDataset
            {
                Label = nameByPlayerId[pid],
                Data = data,
                Color = TrajectoryPalette[i % TrajectoryPalette.Length]
            });
        }
    }

    private static readonly string[] TrajectoryPalette =
    {
        "#198754", "#0d6efd", "#dc3545", "#fd7e14", "#6f42c1",
        "#20c997", "#e83e8c", "#ffc107", "#0dcaf0", "#6c757d",
        "#795548", "#ff5722", "#9c27b0", "#3f51b5", "#009688"
    };

    private static void AccumulatePair(Dictionary<(int Row, int Col), (int Wins, int Games)> pairs, int rowId, int colId, bool rowWon)
    {
        pairs.TryGetValue((rowId, colId), out var current);
        pairs[(rowId, colId)] = (current.Wins + (rowWon ? 1 : 0), current.Games + 1);
    }

    private static void AccumulateTeamPair(Match match, int teamNumber, Dictionary<string, FilteredPairStats> pairStats)
    {
        var teamPlayers = match.MatchPlayers
            .Where(mp => mp.TeamNumber == teamNumber)
            .OrderBy(mp => mp.PlayerId)
            .ToList();

        if (teamPlayers.Count != 2) return;

        var key = $"{teamPlayers[0].PlayerId}-{teamPlayers[1].PlayerId}";
        var won = IsWinByScore(match, teamNumber);

        if (!pairStats.TryGetValue(key, out var pair))
        {
            pair = new FilteredPairStats
            {
                Player1Name = teamPlayers[0].Player.Name,
                Player2Name = teamPlayers[1].Player.Name
            };
            pairStats[key] = pair;
        }
        pair.Matches++;
        if (won) pair.Wins++;
    }

    private void CalculateMatchesOverTime()
    {
        _matchesOverTime.Clear();

        if (_filteredMatches.Count == 0) return;

        var (startDate, endDate) = GetFilterDateRange();
        var totalDays = (endDate.ToDateTime(TimeOnly.MinValue) - startDate.ToDateTime(TimeOnly.MinValue)).Days + 1;

        if (totalDays < 14)
        {
            for (var i = 0; i < totalDays; i++)
            {
                var day = startDate.AddDays(i);
                _matchesOverTime[day.ToString("MMM dd")] =
                    _filteredMatches.Count(m => Tz.ToLocalDate(m.PlayedAt) == day);
            }
        }
        else
        {
            var weeksCount = Math.Min(13, Math.Max(1, (int)Math.Ceiling(totalDays / 7.0)));

            for (var i = weeksCount - 1; i >= 0; i--)
            {
                var weekEnd = endDate.AddDays(-7 * i);
                var weekStart = weekEnd.AddDays(-6);
                if (weekStart < startDate) weekStart = startDate;

                _matchesOverTime[weekStart.ToString("MMM dd")] = _filteredMatches.Count(m =>
                    Tz.ToLocalDate(m.PlayedAt) >= weekStart &&
                    Tz.ToLocalDate(m.PlayedAt) <= weekEnd);
            }
        }
    }

    private (DateOnly startDate, DateOnly endDate) GetFilterDateRange()
    {
        var today = Tz.Today;
        var range = DateFilterHelper.GetDateRange(_selectedPeriod, today, _customStartDate, _customEndDate);

        if (range.HasValue) return range.Value;

        return _allMatches.Count > 0
            ? (Tz.ToLocalDate(_allMatches.Min(m => m.PlayedAt)), today)
            : (today.AddMonths(-1), today);
    }

    private void CalculateDayOfWeekStats()
    {
        _dayOfWeekStats = new int[7];
        foreach (var match in _filteredMatches)
        {
            _dayOfWeekStats[(int)Tz.ToLocalDate(match.PlayedAt).DayOfWeek]++;
        }
    }

    private async Task OnFilterChanged()
    {
        ApplyFilter();
        StateHasChanged();
        await RenderCharts();
    }

    private string GetFilterDescription()
    {
        var periodDesc = DateFilterHelper.GetPeriodDescription(_selectedPeriod, Tz.Today, _customStartDate, _customEndDate);
        return periodDesc != null ? $"{periodDesc} ({_filteredMatchCount} matches)" : $"{_filteredMatchCount} matches";
    }

    private static string StatPillCss(StatResult stat)
    {
        // Tint badge-eligible stats with their badge color so the page mirrors how they appear elsewhere.
        // bg-body-tertiary (not bg-light) so the neutral pill stays readable in dark mode.
        if (stat.Badge == null) return "bg-body-tertiary";

        var css = stat.Badge.CssClass;
        if (css.Contains("bg-warning"))   return "bg-warning bg-opacity-10";
        if (css.Contains("bg-danger"))    return "bg-danger bg-opacity-10";
        if (css.Contains("bg-info"))      return "bg-info bg-opacity-10";
        if (css.Contains("bg-success"))   return "bg-success bg-opacity-10";
        if (css.Contains("bg-primary"))   return "bg-primary bg-opacity-10";
        if (css.Contains("bg-dark"))      return "bg-dark bg-opacity-10";
        if (css.Contains("bg-secondary")) return "bg-secondary bg-opacity-10";
        if (css.Contains("bg-purple"))    return "bg-purple-subtle";
        return "bg-body-tertiary";
    }

    private async Task RenderCharts()
    {
        // ELO distribution: seasonal ladder (participants' SeasonPlayer.Elo) in season scope,
        // all-time Player.Elo otherwise.
        if (IsSeasonScope)
        {
            var participants = _seasonPlayersById.Values
                .Where(sp => _playersById.TryGetValue(sp.PlayerId, out var p) && p.IsActive)
                .OrderByDescending(sp => sp.Elo)
                .ToList();
            if (participants.Count > 0)
            {
                var eloLabels = participants.Select(sp => _playersById[sp.PlayerId].Name).ToArray();
                var eloData = participants.Select(sp => sp.Elo).ToArray();
                await JS.InvokeVoidAsync("renderBarChart", "eloDistributionChart", eloLabels, eloData, "Seasonal ELO", "#198754");
            }
        }
        else if (_rankings.Count > 0)
        {
            var eloLabels = _rankings.Select(r => r.PlayerName).ToArray();
            var eloData = _rankings.Select(r => r.Elo).ToArray();
            await JS.InvokeVoidAsync("renderBarChart", "eloDistributionChart", eloLabels, eloData, "ELO", "#198754");
        }

        if (_filteredRankings.Count > 0)
        {
            var withMatches = _filteredRankings.Where(r => r.Matches > 0).ToArray();
            var wrLabels = withMatches.Select(r => r.PlayerName).ToArray();
            var wrData = withMatches.Select(r => r.WinRate).ToArray();
            await JS.InvokeVoidAsync("renderBarChart", "winRateChart", wrLabels, wrData, "Win Rate %", "#0d6efd");

            var byGames = _filteredRankings.OrderByDescending(r => r.Matches).ToArray();
            var pieColors = new[] { "#198754", "#0d6efd", "#6f42c1", "#fd7e14", "#20c997", "#e83e8c", "#ffc107", "#dc3545", "#6c757d", "#17a2b8" };
            await JS.InvokeVoidAsync("renderPieChart", "gamesPerPlayerChart",
                byGames.Select(r => r.PlayerName).ToArray(),
                byGames.Select(r => r.Matches).ToArray(),
                pieColors);
        }

        if (_matchesOverTime.Count > 0)
        {
            await JS.InvokeVoidAsync("renderLineChart", "matchesOverTimeChart",
                _matchesOverTime.Keys.ToArray(),
                _matchesOverTime.Values.ToArray(),
                "Matches", "#fd7e14");
        }

        if (_dayOfWeekStats.Any(d => d > 0))
        {
            var dayLabels = new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" };
            await JS.InvokeVoidAsync("renderBarChart", "dayOfWeekChart", dayLabels, _dayOfWeekStats, "Matches", "#20c997");
        }

        if (_filteredPairStats.Count > 0)
        {
            var pairLabels = _filteredPairStats.Select(p => $"{p.Player1Name} & {p.Player2Name}").ToArray();
            var pairData = _filteredPairStats.Select(p => p.Matches).ToArray();
            await JS.InvokeVoidAsync("renderHorizontalBarChart", "commonPairsChart", pairLabels, pairData, "Matches", "#e83e8c");
        }

        if (_eloTrajectoryDatasets.Count > 0)
        {
            var datasets = _eloTrajectoryDatasets
                .Select(d => new { label = d.Label, data = d.Data, color = d.Color })
                .ToArray();
            await JS.InvokeVoidAsync("renderMultiLineChart", "eloTrajectoryChart", _eloTrajectoryLabels.ToArray(), datasets);
        }
    }

    private class FilteredPlayerRanking
    {
        public int PlayerId { get; set; }
        public string PlayerName { get; set; } = "";
        public int AvatarId { get; set; }
        public int Matches { get; set; }
        public int Wins { get; set; }
        public double WinRate { get; set; }
    }

    private class FilteredPairStats
    {
        public string Player1Name { get; set; } = "";
        public string Player2Name { get; set; } = "";
        public int Matches { get; set; }
        public int Wins { get; set; }
    }

    private class EloTrajectoryDataset
    {
        public string Label { get; set; } = "";
        public int?[] Data { get; set; } = [];
        public string Color { get; set; } = "";
    }
}
