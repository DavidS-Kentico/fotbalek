@page "/team/{TeamCode}/rankings"
@layout TeamLayout
@rendermode InteractiveServer
@attribute [Authorize]
@inject TeamAccessService TeamAccess
@inject StatsService StatsService
@inject StatsEngine StatsEngine
@inject SeasonService SeasonService
@inject PlayerService PlayerService

<PageTitle>Rankings - Foosball Manager</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else
{
    <PageContainer>
        <PageHeader Title="Rankings" Icon="bi bi-bar-chart">
            <Actions>
                @if (_seasons.Count > 0)
                {
                    <SeasonSelector Seasons="_seasons" @bind-Value="_selectedSeasonId" OnChangedCallback="OnScopeChanged" />
                }
            </Actions>
        </PageHeader>

        <Panel Class="mb-4" Flush>
            <Header>
                <i class="bi bi-person"></i>
                <h2 class="panel__title">
                    Player Rankings
                    @if (_selectedSeason != null)
                    {
                        <small class="text-muted fw-normal">
                            @_selectedSeason.Name@(_selectedSeason.IsClosed ? " — final standings" : "") · seasonal ELO
                        </small>
                    }
                </h2>
            </Header>
            <ChildContent>
                @if (_selectedSeason != null)
                {
                    @if (_seasonStandings.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="text-center" style="width: 60px;">Rank</th>
                                        <th>Player</th>
                                        <th class="text-end">ELO</th>
                                        <th class="text-end">Matches</th>
                                        <th class="text-end">W/L</th>
                                        <th class="text-end">Win Rate</th>
                                        <th class="text-end" title="Longest win / loss streak in the season">Streaks</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in _seasonStandings)
                                    {
                                        var isMine = row.PlayerId == MyPlayerId;
                                        <tr class="@(isMine ? "table-success" : "")">
                                            <td class="text-center"><RankBadge Rank="@row.Rank" Large="true" /></td>
                                            <td>
                                                <div class="d-flex flex-wrap align-items-center gap-2">
                                                    <a href="/team/@TeamCode/players/@row.PlayerId" class="text-decoration-none d-flex align-items-center gap-2">
                                                        <Avatar AvatarId="@row.AvatarId" Size="sm" />
                                                        <span>@row.PlayerName</span>
                                                    </a>
                                                    @if (row.PlayerId == _captainPlayerId)
                                                    {
                                                        <CaptainMark />
                                                    }
                                                    @if (isMine)
                                                    {
                                                        <span class="badge badge-you ms-1">you</span>
                                                    }
                                                    @foreach (var badge in StatRegistry.PlayerBadges(_stats, row.PlayerId))
                                                    {
                                                        <span class="badge @badge.CssClass px-1" title="@badge.Tooltip"><i class="@badge.IconClass"></i></span>
                                                    }
                                                </div>
                                            </td>
                                            <td class="text-end fw-bold">@row.Elo</td>
                                            <td class="text-end">@row.Matches</td>
                                            <td class="text-end"><span class="text-success">@row.Wins</span>/<span class="text-danger">@row.Losses</span></td>
                                            <td class="text-end">
                                                <span class="@(row.WinRate >= 50 ? "text-success" : "text-danger")">@row.WinRate.ToString("F1")%</span>
                                            </td>
                                            <td class="text-end small">
                                                <span class="text-success" title="Longest win streak">W@(row.LongestWinStreak)</span>
                                                <span class="text-muted mx-1">·</span>
                                                <span class="text-danger" title="Longest loss streak">L@(row.LongestLossStreak)</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <EmptyState Icon="bi bi-people" Message="No seasonal matches yet." />
                    }
                }
                else if (_rankings.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 60px;">Rank</th>
                                    <th>Player</th>
                                    <th class="text-end">ELO</th>
                                    <th class="text-end">Matches</th>
                                    <th class="text-end">Wins</th>
                                    <th class="text-end">Win Rate</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var player in _rankings)
                                {
                                    var isMine = player.PlayerId == MyPlayerId;
                                    <tr class="@(isMine ? "table-success" : "")">
                                        <td class="text-center">
                                            <RankBadge Rank="@player.Rank" Large="true" />
                                        </td>
                                        <td>
                                            <div class="d-flex flex-wrap align-items-center gap-2">
                                                <a href="/team/@TeamCode/players/@player.PlayerId" class="text-decoration-none d-flex align-items-center gap-2">
                                                    <Avatar AvatarId="@player.AvatarId" Size="sm" />
                                                    <span>@player.PlayerName</span>
                                                </a>
                                                @if (player.PlayerId == _captainPlayerId)
                                                {
                                                    <CaptainMark />
                                                }
                                                @if (isMine)
                                                {
                                                    <span class="badge badge-you ms-1">you</span>
                                                }
                                                @foreach (var badge in StatRegistry.PlayerBadges(_stats, player.PlayerId))
                                                {
                                                    <span class="badge @badge.CssClass px-1" title="@badge.Tooltip"><i class="@badge.IconClass"></i></span>
                                                }
                                            </div>
                                        </td>
                                        <td class="text-end fw-bold">@player.Elo</td>
                                        <td class="text-end">@player.Matches</td>
                                        <td class="text-end text-success">@player.Wins</td>
                                        <td class="text-end">
                                            <span class="@(player.WinRate >= 50 ? "text-success" : "text-danger")">
                                                @player.WinRate.ToString("F1")%
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <EmptyState Icon="bi bi-people" Message="No players yet." />
                }
            </ChildContent>
        </Panel>

        <div class="row">
            <div class="col-lg-6 mb-4">
                <PositionRankingTable Players="_goalkeepers"
                                      Title="Best Goalkeepers"
                                      Icon="bi bi-shield-fill"
                                      HeaderHint="@($"(min {Constants.TimeThresholds.MinGamesForPositionBadge} games as GK)")"
                                      TeamCode="@TeamCode"
                                      MyPlayerId="MyPlayerId"
                                      CaptainPlayerId="_captainPlayerId"
                                      AverageColumnLabel="Avg Conceded"
                                      AverageColumnTooltip="Average goals conceded per game"
                                      AverageColumnClass="text-secondary"
                                      EmptyIcon="bi bi-shield"
                                      EmptyMessage="@($"No goalkeepers with at least {Constants.TimeThresholds.MinGamesForPositionBadge} games yet.")" />
            </div>
            <div class="col-lg-6 mb-4">
                <PositionRankingTable Players="_attackers"
                                      Title="Best Attackers"
                                      Icon="bi bi-bullseye"
                                      HeaderHint="@($"(min {Constants.TimeThresholds.MinGamesForPositionBadge} games as ATK)")"
                                      TeamCode="@TeamCode"
                                      MyPlayerId="MyPlayerId"
                                      CaptainPlayerId="_captainPlayerId"
                                      AverageColumnLabel="Avg Scored"
                                      AverageColumnTooltip="Average goals scored per game"
                                      AverageColumnClass="text-danger"
                                      EmptyIcon="bi bi-bullseye"
                                      EmptyMessage="@($"No attackers with at least {Constants.TimeThresholds.MinGamesForPositionBadge} games yet.")" />
            </div>
        </div>

        <Panel Title="@($"Best Pairs (min {Constants.TimeThresholds.MinGamesForPartnerStats} matches)")" Icon="bi bi-people" Flush>
            <ChildContent>
                @if (_pairRankings.Count > 0)
                {
                    var showAvgScore = _selectedSeason?.IsClosed != true;
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 60px;">Rank</th>
                                    <th>Players</th>
                                    <th class="text-end">Matches</th>
                                    <th class="text-end">W/L</th>
                                    <th class="text-end">Win Rate</th>
                                    @if (showAvgScore)
                                    {
                                        <th class="text-end">Avg Score</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var rank = 1;
                                }
                                @foreach (var pair in _pairRankings)
                                {
                                    var pairContainsMe = MyPlayerId.HasValue && (pair.Player1Id == MyPlayerId || pair.Player2Id == MyPlayerId);
                                    <tr class="@(pairContainsMe ? "table-success" : "")">
                                        <td class="text-center">
                                            <RankBadge Rank="@rank" Large="true" />
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <Avatar AvatarId="@pair.Player1AvatarId" Size="sm" />
                                                <span class="@(pair.Player1Id == MyPlayerId ? "fw-bold" : "")">@pair.Player1Name</span>
                                                @if (pair.Player1Id == _captainPlayerId)
                                                {
                                                    <CaptainMark />
                                                }
                                                <span class="text-muted">&</span>
                                                <Avatar AvatarId="@pair.Player2AvatarId" Size="sm" />
                                                <span class="@(pair.Player2Id == MyPlayerId ? "fw-bold" : "")">@pair.Player2Name</span>
                                                @if (pair.Player2Id == _captainPlayerId)
                                                {
                                                    <CaptainMark />
                                                }
                                            </div>
                                        </td>
                                        <td class="text-end">@pair.Matches</td>
                                        <td class="text-end">
                                            <span class="text-success">@pair.Wins</span>/<span class="text-danger">@pair.Losses</span>
                                        </td>
                                        <td class="text-end">
                                            <span class="@(pair.WinRate >= 50 ? "text-success" : "text-danger") fw-bold">
                                                @pair.WinRate.ToString("F1")%
                                            </span>
                                        </td>
                                        @if (showAvgScore)
                                        {
                                            <td class="text-end">@pair.AverageScore.ToString("F1")</td>
                                        }
                                    </tr>
                                    rank++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <EmptyState Icon="bi bi-people"
                                Message="@($"Not enough matches to rank pairs yet (minimum {Constants.TimeThresholds.MinGamesForPartnerStats} matches per pair).")" />
                }
            </ChildContent>
        </Panel>
    </PageContainer>
}

@code {
    [Parameter] public string TeamCode { get; set; } = string.Empty;

    private Team? _team;
    private bool _loading = true;
    private List<Season> _seasons = [];
    private int? _selectedSeasonId;
    private Season? _selectedSeason;

    private List<PlayerRanking> _rankings = [];
    private List<SeasonStandingRow> _seasonStandings = [];
    private List<PairStats> _pairRankings = [];
    private List<PositionRanking> _goalkeepers = [];
    private List<PositionRanking> _attackers = [];
    private List<StatResult> _stats = [];
    // Player claimed by the team captain, if any — marked with the armband "C".
    private int? _captainPlayerId;
    [CascadingParameter(Name = "MyPlayerId")] public int? MyPlayerId { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _team = await TeamAccess.GetCurrentTeamAsync();
            if (_team != null)
            {
                if (_team.CaptainUserId is int captainUserId)
                {
                    _captainPlayerId = (await PlayerService.GetUserPlayerInTeamAsync(_team.Id, captainUserId))?.Id;
                }

                _seasons = await SeasonService.GetByTeamAsync(_team.Id);
                // Default scope = the current season; all-time when none is active (idle default).
                _selectedSeasonId = _seasons.FirstOrDefault(s => s.IsActiveAt(DateTimeOffset.UtcNow))?.Id;
                await LoadScopeAsync();
            }
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task OnScopeChanged()
    {
        await LoadScopeAsync();
        StateHasChanged();
    }

    private async Task LoadScopeAsync()
    {
        if (_team == null) return;

        _selectedSeason = _selectedSeasonId is int id ? _seasons.FirstOrDefault(s => s.Id == id) : null;

        if (_selectedSeason != null)
        {
            // Season scope: live aggregation for the active season, frozen tables for closed ones.
            _seasonStandings = await StatsService.GetSeasonStandingsAsync(_selectedSeason);
            (_goalkeepers, _attackers) = await StatsService.GetSeasonPositionRankingsAsync(_selectedSeason);
            _pairRankings = await StatsService.GetSeasonPairRankingsAsync(_selectedSeason);

            // Badge chips come from the season-scoped StatContext — computed on the fly even for
            // closed seasons (their matches are immutable, so this is safe).
            var (players, matches, seasonPlayers) = await StatsEngine.LoadSeasonAsync(_team.Id, _selectedSeason.Id);
            _stats = StatsEngine.ComputeSeason(players, seasonPlayers, matches, isFullScope: true);
            _rankings = [];
        }
        else
        {
            _rankings = await StatsService.GetRankingsAsync(_team.Id);
            _pairRankings = await StatsService.GetPairRankingsAsync(_team.Id);
            (_goalkeepers, _attackers) = await StatsService.GetPositionRankingsAsync(_team.Id);
            _stats = await StatsEngine.GetAllTimeAsync(_team.Id);
            _seasonStandings = [];
        }
    }
}
