@page "/login"
@layout MainLayout
@using Fotbalek.Web.Configuration
@using Microsoft.Extensions.Options
@inject IOptions<AdminOptions> AdminOptions

<PageTitle>Login - Foosball Manager</PageTitle>

<AuthCardLayout>
    <div class="panel auth-panel">
        <div class="auth-panel__head">
            <span class="auth-panel__icon"><i class="bi bi-box-arrow-in-right"></i></span>
            <h1 class="auth-panel__title">Sign in</h1>
            <p class="auth-panel__sub">Welcome back — let's play.</p>
        </div>
        <div class="panel__body">
            <AlertMessage Message="@(string.IsNullOrEmpty(Error) ? null : ErrorMessage)" Variant="danger" />

            <form method="post" action="/account/login">
                <AntiforgeryToken />
                @if (!string.IsNullOrEmpty(ReturnUrl))
                {
                    <input type="hidden" name="returnUrl" value="@ReturnUrl" />
                }

                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input id="username" name="username" type="text" class="form-control" value="@Username" autocomplete="username" autocapitalize="none" spellcheck="false" required autofocus />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input id="password" name="password" type="password" class="form-control" autocomplete="current-password" required />
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-success btn-lg">Sign in</button>
                </div>
            </form>

            <div class="auth-foot">
                <p>New here? <a href="@RegisterUrl">Create an account</a></p>
                <p>
                    @if (!string.IsNullOrWhiteSpace(_contactEmail))
                    {
                        <text>Forgot your password? <a href="mailto:@(_contactEmail)?subject=Fotbalek%20password%20reset">Contact the administrator</a> to reset it.</text>
                    }
                    else
                    {
                        <text>Forgot your password? Contact the service administrator.</text>
                    }
                </p>
            </div>
        </div>
    </div>
</AuthCardLayout>

@code {
    // Expose only ContactEmail — never the admin credentials. Rendered to anonymous
    // visitors, so the configured address must be one the admins are happy to expose.
    private string? _contactEmail;

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "username")]
    public string? Username { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string RegisterUrl => string.IsNullOrEmpty(ReturnUrl)
        ? "/register"
        : $"/register?returnUrl={Uri.EscapeDataString(ReturnUrl)}";

    protected override void OnInitialized()
    {
        _contactEmail = AdminOptions.Value.ContactEmail;
    }

    private string ErrorMessage => Error switch
    {
        "1" => "Invalid username or password.",
        "locked" => "Account is temporarily locked due to too many failed attempts. Try again later.",
        _ => "Login failed. Please try again."
    };
}
