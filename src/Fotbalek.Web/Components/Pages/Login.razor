@page "/login"
@layout MainLayout

<PageTitle>Login - Foosball Manager</PageTitle>

<AuthCardLayout>
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="bi bi-box-arrow-in-right me-2"></i>Login</h5>
        </div>
        <div class="card-body p-4">
            <AlertMessage Message="@(string.IsNullOrEmpty(Error) ? null : ErrorMessage)" Variant="danger" />

            <form method="post" action="/account/login">
                <AntiforgeryToken />
                @if (!string.IsNullOrEmpty(ReturnUrl))
                {
                    <input type="hidden" name="returnUrl" value="@ReturnUrl" />
                }

                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input id="username" name="username" type="text" class="form-control" value="@Username" autocomplete="username" autocapitalize="none" spellcheck="false" required autofocus />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input id="password" name="password" type="password" class="form-control" autocomplete="current-password" required />
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success">Sign in</button>
                    <a href="@RegisterUrl" class="btn btn-outline-secondary">Create new account</a>
                </div>
            </form>

            <hr />
            <p class="text-muted small mb-0 text-center">
                Forgot your password? Contact the service administrator.
            </p>
        </div>
    </div>
</AuthCardLayout>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "username")]
    public string? Username { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string RegisterUrl => string.IsNullOrEmpty(ReturnUrl)
        ? "/register"
        : $"/register?returnUrl={Uri.EscapeDataString(ReturnUrl)}";

    private string ErrorMessage => Error switch
    {
        "1" => "Invalid username or password.",
        "locked" => "Account is temporarily locked due to too many failed attempts. Try again later.",
        _ => "Login failed. Please try again."
    };
}
