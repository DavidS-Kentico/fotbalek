@page "/not-found"
@layout MainLayout
@using Microsoft.AspNetCore.Http

<PageTitle>Not Found - Foosball Manager</PageTitle>

<div class="container">
    <div class="row min-vh-100 align-items-center justify-content-center">
        <div class="col-md-6 text-center">
            <i class="bi bi-emoji-frown display-1 text-muted d-block mb-4"></i>
            <h1 class="display-4 text-muted">404</h1>
            <h2 class="mb-4">Page Not Found</h2>
            <p class="lead text-muted mb-4">
                Sorry, the page you're looking for doesn't exist or has been moved.
            </p>
            <a href="/" class="btn btn-success btn-lg">
                <i class="bi bi-house me-2"></i>
                Go Home
            </a>
        </div>
    </div>
</div>

@code {
    // Available during static SSR / prerender. This page is rendered both by the Router's
    // NotFoundPage (an unmatched route, which starts as a 200) and by
    // UseStatusCodePagesWithReExecute (which has already set an error status). Only upgrade a
    // plain 200 so a route-miss becomes a real 404 without clobbering an already-set 4xx/5xx.
    [CascadingParameter] public HttpContext? HttpContext { get; set; }

    protected override void OnInitialized()
    {
        if (HttpContext is { Response.StatusCode: StatusCodes.Status200OK } ctx)
            ctx.Response.StatusCode = StatusCodes.Status404NotFound;
    }
}
