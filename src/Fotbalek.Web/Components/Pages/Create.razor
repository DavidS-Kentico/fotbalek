@page "/create"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IScopedSender Sender
@inject NavigationManager Navigation

<PageTitle>Create Team - Foosball Manager</PageTitle>

<AuthCardLayout>
    <div class="panel auth-panel">
        <div class="auth-panel__head">
            <span class="auth-panel__icon"><i class="bi bi-plus-circle"></i></span>
            <h1 class="auth-panel__title">Create a team</h1>
            <p class="auth-panel__sub">Set up a league for your office or friends.</p>
        </div>
        <div class="panel__body">
            <EditForm Model="@_model" OnValidSubmit="HandleSubmit" FormName="create-team">
                <DataAnnotationsValidator />

                <AlertMessage Message="@_error" Variant="danger" />

                <div class="mb-3">
                    <label for="name" class="form-label">Team name</label>
                    <InputText id="name" @bind-Value="_model.Name" class="form-control" placeholder="e.g., Office League" />
                    <ValidationMessage For="@(() => _model.Name)" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="codeName" class="form-label">Team URL code</label>
                    <div class="input-group">
                        <span class="input-group-text">/</span>
                        <InputText id="codeName" @bind-Value="_model.CodeName" class="form-control" placeholder="e.g., office-league" @oninput="OnCodeNameInput" />
                    </div>
                    <ValidationMessage For="@(() => _model.CodeName)" class="text-danger" />
                    <small class="text-muted">This will be your team's URL. Only lowercase letters, numbers, and hyphens allowed.</small>
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <InputText id="password" @bind-Value="_model.Password" type="password" class="form-control" placeholder="Min 4 characters" />
                    <ValidationMessage For="@(() => _model.Password)" class="text-danger" />
                    <small class="text-muted">Team members will use this password to join.</small>
                </div>

                <div class="mb-3">
                    <label for="confirmPassword" class="form-label">Confirm password</label>
                    <InputText id="confirmPassword" @bind-Value="_model.ConfirmPassword" type="password" class="form-control" />
                    <ValidationMessage For="@(() => _model.ConfirmPassword)" class="text-danger" />
                </div>

                <div class="d-grid gap-2 mt-4">
                    <SpinnerButton Type="submit" Busy="_loading" CssClass="btn-lg">Create team</SpinnerButton>
                    <a href="/" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </EditForm>
        </div>
    </div>
</AuthCardLayout>

@code {
    private CreateTeamModel _model = new();
    private string? _error;
    private bool _loading;

    private void OnCodeNameInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        _model.CodeName = System.Text.RegularExpressions.Regex.Replace(value.ToLowerInvariant(), @"[^a-z0-9\-]", "");
    }

    private async Task HandleSubmit()
    {
        _error = null;
        _loading = true;

        try
        {
            if (string.IsNullOrWhiteSpace(_model.Name))
            {
                _error = "Team name is required.";
                return;
            }

            if (string.IsNullOrWhiteSpace(_model.CodeName))
            {
                _error = "Team URL code is required.";
                return;
            }

            if (_model.CodeName.Length < 3)
            {
                _error = "Team URL code must be at least 3 characters.";
                return;
            }

            if (_model.Password != _model.ConfirmPassword)
            {
                _error = "Passwords do not match.";
                return;
            }

            if (_model.Password.Length < 4)
            {
                _error = "Password must be at least 4 characters.";
                return;
            }

            var result = await Sender.Send(new CreateTeamCommand(_model.Name, _model.CodeName, _model.Password));
            if (result.IsFailure)
            {
                if (result.Error.Type == ErrorType.Unauthorized)
                {
                    Navigation.NavigateTo("/login", forceLoad: true);
                    return;
                }
                _error = result.Error.Message;
                return;
            }

            Navigation.NavigateTo($"/team/{result.Value.CodeName}/claim", forceLoad: true);
        }
        catch (Exception)
        {
            _error = "Something went wrong. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private class CreateTeamModel
    {
        public string Name { get; set; } = string.Empty;
        public string CodeName { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
