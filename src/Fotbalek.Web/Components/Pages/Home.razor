@page "/"
@rendermode InteractiveServer
@inject CurrentUserService CurrentUser
@inject TeamMembershipService MembershipService
@inject LandingStatsService LandingStats
@inject PresenceTracker Presence
@inject IJSRuntime JS

<PageTitle>Foosball Manager</PageTitle>

<div class="container py-4">
    <div class="text-center mb-5">
        <h1 class="display-3 fw-bold text-success">
            <i class="bi bi-trophy-fill me-2"></i>Fotbalek
        </h1>
        <p class="lead text-muted mb-3">
            Track ELO ratings, view statistics, and compete with your colleagues.
        </p>

        @if (!_loading && _onlineCount > 0)
        {
            <p class="mb-4">
                <span class="badge bg-success-subtle text-success border border-success-subtle">
                    <span class="presence-dot-inline"></span>
                    @_onlineCount @(_onlineCount == 1 ? "person" : "people") online right now
                </span>
            </p>
        }

        @if (_loading)
        {
            <LoadingSpinner />
        }
        else if (_isAuthenticated)
        {
            <div class="d-flex flex-wrap gap-2 justify-content-center">
                <a href="/create" class="btn btn-success">
                    <i class="bi bi-plus-circle me-1"></i> Create Team
                </a>
                <a href="/join" class="btn btn-outline-success">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Join Team
                </a>
                <a href="/account" class="btn btn-outline-secondary">
                    <i class="bi bi-person-circle me-1"></i> Account
                </a>
                <form method="post" action="/account/logout" class="m-0">
                    <AntiforgeryToken />
                    <button type="submit" class="btn btn-outline-secondary">
                        <i class="bi bi-box-arrow-right me-1"></i> Sign out
                    </button>
                </form>
            </div>
        }
        else
        {
            <div class="d-flex flex-wrap gap-2 justify-content-center">
                <a href="/login?returnUrl=%2Fcreate" class="btn btn-success">
                    <i class="bi bi-plus-circle me-1"></i> Create Team
                </a>
                <a href="/login?returnUrl=%2Fjoin" class="btn btn-outline-success">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Join Team
                </a>
                <a href="/login" class="btn btn-outline-secondary">
                    <i class="bi bi-person me-1"></i> Sign in
                </a>
            </div>
            <p class="text-muted small mt-3 mb-0">
                Need an account? <a href="/register">Register here</a>.
            </p>
        }
    </div>

    @if (!_loading && _myTeams.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-people-fill me-2"></i>Your Teams</h5>
            </div>
            <div class="list-group list-group-flush">
                @foreach (var team in _myTeams)
                {
                    <a href="/team/@team.CodeName" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-shield-fill text-success me-2"></i>@team.Name</span>
                        <small class="text-muted">@@@team.CodeName</small>
                    </a>
                }
            </div>
        </div>
    }

    @* "How it works" — only for visitors without a team yet (anonymous or new users). *@
    @if (!_loading && _myTeams.Count == 0)
    {
    <div class="row text-center mb-5 g-3">
        <div class="col-md-4">
            <div class="p-3 h-100">
                <div class="display-6 text-success mb-2"><i class="bi bi-1-circle-fill"></i></div>
                <h5>Create or join a team</h5>
                <p class="text-muted small mb-0">
                    Set up a team for your office or join an existing one with a code and password.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 h-100">
                <div class="display-6 text-success mb-2"><i class="bi bi-2-circle-fill"></i></div>
                <h5>Add players, record matches</h5>
                <p class="text-muted small mb-0">
                    Claim your player, then log 2v2 matches with positions and final score.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 h-100">
                <div class="display-6 text-success mb-2"><i class="bi bi-3-circle-fill"></i></div>
                <h5>Watch the stats unfold</h5>
                <p class="text-muted small mb-0">
                    ELO ratings, rankings, rivalries, streaks and badges — all updated automatically.
                </p>
            </div>
        </div>
    </div>
    }

    @if (!_loading && _stats != null)
    {
        @if (_stats.Totals.Matches == 0)
        {
            <div class="card text-center mb-4">
                <div class="card-body py-5">
                    <i class="bi bi-controller display-1 text-muted mb-3 d-block"></i>
                    <h4>No matches played yet</h4>
                    <p class="text-muted mb-4">Be the first to start a team and get the ball rolling.</p>
                    @if (_isAuthenticated)
                    {
                        <a href="/create" class="btn btn-success">
                            <i class="bi bi-plus-circle me-1"></i> Create the first team
                        </a>
                    }
                    else
                    {
                        <a href="/login?returnUrl=%2Fcreate" class="btn btn-success">
                            <i class="bi bi-plus-circle me-1"></i> Create the first team
                        </a>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="row mb-4">
                <div class="col-6 col-md-3 mb-3">
                    <StatTile Variant="success" Icon="bi bi-shield-fill" Value="@_stats.Totals.Teams.ToString()" Label="Teams" />
                </div>
                <div class="col-6 col-md-3 mb-3">
                    <StatTile Variant="primary" Icon="bi bi-people-fill" Value="@_stats.Totals.Players.ToString()" Label="Active Players" />
                </div>
                <div class="col-6 col-md-3 mb-3">
                    <StatTile Variant="info" Icon="bi bi-controller" Value="@_stats.Totals.Matches.ToString()" Label="Total Matches" />
                </div>
                <div class="col-6 col-md-3 mb-3">
                    <StatTile Variant="warning" Icon="bi bi-bullseye" Value="@_stats.Totals.TotalGoals.ToString()" Label="Goals Scored" />
                </div>
            </div>

            <div class="row">
                <div class="col-lg-8 mb-4">
                    <ChartCard
                        CanvasId="landingActivityChart"
                        Title="Activity — last 30 days"
                        Icon="bi bi-graph-up"
                        Subtitle="Matches recorded per day across all teams"
                        Height="220"
                        HasData="_stats.Activity.Any(a => a.Matches > 0)" />
                </div>
                <div class="col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="bi bi-stars me-2"></i>Fun facts</h6>
                        </div>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-calendar-day me-2 text-success"></i>Matches today</span>
                                <span class="fw-bold">@_stats.FunFacts.MatchesToday</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-bullseye me-2 text-info"></i>Avg goals / match</span>
                                <span class="fw-bold">@_stats.FunFacts.AverageGoalsPerMatch.ToString("F1")</span>
                            </li>
                            @if (!string.IsNullOrEmpty(_stats.FunFacts.BiggestBlowout))
                            {
                                <li class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span><i class="bi bi-fire me-2 text-warning"></i>Biggest blowout this week</span>
                                        <span class="fw-bold">@_stats.FunFacts.BiggestBlowout</span>
                                    </div>
                                    <small class="text-muted">in @_stats.FunFacts.BiggestBlowoutTeam</small>
                                </li>
                            }
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-fire me-2 text-danger"></i>Matches this week</span>
                                <span class="fw-bold">@_stats.Totals.MatchesThisWeek</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-6 mb-4">
                    <div class="card h-100">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Most Active Teams</h5>
                        </div>
                        <div class="card-body p-0">
                            @if (_stats.TopTeams.Count > 0)
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="text-center" style="width: 50px;">#</th>
                                                <th>Team</th>
                                                <th class="text-end">Players</th>
                                                <th class="text-end">Matches</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (var i = 0; i < _stats.TopTeams.Count; i++)
                                            {
                                                var team = _stats.TopTeams[i];
                                                var rank = i + 1;
                                                <tr>
                                                    <td class="text-center">
                                                        <RankBadge Rank="rank" />
                                                    </td>
                                                    <td>
                                                        <span class="fw-semibold">@team.Name</span>
                                                        <small class="text-muted ms-1">@@@team.CodeName</small>
                                                    </td>
                                                    <td class="text-end text-muted">@team.PlayerCount</td>
                                                    <td class="text-end fw-bold">@team.MatchCount</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <EmptyState Icon="bi bi-shield" Message="No active teams yet. Be the first!" />
                            }
                        </div>
                    </div>
                </div>

                <div class="col-lg-6 mb-4">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="bi bi-fire me-2"></i>Hottest This Week</h5>
                            <span class="badge bg-warning text-dark">@_stats.Totals.MatchesThisWeek matches</span>
                        </div>
                        <div class="card-body p-0">
                            @if (_stats.HottestTeams.Count > 0)
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="text-center" style="width: 50px;">#</th>
                                                <th>Team</th>
                                                <th class="text-end">Players</th>
                                                <th class="text-end">Matches</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (var i = 0; i < _stats.HottestTeams.Count; i++)
                                            {
                                                var team = _stats.HottestTeams[i];
                                                var rank = i + 1;
                                                <tr>
                                                    <td class="text-center">
                                                        <RankBadge Rank="rank" />
                                                    </td>
                                                    <td>
                                                        <span class="fw-semibold">@team.Name</span>
                                                        <small class="text-muted ms-1">@@@team.CodeName</small>
                                                    </td>
                                                    <td class="text-end text-muted">@team.PlayerCount</td>
                                                    <td class="text-end fw-bold">@team.MatchCount</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <EmptyState Icon="bi bi-calendar-x" Message="No matches played this week yet." />
                            }
                        </div>
                    </div>
                </div>
            </div>

            @if (_stats.RecentMatches.Count > 0)
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Recent Activity</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Team</th>
                                        <th class="text-center">Score</th>
                                        <th class="text-end">When</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var match in _stats.RecentMatches)
                                    {
                                        <tr>
                                            <td>
                                                <i class="bi bi-shield-fill text-success me-2"></i>
                                                <span class="fw-semibold">@match.TeamName</span>
                                                <small class="text-muted ms-1">@@@match.TeamCodeName</small>
                                            </td>
                                            <td class="text-center fw-bold">
                                                @match.Team1Score – @match.Team2Score
                                            </td>
                                            <td class="text-end text-muted small">
                                                @FormatRelative(match.PlayedAt)
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
    }
</div>

@code {
    private bool _loading = true;
    private bool _isAuthenticated;
    private List<Fotbalek.Web.Data.Entities.Team> _myTeams = [];
    private LandingStats? _stats;
    private int _onlineCount;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _stats = await LandingStats.GetAsync();
        _onlineCount = Presence.OnlineCount;

        var userId = await CurrentUser.GetUserIdAsync();
        if (userId != null)
        {
            _isAuthenticated = true;
            _myTeams = await MembershipService.GetTeamsForUserAsync(userId.Value);
        }

        _loading = false;
        StateHasChanged();

        // Render chart after the canvas is in the DOM.
        if (_stats != null && _stats.Activity.Any(a => a.Matches > 0))
        {
            var labels = _stats.Activity.Select(a => a.Day.ToString("MM-dd")).ToArray();
            var data = _stats.Activity.Select(a => a.Matches).ToArray();
            await JS.InvokeVoidAsync("renderBarChart", "landingActivityChart", labels, data, "Matches", "#198754");
        }
    }

    private static string FormatRelative(DateTimeOffset when)
    {
        var diff = DateTimeOffset.UtcNow - when;
        if (diff.TotalSeconds < 60) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} min ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return when.ToLocalTime().ToString("MMM d");
    }
}

<style>
    .presence-dot-inline {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: #198754;
        margin-right: 6px;
        animation: presence-pulse 2s ease-in-out infinite;
        vertical-align: middle;
    }

    @@keyframes presence-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }
</style>
