@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject CurrentUserService CurrentUser
@inject TeamMembershipService MembershipService
@inject LandingStatsService LandingStats
@inject PresenceTracker Presence
@inject ChatUiState ChatUi
@inject IJSRuntime JS

<PageTitle>Foosball Manager</PageTitle>

@* ===== Hero ===== *@
<section class="ov-hero">
    <div class="ov-hero__inner container">
        <h1 class="ov-hero__brand">
            <i class="bi bi-trophy-fill"></i><span>Fotbalek</span>
        </h1>
        <p class="ov-hero__tagline">
            Track ELO ratings, follow the stats and settle the office foosball rivalry — one match at a time.
        </p>

        @if (!_loading && _onlineCount > 0)
        {
            <div class="ov-hero__online">
                <span class="ov-live-dot"></span>
                @_onlineCount @(_onlineCount == 1 ? "person" : "people") online right now
            </div>
        }

        <div class="ov-hero__cta">
            @if (_loading)
            {
                <div class="spinner-border text-light" role="status">
                    <span class="visually-hidden">Loading…</span>
                </div>
            }
            else if (_isAuthenticated)
            {
                <a href="/create" class="btn btn-lg ov-btn-light">
                    <i class="bi bi-plus-circle me-1"></i> Create Team
                </a>
                <a href="/join" class="btn btn-lg ov-btn-ghost">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Join Team
                </a>
                <a href="/account" class="btn btn-lg ov-btn-ghost">
                    <i class="bi bi-person-circle me-1"></i> Account
                </a>
            }
            else
            {
                <a href="/login?returnUrl=%2Fcreate" class="btn btn-lg ov-btn-light">
                    <i class="bi bi-plus-circle me-1"></i> Create Team
                </a>
                <a href="/login?returnUrl=%2Fjoin" class="btn btn-lg ov-btn-ghost">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Join Team
                </a>
                <a href="/login" class="btn btn-lg ov-btn-ghost">
                    <i class="bi bi-person me-1"></i> Sign in
                </a>
            }
        </div>

        @if (!_loading && _isAuthenticated)
        {
            <form method="post" action="/account/logout" class="ov-hero__signout">
                <AntiforgeryToken />
                <span>You're signed in</span>
                <span class="ov-sep">·</span>
                <button type="submit">Sign out</button>
            </form>
        }
        else if (!_loading)
        {
            <p class="ov-hero__subnote">
                Need an account? <a href="/register">Register here</a>.
            </p>
        }
    </div>
</section>

<div class="container ov-body py-4 py-lg-5">

    @* ── Your teams (signed in, has teams) ── *@
    @if (!_loading && _myTeams.Count > 0)
    {
        <section class="mb-5">
            <div class="ov-section-head">
                <h2 class="ov-section-title"><i class="bi bi-people-fill me-2"></i>Your teams</h2>
                <a href="/create" class="btn btn-sm btn-outline-success">
                    <i class="bi bi-plus-lg me-1"></i>New team
                </a>
            </div>
            <div class="ov-teams">
                @foreach (var team in _myTeams)
                {
                    var chatUnread = ChatUi.GetUnread(team.Id);
                    <a href="/team/@team.CodeName" class="ov-team-card">
                        <span class="ov-team-crest"><i class="bi bi-shield-fill"></i></span>
                        <span class="ov-team-main">
                            <span class="ov-team-name">@team.Name</span>
                            <span class="ov-team-code">@@@team.CodeName</span>
                        </span>
                        @if (chatUnread > 0)
                        {
                            <span class="badge rounded-pill text-bg-danger" title="Unread chat messages">
                                <i class="bi bi-chat-dots me-1"></i>@(chatUnread > 99 ? "99+" : chatUnread.ToString())
                            </span>
                        }
                        <i class="bi bi-chevron-right ov-team-chevron"></i>
                    </a>
                }
            </div>
        </section>
    }

    @* ── How it works (no teams yet) ── *@
    @if (!_loading && _myTeams.Count == 0)
    {
        <section class="mb-5">
            <div class="ov-section-head ov-section-head--center">
                <h2 class="ov-section-title">How it works</h2>
                <p class="ov-section-sub">From zero to leaderboard in three steps.</p>
            </div>
            <div class="ov-steps">
                <div class="ov-step">
                    <span class="ov-step__num">1</span>
                    <h3>Create or join a team</h3>
                    <p>Set up a team for your office or join an existing one with a code and password.</p>
                </div>
                <div class="ov-step">
                    <span class="ov-step__num">2</span>
                    <h3>Add players, record matches</h3>
                    <p>Claim your player, then log 2v2 matches with positions and the final score.</p>
                </div>
                <div class="ov-step">
                    <span class="ov-step__num">3</span>
                    <h3>Watch the stats unfold</h3>
                    <p>ELO ratings, rankings, rivalries, streaks and badges — all updated automatically.</p>
                </div>
            </div>
        </section>
    }

    @* ── Community stats (aggregate only — no individual team data) ── *@
    @if (!_loading && _stats != null)
    {
        @if (_stats.Totals.Matches == 0)
        {
            <section class="ov-empty">
                <i class="bi bi-controller"></i>
                <h3>No matches played yet</h3>
                <p>Be the first to start a team and get the ball rolling.</p>
                <a href="@(_isAuthenticated ? "/create" : "/login?returnUrl=%2Fcreate")" class="btn btn-success btn-lg">
                    <i class="bi bi-plus-circle me-1"></i> Create the first team
                </a>
            </section>
        }
        else
        {
            <section class="mb-4">
                <div class="ov-section-head">
                    <h2 class="ov-section-title"><i class="bi bi-globe2 me-2"></i>Across all teams</h2>
                </div>
                <div class="ov-stats">
                    <StatTile Variant="success" Icon="bi bi-shield-fill" Value="@_stats.Totals.Teams.ToString()" Label="Teams" />
                    <StatTile Variant="primary" Icon="bi bi-people-fill" Value="@_stats.Totals.Players.ToString()" Label="Active players" />
                    <StatTile Variant="info" Icon="bi bi-controller" Value="@_stats.Totals.Matches.ToString()" Label="Matches" />
                    <StatTile Variant="warning" Icon="bi bi-bullseye" Value="@_stats.Totals.TotalGoals.ToString()" Label="Goals scored" />
                </div>
            </section>

            <div class="row g-4">
                <div class="col-lg-8">
                    <Panel Class="h-100">
                        <Header>
                            <i class="bi bi-activity"></i>
                            <div>
                                <h2 class="panel__title">Activity</h2>
                                <div class="text-muted small">Matches recorded per day · last 30 days</div>
                            </div>
                        </Header>
                        <ChildContent>
                            @if (_stats.Activity.Any(a => a.Matches > 0))
                            {
                                @* Fixed-height wrapper: Chart.js runs responsive + maintainAspectRatio:false,
                                   which grows unbounded if the canvas's container has no definite height. *@
                                <div class="ov-chart">
                                    <canvas id="landingActivityChart"></canvas>
                                </div>
                            }
                            else
                            {
                                <EmptyState Icon="bi bi-graph-up" Message="No activity in the last 30 days." />
                            }
                        </ChildContent>
                    </Panel>
                </div>

                <div class="col-lg-4">
                    <Panel Class="h-100" Title="Highlights" Icon="bi bi-stars">
                            <ul class="ov-facts">
                                <li>
                                    <span class="ov-fact__ico text-success"><i class="bi bi-calendar-day"></i></span>
                                    <span class="ov-fact__label">Matches today</span>
                                    <span class="ov-fact__value">@_stats.FunFacts.MatchesToday</span>
                                </li>
                                <li>
                                    <span class="ov-fact__ico text-danger"><i class="bi bi-fire"></i></span>
                                    <span class="ov-fact__label">Matches this week</span>
                                    <span class="ov-fact__value">@_stats.Totals.MatchesThisWeek</span>
                                </li>
                                <li>
                                    <span class="ov-fact__ico text-info"><i class="bi bi-bullseye"></i></span>
                                    <span class="ov-fact__label">Avg goals / match</span>
                                    <span class="ov-fact__value">@_stats.FunFacts.AverageGoalsPerMatch.ToString("F1")</span>
                                </li>
                                @if (!string.IsNullOrEmpty(_stats.FunFacts.BiggestBlowout))
                                {
                                    <li>
                                        <span class="ov-fact__ico text-warning"><i class="bi bi-lightning-charge-fill"></i></span>
                                        <span class="ov-fact__label">Biggest win this week</span>
                                        <span class="ov-fact__value">@_stats.FunFacts.BiggestBlowout</span>
                                    </li>
                                }
                                @if (_busiestDay is { Matches: > 0 } bd)
                                {
                                    <li>
                                        <span class="ov-fact__ico text-primary"><i class="bi bi-calendar-week"></i></span>
                                        <span class="ov-fact__label">Busiest day</span>
                                        <span class="ov-fact__value">
                                            @bd.Matches<small class="text-muted ms-1">· @bd.Day.ToString("MMM d")</small>
                                        </span>
                                    </li>
                                }
                            </ul>
                    </Panel>
                </div>
            </div>

            @* ── Latest results — anonymized pulse ── *@
            @if (_stats.RecentScores.Count > 0)
            {
                <Panel Class="mt-4">
                    <Header>
                        <i class="bi bi-broadcast"></i>
                        <div>
                            <h2 class="panel__title">Latest results</h2>
                            <div class="text-muted small">Live scores from across the community — teams kept private.</div>
                        </div>
                    </Header>
                    <ChildContent>
                        <div class="ov-pulse">
                            @foreach (var s in _stats.RecentScores)
                            {
                                <div class="ov-result" title="@FormatRelative(s.PlayedAt)">
                                    <span class="ov-result__score">
                                        @s.Team1Score<span class="ov-result__dash">–</span>@s.Team2Score
                                    </span>
                                    <span class="ov-result__time">@FormatRelative(s.PlayedAt)</span>
                                </div>
                            }
                        </div>
                    </ChildContent>
                </Panel>
            }
        }
    }
</div>

@code {
    private bool _loading = true;
    private bool _isAuthenticated;
    private List<Fotbalek.Web.Data.Entities.Team> _myTeams = [];
    private LandingStats? _stats;
    private int _onlineCount;
    private LandingActivityPoint? _busiestDay;
    private bool _chatSubscribed;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _stats = await LandingStats.GetAsync();
        _onlineCount = Presence.OnlineCount;
        _busiestDay = _stats.Activity.Count > 0
            ? _stats.Activity.OrderByDescending(a => a.Matches).First()
            : null;

        var userId = await CurrentUser.GetUserIdAsync();
        if (userId != null)
        {
            _isAuthenticated = true;
            _myTeams = await MembershipService.GetTeamsForUserAsync(userId.Value);
            // Per-team chat badges render from ChatUiState's cache, which the dock (also on
            // this page) keeps current.
            ChatUi.Changed += OnChatUnreadChanged;
            _chatSubscribed = true;
        }

        _loading = false;
        StateHasChanged();

        // Render chart after the canvas is in the DOM.
        if (_stats.Activity.Any(a => a.Matches > 0))
        {
            var labels = _stats.Activity.Select(a => a.Day.ToString("MM-dd")).ToArray();
            var data = _stats.Activity.Select(a => a.Matches).ToArray();
            await JS.InvokeVoidAsync("renderLineChart", "landingActivityChart", labels, data, "Matches", "#198754");
        }
    }

    private async void OnChatUnreadChanged()
    {
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException) { }
    }

    public void Dispose()
    {
        if (_chatSubscribed)
        {
            ChatUi.Changed -= OnChatUnreadChanged;
            _chatSubscribed = false;
        }
    }

    private static string FormatRelative(DateTimeOffset when)
    {
        var diff = DateTimeOffset.UtcNow - when;
        if (diff.TotalSeconds < 60) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} min ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return when.ToLocalTime().ToString("MMM d");
    }
}
