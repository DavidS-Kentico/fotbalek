@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@inject CurrentUserService CurrentUser
@inject TeamMembershipService MembershipService
@inject NavigationManager Navigation

<PageTitle>Foosball Manager</PageTitle>

@if (_loading)
{
    <LoadingSpinner FullScreen="true" />
}
else
{
    <AuthCardLayout LargeTitle="true" Subtitle="Manage your foosball tournaments with ease">
        <div class="card shadow">
            <div class="card-body p-4">
                <div class="d-grid gap-3">
                    <a href="/create" class="btn btn-success btn-lg">
                        <i class="bi bi-plus-circle me-2"></i>
                        Create New Team
                    </a>
                    <a href="/join" class="btn btn-outline-success btn-lg">
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        Join Existing Team
                    </a>
                </div>
            </div>
        </div>

        <div class="text-center mt-4 d-flex flex-column gap-2">
            <small class="text-muted">
                Track ELO ratings, view statistics, and compete with your colleagues!
            </small>
            <form method="post" action="/account/logout" class="m-0">
                <AntiforgeryToken />
                <button type="submit" class="btn btn-link btn-sm text-muted">
                    <i class="bi bi-box-arrow-right me-1"></i> Sign out
                </button>
            </form>
        </div>
    </AuthCardLayout>
}

@code {
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var userId = await CurrentUser.GetUserIdAsync();
        if (userId == null) return;

        var teams = await MembershipService.GetTeamsForUserAsync(userId.Value);
        if (teams.Count > 0)
        {
            Navigation.NavigateTo($"/{teams[0].CodeName}", forceLoad: true);
            return;
        }

        _loading = false;
        StateHasChanged();
    }
}
