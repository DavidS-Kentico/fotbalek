@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@inject CurrentUserService CurrentUser
@inject TeamMembershipService MembershipService
@inject NavigationManager Navigation

<PageTitle>Foosball Manager</PageTitle>

@if (_loading)
{
    <div class="d-flex justify-content-center align-items-center min-vh-100">
        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="container">
        <div class="row min-vh-100 align-items-center justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="text-center mb-5">
                    <h1 class="display-4 fw-bold text-success">
                        <i class="bi bi-trophy-fill me-2"></i>
                        Fotbalek
                    </h1>
                    <p class="lead text-muted">Manage your foosball tournaments with ease</p>
                </div>

                <div class="card shadow">
                    <div class="card-body p-4">
                        <div class="d-grid gap-3">
                            <a href="/create" class="btn btn-success btn-lg">
                                <i class="bi bi-plus-circle me-2"></i>
                                Create New Team
                            </a>
                            <a href="/join" class="btn btn-outline-success btn-lg">
                                <i class="bi bi-box-arrow-in-right me-2"></i>
                                Join Existing Team
                            </a>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-4 d-flex flex-column gap-2">
                    <small class="text-muted">
                        Track ELO ratings, view statistics, and compete with your colleagues!
                    </small>
                    <form method="post" action="/account/logout" class="m-0">
                        <AntiforgeryToken />
                        <button type="submit" class="btn btn-link btn-sm text-muted">
                            <i class="bi bi-box-arrow-right me-1"></i> Sign out
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var userId = await CurrentUser.GetUserIdAsync();
        if (userId == null) return;

        var teams = await MembershipService.GetTeamsForUserAsync(userId.Value);
        if (teams.Count > 0)
        {
            Navigation.NavigateTo($"/{teams[0].CodeName}", forceLoad: true);
            return;
        }

        // No teams — show the create/join landing
        _loading = false;
        StateHasChanged();
    }
}
