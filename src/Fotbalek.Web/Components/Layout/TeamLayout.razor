@implements IDisposable
@inherits LayoutComponentBase
@inject TeamAccessService TeamAccess
@inject TeamService TeamService
@inject TeamMembershipService MembershipService
@inject PlayerService PlayerService
@inject CurrentUserService CurrentUser
@inject ShareTokenService ShareTokenService
@inject PresenceTracker Presence
@inject GameRoomManager GameRooms
@inject NavigationManager Navigation
@inject TimeZoneService Tz
@inject IJSRuntime JS

<div class="min-vh-100 d-flex flex-column">
    @if (_team != null && _user != null)
    {
        <header class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center text-success fw-bold" href="/team/@_team.CodeName">
                    <i class="bi bi-trophy-fill me-2"></i>
                    @_team.Name
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <NavLink class="nav-link" href="@($"/team/{_team.CodeName}")" Match="NavLinkMatch.All">
                                <i class="bi bi-house me-1"></i> Dashboard
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="@($"/team/{_team.CodeName}/rankings")">
                                <i class="bi bi-bar-chart me-1"></i> Rankings
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="@($"/team/{_team.CodeName}/stats")">
                                <i class="bi bi-graph-up me-1"></i> Stats
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="@($"/team/{_team.CodeName}/matches")">
                                <i class="bi bi-list-ul me-1"></i> History
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="@($"/team/{_team.CodeName}/players")">
                                <i class="bi bi-people me-1"></i> Players
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="@($"/team/{_team.CodeName}/seasons")">
                                <i class="bi bi-award me-1"></i> Seasons
                            </NavLink>
                        </li>
                    </ul>

                    <div class="d-flex gap-2 align-items-center">
                        @{
                            var onlinePlayers = GetOnlinePlayers();
                        }
                        @if (onlinePlayers.Count > 0)
                        {
                            <div class="presence-stack d-flex align-items-center me-2" title="@($"{onlinePlayers.Count} online")">
                                @foreach (var p in onlinePlayers.Take(5))
                                {
                                    <a href="/team/@_team.CodeName/players/@p.Id" class="presence-avatar">
                                        <Avatar AvatarId="@p.AvatarId" Size="sm" Title="@p.Name" />
                                        <span class="presence-dot"></span>
                                    </a>
                                }
                                @if (onlinePlayers.Count > 5)
                                {
                                    <span class="presence-more">+@(onlinePlayers.Count - 5)</span>
                                }
                            </div>
                        }
                        @if (GameRooms.GetForTeam(_team.Id) is { } liveRoom)
                        {
                            var seated = liveRoom.GetState().Seats.Count(s => s.Occupied);
                            <a href="/team/@_team.CodeName/game" class="btn btn-outline-danger d-flex align-items-center gap-2"
                               title="@(seated < 4 ? "Live game — join or watch" : "Live game — watch")">
                                <span class="live-dot"></span> @seated/4 · @(seated < 4 ? "Join" : "Watch")
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary" title="Start live game" @onclick="StartLiveGame">
                                🎮
                            </button>
                        }
                        <a href="@($"/team/{_team.CodeName}/match/new")" class="btn btn-success">
                            <i class="bi bi-plus-lg me-1"></i> New Match
                        </a>
                        <button class="btn btn-outline-secondary" @onclick="ShowShareModal" title="Share Team URL">
                            <i class="bi bi-share"></i>
                        </button>

                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown">
                                @if (_myPlayer != null)
                                {
                                    <Avatar AvatarId="@_myPlayer.AvatarId" Size="sm" />
                                }
                                else
                                {
                                    <i class="bi bi-person-circle"></i>
                                }
                                <span>@DisplayName</span>
                                @if (_isCaptain)
                                {
                                    <span class="badge bg-warning text-dark">Captain</span>
                                }
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (_myPlayer != null)
                                {
                                    <li>
                                        <a class="dropdown-item" href="/team/@_team.CodeName/players/@_myPlayer.Id">
                                            <i class="bi bi-person-badge me-2"></i>My player
                                        </a>
                                    </li>
                                }
                                @if (_isCaptain)
                                {
                                    <li>
                                        <a class="dropdown-item" href="/team/@_team.CodeName/settings">
                                            <i class="bi bi-gear me-2"></i>Team settings
                                        </a>
                                    </li>
                                }
                                @if (_myPlayer != null || _isCaptain)
                                {
                                    <li><hr class="dropdown-divider" /></li>
                                }
                                <li>
                                    <a class="dropdown-item" href="/">
                                        <i class="bi bi-house-door me-2"></i>Overview
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/account">
                                        <i class="bi bi-person-circle me-2"></i>My account
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><h6 class="dropdown-header">Switch team</h6></li>
                                @foreach (var team in _userTeams)
                                {
                                    <li>
                                        <button type="button" class="dropdown-item @(team.Id == _team.Id ? "active" : "")" @onclick="() => SwitchTeam(team.CodeName)">
                                            <i class="bi bi-trophy me-2"></i>@team.Name
                                        </button>
                                    </li>
                                }
                                <li><a class="dropdown-item" href="/create"><i class="bi bi-plus-circle me-2"></i>Create team</a></li>
                                <li><a class="dropdown-item" href="/join"><i class="bi bi-box-arrow-in-right me-2"></i>Join team</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li class="px-3 py-1 small text-muted">@(_user?.UserName)</li>
                                <li>
                                    <form method="post" action="/account/logout" class="m-0">
                                        <AntiforgeryToken />
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right me-2"></i>Sign out
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        @if (_team.CaptainUserId == null)
        {
            <div class="alert alert-warning rounded-0 mb-0">
                <div class="container d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-exclamation-triangle me-2"></i>This team has no captain yet.</span>
                    <button class="btn btn-sm btn-warning" @onclick="ClaimCaptain" disabled="@_claimingCaptain">
                        @if (_claimingCaptain)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Become captain
                    </button>
                </div>
            </div>
        }

        <main class="flex-grow-1 bg-light">
            <CascadingValue Value="_myPlayer?.Id" Name="MyPlayerId">
                @Body
            </CascadingValue>
        </main>

        <AppFooter />

        <Modal Show="_showShareModal" Title="Share Team" Icon="bi bi-share" OnClose="() => _showShareModal = false">
            <Body>
                <p class="text-muted">Share this link with your teammates so they can join without entering a password:</p>
                @if (_generatingToken)
                {
                    <div class="text-center py-3">
                        <div class="spinner-border spinner-border-sm text-success" role="status">
                            <span class="visually-hidden">Generating link...</span>
                        </div>
                    </div>
                }
                else if (!string.IsNullOrEmpty(_shareToken))
                {
                    <div class="input-group">
                        <input type="text" class="form-control" readonly value="@GetShareUrl()" />
                        <button class="btn btn-success" @onclick="CopyShareUrl">
                            <i class="bi @(_copied ? "bi-check" : "bi-clipboard")"></i>
                            @(_copied ? "Copied!" : "Copy")
                        </button>
                    </div>
                    @if (_copied)
                    {
                        <small class="text-success mt-2 d-block">Link copied to clipboard!</small>
                    }
                    <small class="text-muted mt-2 d-block">
                        <i class="bi bi-clock me-1"></i>This link expires in 24 hours.
                    </small>
                }
                <hr />
                <p class="text-muted mb-2 small">Or share the team URL (requires password + login):</p>
                <div class="input-group input-group-sm">
                    <input type="text" class="form-control" readonly value="@GetTeamUrl()" />
                    <button class="btn btn-outline-secondary" @onclick="CopyTeamUrl">
                        <i class="bi @(_copiedBasic ? "bi-check" : "bi-clipboard")"></i>
                    </button>
                </div>
            </Body>
            <Footer>
                <button type="button" class="btn btn-secondary" @onclick="() => _showShareModal = false">Close</button>
            </Footer>
        </Modal>
    }
    else if (_loading)
    {
        <LoadingSpinner FullScreen="true" />
    }
</div>

<div id="blazor-error-ui" data-nosnippet class="alert alert-danger position-fixed bottom-0 start-50 translate-middle-x mb-3" style="display: none;">
    An unhandled error has occurred.
    <a href="." class="alert-link">Reload</a>
    <button type="button" class="btn-close" onclick="this.parentElement.style.display='none'"></button>
</div>

@code {
    private Team? _team;
    private AppUser? _user;
    private Player? _myPlayer;
    private bool _loading = true;
    private bool _isCaptain;
    private bool _claimingCaptain;
    private bool _showShareModal;
    private bool _copied;
    private bool _copiedBasic;
    private bool _generatingToken;
    private string? _shareToken;
    private List<Team> _userTeams = new();
    private List<Player> _teamPlayersWithUser = new();
    private bool _presenceSubscribed;

    private string DisplayName => _myPlayer?.Name ?? _user?.UserName ?? "User";

    private List<Player> GetOnlinePlayers()
    {
        if (_teamPlayersWithUser.Count == 0) return new();
        return _teamPlayersWithUser
            .Where(p => p.UserId.HasValue && Presence.IsOnline(p.UserId.Value))
            .OrderBy(p => p.Name)
            .ToList();
    }

    private async void OnPresenceChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (_presenceSubscribed)
        {
            Presence.Changed -= OnPresenceChanged;
            GameRooms.Changed -= OnPresenceChanged;
            _presenceSubscribed = false;
        }
    }

    private string GetTeamUrl()
    {
        var baseUrl = Navigation.BaseUri.TrimEnd('/');
        return $"{baseUrl}/team/{_team?.CodeName}";
    }

    private string GetShareUrl()
    {
        var baseUrl = Navigation.BaseUri.TrimEnd('/');
        return $"{baseUrl}/join?team={_team?.CodeName}&token={_shareToken}";
    }

    private async Task ShowShareModal()
    {
        _copied = false;
        _copiedBasic = false;
        _shareToken = null;
        _showShareModal = true;
        _generatingToken = true;
        StateHasChanged();

        try
        {
            if (_team != null && _user != null)
            {
                _shareToken = await ShareTokenService.GenerateTokenAsync(_team.Id, _user.Id);
            }
        }
        catch
        {
        }
        finally
        {
            _generatingToken = false;
            StateHasChanged();
        }
    }

    private async Task CopyShareUrl()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", GetShareUrl());
            _copied = true;
            _copiedBasic = false;
            StateHasChanged();
        }
        catch { }
    }

    private async Task CopyTeamUrl()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", GetTeamUrl());
            _copiedBasic = true;
            _copied = false;
            StateHasChanged();
        }
        catch { }
    }

    private void SwitchTeam(string codeName)
    {
        Navigation.NavigateTo($"/team/{codeName}", forceLoad: true);
    }

    private void StartLiveGame()
    {
        if (_team == null || _user == null) return;
        var room = GameRooms.GetOrCreateForTeam(_team.Id);
        // The seat sits in the not-yet-connected grace state until the game page's JS client
        // joins the room (§3.2).
        room.TryTakeFirstFreeSeat(_user.Id, DisplayName, _myPlayer?.AvatarId ?? 1);
        Navigation.NavigateTo($"/team/{_team.CodeName}/game");
    }

    private async Task ClaimCaptain()
    {
        if (_team == null || _user == null) return;
        _claimingCaptain = true;
        try
        {
            var success = await TeamService.TryClaimCaptainAsync(_team.Id, _user.Id);
            if (success)
            {
                _team.CaptainUserId = _user.Id;
                _isCaptain = true;
            }
        }
        finally
        {
            _claimingCaptain = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Resolve the user's browser timezone once per circuit (interop is unavailable
                // during prerender, so this must happen after the first render).
                await Tz.EnsureResolvedAsync();

                var teamCode = TeamAccess.GetTeamCodeFromUrl();
                _user = await CurrentUser.GetUserAsync();

                if (_user == null)
                {
                    var ret = teamCode != null ? $"/team/{teamCode}" : "/";
                    Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(ret)}", forceLoad: true);
                    return;
                }

                _team = await TeamAccess.GetCurrentTeamAsync();

                if (_team == null)
                {
                    if (teamCode != null)
                    {
                        // Authenticated but not a member of this team
                        Navigation.NavigateTo($"/join?team={teamCode}", forceLoad: true);
                    }
                    else
                    {
                        Navigation.NavigateTo("/", forceLoad: true);
                    }
                    return;
                }

                _isCaptain = _team.CaptainUserId == _user.Id;
                _userTeams = await MembershipService.GetTeamsForUserAsync(_user.Id);

                _myPlayer = await PlayerService.GetUserPlayerInTeamAsync(_team.Id, _user.Id);

                var allPlayers = await PlayerService.GetByTeamAsync(_team.Id);
                _teamPlayersWithUser = allPlayers.Where(p => p.UserId.HasValue).ToList();

                Presence.Changed += OnPresenceChanged;
                GameRooms.Changed += OnPresenceChanged;
                _presenceSubscribed = true;

                // Gate: if user has no Player in this team, redirect to claim screen
                // (except when we're already on the claim page)
                var path = new Uri(Navigation.Uri).AbsolutePath;
                if (_myPlayer == null && !path.EndsWith("/claim", StringComparison.OrdinalIgnoreCase))
                {
                    Navigation.NavigateTo($"/team/{_team.CodeName}/claim", forceLoad: true);
                    return;
                }

                _loading = false;
                StateHasChanged();
            }
            catch
            {
                _loading = false;
                StateHasChanged();
            }
        }
    }
}
