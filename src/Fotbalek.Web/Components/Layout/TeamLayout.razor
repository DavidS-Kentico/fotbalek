@implements IDisposable
@inherits LayoutComponentBase
@inject TeamAccessService TeamAccess
@inject TeamService TeamService
@inject TeamMembershipService MembershipService
@inject PlayerService PlayerService
@inject CurrentUserService CurrentUser
@inject ShareTokenService ShareTokenService
@inject PresenceTracker Presence
@inject GameRoomManager GameRooms
@inject NavigationManager Navigation
@inject TimeZoneService Tz
@inject ChatUiState ChatUi
@inject IJSRuntime JS

@* Fallback title while the team loads (pages register their own <PageTitle> later in the
   render tree, so theirs wins once @Body renders). *@
<PageTitle>@(_team != null ? $"{_team.Name} - Foosball Manager" : "Foosball Manager")</PageTitle>

<div class="min-vh-100 d-flex flex-column">
    @if (_team != null && _user != null)
    {
        <header class="navbar navbar-expand-lg bg-body border-bottom shadow-sm team-navbar">
            <div class="container">
                @* ── Left: team (workspace) switcher ── *@
                <div class="dropdown team-switcher order-0 order-lg-1">
                    <button class="btn team-switcher-btn dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="@_team.Name">
                        <i class="bi bi-trophy-fill text-success"></i>
                        <span class="team-switcher-name text-truncate">@_team.Name</span>
                    </button>
                    <ul class="dropdown-menu">
                        <li><h6 class="dropdown-header">Your teams</h6></li>
                        @foreach (var team in _userTeams)
                        {
                            var chatUnread = ChatUi.GetUnread(team.Id);
                            <li>
                                <button type="button" class="dropdown-item d-flex align-items-center gap-2 @(team.Id == _team.Id ? "active" : "")" @onclick="() => SwitchTeam(team.CodeName)">
                                    <i class="bi bi-trophy"></i>
                                    <span class="text-truncate">@team.Name</span>
                                    @if (chatUnread > 0)
                                    {
                                        <span class="badge rounded-pill text-bg-danger ms-auto">@(chatUnread > 99 ? "99+" : chatUnread.ToString())</span>
                                    }
                                    @if (team.Id == _team.Id)
                                    {
                                        <i class="bi bi-check-lg @(chatUnread > 0 ? "" : "ms-auto")"></i>
                                    }
                                </button>
                            </li>
                        }
                        <li><hr class="dropdown-divider" /></li>
                        <li><a class="dropdown-item" href="/create"><i class="bi bi-plus-circle me-2"></i>Create team</a></li>
                        <li><a class="dropdown-item" href="/join"><i class="bi bi-box-arrow-in-right me-2"></i>Join team</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><a class="dropdown-item" href="/"><i class="bi bi-grid me-2"></i>Overview</a></li>
                    </ul>
                </div>

                @* Sections toggler (mobile only) *@
                <button class="navbar-toggler order-1 order-lg-1 ms-2" type="button" data-bs-toggle="collapse" data-bs-target="#teamSections" aria-controls="teamSections" aria-expanded="false" aria-label="Toggle sections">
                    <span class="navbar-toggler-icon"></span>
                </button>

                @* ── Right: actions + account ── *@
                <div class="d-flex align-items-center gap-2 navbar-actions order-2 order-lg-3 ms-auto ms-lg-0">
                    @{
                        var onlinePlayers = GetOnlinePlayers();
                    }
                    @if (onlinePlayers.Count > 0)
                    {
                        <div class="dropdown presence-dropdown d-none d-md-block">
                            <button class="btn presence-chip d-flex align-items-center gap-1" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="@($"{onlinePlayers.Count} online")">
                                <i class="bi bi-people-fill"></i>
                                <span>@onlinePlayers.Count</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end presence-menu">
                                <li><h6 class="dropdown-header">Online now</h6></li>
                                @foreach (var p in onlinePlayers)
                                {
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center gap-2" href="/team/@_team.CodeName/players/@p.Id">
                                            <span class="presence-avatar-wrap"><Avatar AvatarId="@p.AvatarId" Size="sm" Title="@p.Name" /><span class="presence-dot"></span></span>
                                            <span class="text-truncate">@p.Name</span>
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    @if (GameRooms.GetForTeam(_team.Id) is { } liveRoom)
                    {
                        var seated = liveRoom.GetState().Seats.Count(s => s.Occupied);
                        <a href="/team/@_team.CodeName/game" class="btn btn-outline-danger btn-sm d-flex align-items-center gap-2 live-pill"
                           title="@(seated < 4 ? "Live game — join or watch" : "Live game — watch")">
                            <span class="live-dot"></span>
                            <span class="d-none d-sm-inline">@seated/4 · @(seated < 4 ? "Join" : "Watch")</span>
                            <span class="d-sm-none">@seated/4</span>
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-outline-secondary btn-icon d-none d-md-inline-flex" title="Start live game" aria-label="Start live game" @onclick="StartLiveGame">
                            <i class="bi bi-controller"></i>
                        </button>
                    }

                    <a href="@($"/team/{_team.CodeName}/match/new")" class="btn btn-success d-flex align-items-center gap-1" aria-label="New match">
                        <i class="bi bi-plus-lg"></i> <span class="d-none d-lg-inline">New match</span>
                    </a>

                    <div class="dropdown">
                        <button class="btn btn-outline-secondary dropdown-toggle account-btn d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" aria-label="Account menu">
                            @if (_myPlayer != null)
                            {
                                <Avatar AvatarId="@_myPlayer.AvatarId" Size="sm" />
                            }
                            else
                            {
                                <i class="bi bi-person-circle"></i>
                            }
                            <span class="d-none d-xl-inline">@DisplayName</span>
                            @if (_isCaptain)
                            {
                                <span class="badge bg-warning text-dark d-none d-xl-inline">Captain</span>
                            }
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li class="px-3 py-1">
                                <div class="fw-semibold text-truncate">@DisplayName</div>
                                <div class="small text-muted text-truncate">@_user?.UserName</div>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            @if (_myPlayer != null)
                            {
                                <li>
                                    <a class="dropdown-item" href="/team/@_team.CodeName/players/@_myPlayer.Id">
                                        <i class="bi bi-person-badge me-2"></i>My player
                                    </a>
                                </li>
                            }
                            <li>
                                <a class="dropdown-item" href="/account">
                                    <i class="bi bi-person-circle me-2"></i>My account
                                </a>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form method="post" action="/account/logout" class="m-0">
                                    <AntiforgeryToken />
                                    <button type="submit" class="dropdown-item">
                                        <i class="bi bi-box-arrow-right me-2"></i>Sign out
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>

                @* ── Center: sections (collapsible) ── *@
                <div class="collapse navbar-collapse team-sections order-3 order-lg-2" id="teamSections">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <NavLink class="nav-link" href="@($"/team/{_team.CodeName}")" Match="NavLinkMatch.All">
                                <i class="bi bi-house me-1"></i> Dashboard
                            </NavLink>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(SectionActive("rankings", "stats", "matches") ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-graph-up-arrow me-1"></i> Insights
                            </a>
                            <ul class="dropdown-menu">
                                <li><NavLink class="dropdown-item" href="@($"/team/{_team.CodeName}/rankings")"><i class="bi bi-bar-chart me-2"></i>Rankings</NavLink></li>
                                <li><NavLink class="dropdown-item" href="@($"/team/{_team.CodeName}/stats")"><i class="bi bi-graph-up me-2"></i>Stats</NavLink></li>
                                <li><NavLink class="dropdown-item" href="@($"/team/{_team.CodeName}/matches")"><i class="bi bi-list-ul me-2"></i>History</NavLink></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(SectionActive("players", "seasons", "settings") ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-people me-1"></i> Team
                            </a>
                            <ul class="dropdown-menu">
                                <li><NavLink class="dropdown-item" href="@($"/team/{_team.CodeName}/players")"><i class="bi bi-people me-2"></i>Players</NavLink></li>
                                <li><NavLink class="dropdown-item" href="@($"/team/{_team.CodeName}/seasons")"><i class="bi bi-award me-2"></i>Seasons</NavLink></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button type="button" class="dropdown-item" @onclick="ShowShareModal"><i class="bi bi-share me-2"></i>Share team</button></li>
                                @if (_isCaptain)
                                {
                                    <li><a class="dropdown-item" href="/team/@_team.CodeName/settings"><i class="bi bi-gear me-2"></i>Team settings</a></li>
                                }
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        @if (_team.CaptainUserId == null)
        {
            <div class="alert alert-warning rounded-0 mb-0">
                <div class="container d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-exclamation-triangle me-2"></i>This team has no captain yet.</span>
                    <button class="btn btn-sm btn-warning" @onclick="ClaimCaptain" disabled="@_claimingCaptain">
                        @if (_claimingCaptain)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Become captain
                    </button>
                </div>
            </div>
        }

        <main class="flex-grow-1 bg-body-tertiary">
            <CascadingValue Value="_myPlayer?.Id" Name="MyPlayerId">
                @Body
            </CascadingValue>
        </main>

        <AppFooter />

        @* Global chat dock, hinting the current team as the default conversation. *@
        <ChatDock DefaultTeamId="_team.Id" />

        <Modal Show="_showShareModal" Title="Share Team" Icon="bi bi-share" OnClose="() => _showShareModal = false">
            <Body>
                <p class="text-muted">Share this link with your teammates so they can join without entering a password:</p>
                @if (_generatingToken)
                {
                    <div class="text-center py-3">
                        <div class="spinner-border spinner-border-sm text-success" role="status">
                            <span class="visually-hidden">Generating link...</span>
                        </div>
                    </div>
                }
                else if (!string.IsNullOrEmpty(_shareToken))
                {
                    <div class="input-group">
                        <input type="text" class="form-control" readonly value="@GetShareUrl()" />
                        <button class="btn btn-success" @onclick="CopyShareUrl">
                            <i class="bi @(_copied ? "bi-check" : "bi-clipboard")"></i>
                            @(_copied ? "Copied!" : "Copy")
                        </button>
                    </div>
                    @if (_copied)
                    {
                        <small class="text-success mt-2 d-block">Link copied to clipboard!</small>
                    }
                    <small class="text-muted mt-2 d-block">
                        <i class="bi bi-clock me-1"></i>This link expires in 24 hours.
                    </small>
                }
                <hr />
                <p class="text-muted mb-2 small">Or share the team URL (requires password + login):</p>
                <div class="input-group input-group-sm">
                    <input type="text" class="form-control" readonly value="@GetTeamUrl()" />
                    <button class="btn btn-outline-secondary" @onclick="CopyTeamUrl">
                        <i class="bi @(_copiedBasic ? "bi-check" : "bi-clipboard")"></i>
                    </button>
                </div>
            </Body>
            <Footer>
                <button type="button" class="btn btn-secondary" @onclick="() => _showShareModal = false">Close</button>
            </Footer>
        </Modal>
    }
    else if (_loading)
    {
        <LoadingSpinner FullScreen="true" />
    }
</div>

<div id="blazor-error-ui" data-nosnippet class="alert alert-danger position-fixed bottom-0 start-50 translate-middle-x mb-3" style="display: none;">
    An unhandled error has occurred.
    <a href="." class="alert-link">Reload</a>
    <button type="button" class="btn-close" onclick="this.parentElement.style.display='none'"></button>
</div>

@code {
    private Team? _team;
    private AppUser? _user;
    private Player? _myPlayer;
    private bool _loading = true;
    private bool _isCaptain;
    private bool _claimingCaptain;
    private bool _showShareModal;
    private bool _copied;
    private bool _copiedBasic;
    private bool _generatingToken;
    private string? _shareToken;
    private List<Team> _userTeams = new();
    private List<Player> _teamPlayersWithUser = new();
    private bool _presenceSubscribed;

    private string DisplayName => _myPlayer?.Name ?? _user?.UserName ?? "User";

    // The first route segment after /team/{code} — e.g. "rankings" on
    // /team/foo/rankings, or "" on the dashboard. Matched exactly so a team
    // whose code happens to contain a section word can't false-trigger.
    private string CurrentSection
    {
        get
        {
            var path = new Uri(Navigation.Uri).AbsolutePath;
            var prefix = $"/team/{_team?.CodeName}/";
            if (!path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)) return "";
            var rest = path[prefix.Length..];
            var slash = rest.IndexOf('/');
            return slash >= 0 ? rest[..slash] : rest;
        }
    }

    // Highlights a grouped section toggle (Insights / Team) when the current page
    // lives under one of its child routes.
    private bool SectionActive(params string[] segments)
        => segments.Contains(CurrentSection, StringComparer.OrdinalIgnoreCase);

    private List<Player> GetOnlinePlayers()
    {
        if (_teamPlayersWithUser.Count == 0) return new();
        return _teamPlayersWithUser
            .Where(p => p.UserId.HasValue && Presence.IsOnline(p.UserId.Value))
            .OrderBy(p => p.Name)
            .ToList();
    }

    private async void OnPresenceChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    // Re-render so the active-section highlight follows client-side navigation.
    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        if (_presenceSubscribed)
        {
            Presence.Changed -= OnPresenceChanged;
            GameRooms.Changed -= OnPresenceChanged;
            ChatUi.Changed -= OnPresenceChanged;
            Navigation.LocationChanged -= OnLocationChanged;
            _presenceSubscribed = false;
        }
    }

    private string GetTeamUrl()
    {
        var baseUrl = Navigation.BaseUri.TrimEnd('/');
        return $"{baseUrl}/team/{_team?.CodeName}";
    }

    private string GetShareUrl()
    {
        var baseUrl = Navigation.BaseUri.TrimEnd('/');
        return $"{baseUrl}/join?team={_team?.CodeName}&token={_shareToken}";
    }

    private async Task ShowShareModal()
    {
        _copied = false;
        _copiedBasic = false;
        _shareToken = null;
        _showShareModal = true;
        _generatingToken = true;
        StateHasChanged();

        try
        {
            if (_team != null && _user != null)
            {
                _shareToken = await ShareTokenService.GenerateTokenAsync(_team.Id, _user.Id);
            }
        }
        catch
        {
        }
        finally
        {
            _generatingToken = false;
            StateHasChanged();
        }
    }

    private async Task CopyShareUrl()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", GetShareUrl());
            _copied = true;
            _copiedBasic = false;
            StateHasChanged();
        }
        catch { }
    }

    private async Task CopyTeamUrl()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", GetTeamUrl());
            _copiedBasic = true;
            _copied = false;
            StateHasChanged();
        }
        catch { }
    }

    private void SwitchTeam(string codeName)
    {
        Navigation.NavigateTo($"/team/{codeName}", forceLoad: true);
    }

    private void StartLiveGame()
    {
        if (_team == null || _user == null) return;
        var room = GameRooms.GetOrCreateForTeam(_team.Id);
        // The seat sits in the not-yet-connected grace state until the game page's JS client
        // joins the room (§3.2).
        room.TryTakeFirstFreeSeat(_user.Id, DisplayName, _myPlayer?.AvatarId ?? 1);
        Navigation.NavigateTo($"/team/{_team.CodeName}/game");
    }

    private async Task ClaimCaptain()
    {
        if (_team == null || _user == null) return;
        _claimingCaptain = true;
        try
        {
            var success = await TeamService.TryClaimCaptainAsync(_team.Id, _user.Id);
            if (success)
            {
                _team.CaptainUserId = _user.Id;
                _isCaptain = true;
            }
        }
        finally
        {
            _claimingCaptain = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Resolve the user's browser timezone once per circuit (interop is unavailable
                // during prerender, so this must happen after the first render).
                await Tz.EnsureResolvedAsync();

                var teamCode = TeamAccess.GetTeamCodeFromUrl();
                _user = await CurrentUser.GetUserAsync();

                if (_user == null)
                {
                    var ret = teamCode != null ? $"/team/{teamCode}" : "/";
                    Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(ret)}", forceLoad: true);
                    return;
                }

                _team = await TeamAccess.GetCurrentTeamAsync();

                if (_team == null)
                {
                    if (teamCode != null)
                    {
                        // Authenticated but not a member of this team
                        Navigation.NavigateTo($"/join?team={teamCode}", forceLoad: true);
                    }
                    else
                    {
                        Navigation.NavigateTo("/", forceLoad: true);
                    }
                    return;
                }

                _isCaptain = _team.CaptainUserId == _user.Id;
                _userTeams = await MembershipService.GetTeamsForUserAsync(_user.Id);

                _myPlayer = await PlayerService.GetUserPlayerInTeamAsync(_team.Id, _user.Id);

                var allPlayers = await PlayerService.GetByTeamAsync(_team.Id);
                _teamPlayersWithUser = allPlayers.Where(p => p.UserId.HasValue).ToList();

                Presence.Changed += OnPresenceChanged;
                GameRooms.Changed += OnPresenceChanged;
                // Chat unread badges in the team switcher render from ChatUiState's cache,
                // maintained by the dock (a child can't re-render its parent).
                ChatUi.Changed += OnPresenceChanged;
                Navigation.LocationChanged += OnLocationChanged;
                _presenceSubscribed = true;

                // Gate: if user has no Player in this team, redirect to claim screen
                // (except when we're already on the claim page)
                var path = new Uri(Navigation.Uri).AbsolutePath;
                if (_myPlayer == null && !path.EndsWith("/claim", StringComparison.OrdinalIgnoreCase))
                {
                    Navigation.NavigateTo($"/team/{_team.CodeName}/claim", forceLoad: true);
                    return;
                }

                _loading = false;
                StateHasChanged();
            }
            catch
            {
                _loading = false;
                StateHasChanged();
            }
        }
    }
}
