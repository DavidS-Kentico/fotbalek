@inherits LayoutComponentBase
@using System.Security.Claims
@using Fotbalek.Web.Configuration

<div class="min-vh-100 d-flex flex-column">
    <header class="navbar navbar-expand navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center fw-bold" href="/admin">
                <i class="bi bi-shield-lock-fill me-2 text-warning"></i>
                Fotbalek Admin
            </a>

            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <NavLink class="nav-link" href="/admin" Match="NavLinkMatch.All">
                        <i class="bi bi-people me-1"></i> Users
                    </NavLink>
                </li>
            </ul>

            <div class="d-flex align-items-center gap-3">
                <AuthorizeView Policy="@AdminAuth.Policy">
                    <span class="navbar-text small text-white-50">
                        <i class="bi bi-person-circle me-1"></i>@GetAdminName(context.User)
                    </span>
                </AuthorizeView>
                <form method="post" action="/admin/auth/logout" class="m-0">
                    <AntiforgeryToken />
                    <button type="submit" class="btn btn-sm btn-outline-light">
                        <i class="bi bi-box-arrow-right me-1"></i> Sign out
                    </button>
                </form>
            </div>
        </div>
    </header>

    <main class="flex-grow-1 bg-body-tertiary">
        @Body
    </main>

    <AppFooter />
</div>

<div id="blazor-error-ui" data-nosnippet class="alert alert-danger position-fixed bottom-0 start-50 translate-middle-x mb-3" style="display: none;">
    An unhandled error has occurred.
    <a href="." class="alert-link">Reload</a>
    <button type="button" class="btn-close" onclick="this.parentElement.style.display='none'"></button>
</div>

@code {
    // With an admin-only session the principal's *primary* identity is the unauthenticated
    // default one, so User.Identity.Name is null — read the name off the admin identity.
    private static string? GetAdminName(ClaimsPrincipal user) =>
        user.Identities.FirstOrDefault(i => i.HasClaim(AdminAuth.ClaimType, "true"))?.Name;
}
